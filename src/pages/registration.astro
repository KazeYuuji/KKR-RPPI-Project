---
import PublicLayout from "../layouts/PublicLayout.astro";
import RegistrationForm from "../components/RegistrationForm.astro";
---
<PublicLayout title="Daftar Sekarang | KKR RPPI" description="Formulir pendaftaran KKR RPPI.">
  <div class="pb-12 pt-10 sm:pt-14">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="mb-6 grid gap-4 rounded-xl glass-card p-5 sm:grid-cols-[1fr_auto] sm:items-center">
        <div class="space-y-1">
          <p class="text-[11px] uppercase tracking-[0.3em] font-semibold text-kkr-red">Registrasi</p>
          <h1 class="text-2xl font-semibold leading-tight text-kkr-dark sm:text-3xl">Daftar Sekarang</h1>
          <p class="text-xs text-kkr-dark/70">Bergabunglah bersama kami dalam KKR RPPI.</p>
        </div>
        <div class="flex items-center gap-3 rounded-xl bg-white/70 p-3 sm:text-right">
          <div>
            <p class="text-[11px] uppercase tracking-[0.2em] text-kkr-maroon/70 font-medium">Tiket</p>
            <p class="text-xl font-semibold text-kkr-dark">GRATIS</p>
          </div>
          <div class="h-10 w-px bg-kkr-light/60"></div>
          <div>
            <p class="text-[11px] uppercase tracking-[0.2em] text-kkr-maroon/70 font-medium">Tersedia</p>
            <div id="ticket-info" class="space-y-0.5"></div>
          </div>
        </div>
      </div>

      <div class="grid gap-5 lg:grid-cols-[1.2fr_1fr]">
        <div class="rounded-xl glass-card p-5 sm:p-6">
          <RegistrationForm />
        </div>
        <aside class="space-y-4">
          <div class="rounded-xl glass-card p-5 text-center">
            <img src="/logo.png" alt="Logo Gereja" class="mx-auto h-20 w-20 sm:h-24 sm:w-24 rounded-full border-2 border-kkr-gold/40 bg-white p-2 object-contain shadow-md shadow-kkr-gold/20" id="reg-logo" />
            <p class="mt-2 text-[11px] uppercase tracking-[0.3em] font-semibold text-kkr-red">Detail Pendaftaran</p>
            <h2 class="mt-2 text-base font-semibold text-kkr-dark">Selangkah lagi!</h2>
            <p class="mt-2 text-xs text-kkr-dark/70 leading-5">Isi data diri dengan benar untuk mendapatkan tiket KKR RPPI.</p>
          </div>

          <div class="rounded-xl glass-card p-5">
            <div class="flex items-center gap-2">
              <p class="text-[11px] uppercase tracking-[0.3em] text-kkr-maroon/80 font-medium">Lokasi Acara</p>
            </div>
            <p id="reg-venue" class="mt-2 text-sm font-semibold text-kkr-dark">Memuat...</p>
            <p id="reg-address" class="mt-1 text-xs text-kkr-dark/70"></p>
            <div class="mt-3 overflow-hidden rounded-xl border border-white/20 relative">
              <iframe id="reg-maps" class="aspect-[16/9] w-full" style="filter:grayscale(0.15) contrast(1.05)" loading="lazy" allowfullscreen referrerpolicy="strict-origin-when-cross-origin"></iframe>
              <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-inset ring-black/5"></div>
            </div>
            <a id="gmaps-link" href="#" target="_blank" rel="noopener" class="mt-1.5 inline-flex items-center gap-1 text-xs text-kkr-red hover:underline">Buka di Google Maps &rarr;</a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <script>
    function escapeHtml(str) {
      if (str == null) return "";
      return String(str).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }

    function setGmaps(url, mapsLink) {
      var iframe = document.getElementById("reg-maps");
      var gmapLink = document.getElementById("gmaps-link");
      if (iframe && url) {
        iframe.src = url;
      }
      if (gmapLink && mapsLink) {
        gmapLink.href = mapsLink;
      }
    }

    async function osmCoords(venue, mapsLink) {
      try {
        var params = "venue=" + encodeURIComponent(venue || "Lokasi Acara");
        if (mapsLink) params += "&mapsLink=" + encodeURIComponent(mapsLink);
        var res = await fetch("/api/geocode?" + params);
        var data = await res.json();
        return data;
      } catch(e) {}
      return null;
    }

    async function loadSettings() {
      try {
        const s = await (window.__SETTINGS_CACHE || fetch("/api/settings").then(r => r.json()).then(d => d.settings || {}));
        const venue = s.locVenue || "Kediri";
        const mapsLink = s.locMapsLink || "";
        const logoUrl = s.churchLogo || "/logo.png";
        document.getElementById("reg-logo") && (document.getElementById("reg-logo").src = logoUrl);
        document.getElementById("reg-venue").textContent = venue;
        document.getElementById("reg-address").textContent = "Lihat peta di bawah";
        osmCoords(venue, mapsLink).then(function(data) {
          if (data && data.url) {
            setGmaps(data.url, mapsLink);
          }
        });
      } catch {}
    }

    async function loadTickets() {
      try {
        const res = await fetch("/api/tickets");
        const d = await res.json();
        const list = d.tickets || [];
        const info = document.getElementById("ticket-info");
        info.innerHTML = list.map(t => {
          const habis = t.remaining <= 0;
          return '<div class="flex items-center justify-between gap-2 ' + (habis ? "text-red-700" : "text-kkr-dark") + '">' +
            '<span class="text-xs font-medium truncate">' + escapeHtml(t.name) + '</span>' +
            '<span class="text-[11px] shrink-0 ' + (habis ? "text-red-500 font-semibold" : "text-kkr-dark/60") + '">' + (habis ? "Habis" : "Sisa " + t.remaining) + '</span>' +
          "</div>";
        }).join("");
      } catch {}
    }

    document.addEventListener("DOMContentLoaded", function() { loadSettings(); loadTickets(); setInterval(loadTickets, 10000); });
  </script>
</PublicLayout>
