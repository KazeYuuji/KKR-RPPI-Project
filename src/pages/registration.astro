---
import PublicLayout from "../layouts/PublicLayout.astro";
import RegistrationForm from "../components/RegistrationForm.astro";
---
<PublicLayout title="Daftar Sekarang | KKR RPPI" description="Formulir pendaftaran KKR RPPI.">
  <div class="pb-16 pt-10 sm:pt-14">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <!-- Hero Banner -->
      <div class="relative mb-8 overflow-hidden rounded-2xl bg-gradient-to-br from-kkr-dark/90 via-kkr-purple/70 to-kkr-maroon/60 p-6 sm:p-8 shadow-xl border border-white/10 backdrop-blur-sm">
        <div class="pointer-events-none absolute -top-24 -right-24 h-48 w-48 rounded-full bg-kkr-gold/15 blur-3xl"></div>
        <div class="pointer-events-none absolute -bottom-16 -left-16 h-40 w-40 rounded-full bg-kkr-red/15 blur-3xl"></div>
        <div class="relative z-10 grid gap-5 sm:grid-cols-[1fr_auto] sm:items-center">
          <div class="space-y-2">
            <div class="flex items-center gap-2">
              <span class="inline-block h-px w-6 bg-kkr-gold/60"></span>
              <p id="reg-section-label" class="text-[11px] uppercase tracking-[0.3em] font-semibold text-kkr-gold">Registrasi</p>
            </div>
            <h1 id="reg-heading" class="text-2xl font-bold leading-tight text-white sm:text-3xl">Daftar Sekarang</h1>
            <p id="reg-description" class="text-sm text-white/70 max-w-md">Bergabunglah bersama kami dalam KKR RPPI.</p>
          </div>
          <div class="flex items-center gap-4 rounded-xl bg-white/10 p-3.5 sm:p-4 backdrop-blur-sm border border-white/10">
            <div class="text-center">
              <p class="text-[10px] uppercase tracking-[0.2em] text-kkr-gold/80 font-medium">Tiket</p>
              <p class="text-2xl font-bold text-white">GRATIS</p>
            </div>
            <div class="h-12 w-px bg-white/15"></div>
            <div>
              <p class="text-[10px] uppercase tracking-[0.2em] text-kkr-gold/80 font-medium">Tersedia</p>
              <div id="ticket-info" class="space-y-0.5 mt-0.5"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="grid gap-6 lg:grid-cols-[1.3fr_1fr]">
        <!-- Form -->
        <div class="rounded-2xl bg-white/95 p-5 sm:p-7 shadow-lg shadow-black/10 border border-white/40 backdrop-blur-sm">
          <RegistrationForm />
        </div>

        <!-- Sidebar -->
        <aside class="space-y-5">
          <!-- Logo Card -->
          <div class="relative overflow-hidden rounded-2xl bg-white/95 p-6 text-center shadow-lg shadow-black/10 border border-white/40 backdrop-blur-sm">
            <div class="pointer-events-none absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-kkr-red via-kkr-gold to-kkr-maroon"></div>
            <div class="relative">
              <div class="mx-auto flex h-24 w-24 sm:h-28 sm:w-28 items-center justify-center rounded-full border-2 border-kkr-gold/40 bg-gradient-to-br from-white to-kkr-light/30 p-2 shadow-lg shadow-kkr-gold/20">
                <img src="/logo-header.png" alt="Logo Gereja" class="h-full w-full object-contain rounded-full" id="reg-logo" />
              </div>
              <div class="mt-4 space-y-1">
                <p id="reg-sidebar-badge" class="text-[11px] uppercase tracking-[0.3em] font-semibold text-kkr-red">Detail Pendaftaran</p>
                <h2 id="reg-sidebar-title" class="text-lg font-semibold text-kkr-dark">Selangkah lagi!</h2>
                <p id="reg-sidebar-desc" class="text-xs text-kkr-dark/60 leading-relaxed">Isi data diri dengan benar untuk mendapatkan tiket KKR RPPI.</p>
              </div>
            </div>
          </div>

          <!-- Location Card -->
          <div class="rounded-2xl bg-white/95 p-5 shadow-lg shadow-black/10 border border-white/40 backdrop-blur-sm">
            <div class="flex items-center gap-2 mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-kkr-red" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <p id="reg-location-label" class="text-[11px] uppercase tracking-[0.3em] text-kkr-maroon/80 font-medium">Lokasi Acara</p>
            </div>
            <p id="reg-venue" class="text-sm font-semibold text-kkr-dark">Memuat...</p>
            <p id="reg-address" class="mt-1 text-xs text-kkr-dark/60"></p>
            <div class="mt-3 overflow-hidden rounded-xl border border-kkr-light/30 relative shadow-sm">
              <iframe id="reg-maps" title="Peta Lokasi Acara" class="aspect-[16/9] w-full" style="filter:grayscale(0.15) contrast(1.05)" loading="lazy" allowfullscreen referrerpolicy="strict-origin-when-cross-origin"></iframe>
              <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-inset ring-black/5"></div>
            </div>
            <a id="gmaps-link" href="#" target="_blank" rel="noopener" class="mt-2 inline-flex items-center gap-1.5 text-xs text-kkr-red font-medium hover:underline transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              <span id="reg-maps-btn-text">Buka di Google Maps &rarr;</span>
            </a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <script>
    function escapeHtml(str) {
      if (str == null) return "";
      return String(str).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }

    function setGmaps(url, mapsLink) {
      var iframe = document.getElementById("reg-maps");
      var gmapLink = document.getElementById("gmaps-link");
      if (iframe && url) {
        iframe.src = url;
      }
      if (gmapLink && mapsLink) {
        gmapLink.href = mapsLink;
      }
    }

    async function osmCoords(venue, mapsLink) {
      try {
        var params = "venue=" + encodeURIComponent(venue || "Lokasi Acara");
        if (mapsLink) params += "&mapsLink=" + encodeURIComponent(mapsLink);
        var res = await fetch("/api/geocode?" + params);
        var data = await res.json();
        return data;
      } catch(e) {}
      return null;
    }

    async function loadSettings() {
      try {
        const s = await (window.__SETTINGS_CACHE || fetch("/api/settings").then(r => r.json()).then(d => d.settings || {}));
        const venue = s.locVenue || "Kediri";
        const mapsLink = s.locMapsLink || "";
        const logoUrl = s.churchLogo || "/logo-header.png";
        document.getElementById("reg-logo") && (document.getElementById("reg-logo").src = logoUrl);
        document.getElementById("reg-venue").textContent = venue;
        document.getElementById("reg-address").textContent = s.locAddress || "Lihat peta di bawah";

        // Registration page labels
        const regLabelIds = ["reg-section-label","reg-heading","reg-description","reg-sidebar-badge","reg-sidebar-title","reg-sidebar-desc","reg-location-label","reg-maps-btn-text"];
        const regLabelKeys = ["regSectionLabel","regHeading","regDescription","regSidebarBadge","regSidebarTitle","regSidebarDesc","regLocationLabel","regMapsBtnText"];
        const regLabelFalls = ["Registrasi","Daftar Sekarang","Bergabunglah bersama kami dalam KKR RPPI.","Detail Pendaftaran","Selangkah lagi!","Isi data diri dengan benar untuk mendapatkan tiket KKR RPPI.","Lokasi Acara","Buka di Google Maps \u2192"];
        regLabelIds.forEach((id, i) => {
          const el = document.getElementById(id);
          if (el) el.textContent = s[regLabelKeys[i]] || regLabelFalls[i];
        });

        osmCoords(venue, mapsLink).then(function(data) {
          if (data && data.url) {
            setGmaps(data.url, mapsLink);
          }
        });
      } catch {}
    }

    async function loadTickets() {
      try {
        const res = await fetch("/api/tickets");
        const d = await res.json();
        const list = d.tickets || [];
        const info = document.getElementById("ticket-info");
        info.innerHTML = list.map(t => {
          const habis = t.remaining <= 0;
          return '<div class="flex items-center justify-between gap-2 ' + (habis ? "text-red-300" : "text-white/90") + '">' +
            '<span class="text-xs font-medium truncate">' + escapeHtml(t.name) + '</span>' +
            '<span class="text-[10px] shrink-0 ' + (habis ? "text-red-400 font-semibold" : "text-kkr-gold/80") + '">' + (habis ? "Habis" : "Sisa " + t.remaining) + '</span>' +
          "</div>";
        }).join("");
      } catch {}
    }

    document.addEventListener("DOMContentLoaded", function() { loadSettings(); loadTickets(); var ti = setInterval(loadTickets, 10000); document.addEventListener("visibilitychange", function() { if (document.hidden) clearInterval(ti); else loadTickets(); }); });
  </script>
</PublicLayout>
