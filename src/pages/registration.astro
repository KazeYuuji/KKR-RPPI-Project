---
import PublicLayout from "../layouts/PublicLayout.astro";
import RegistrationForm from "../components/RegistrationForm.astro";
---
<PublicLayout title="Daftar Sekarang | KKR RPPI" description="Formulir pendaftaran KKR RPPI.">
  <div class="pb-24 pt-16 sm:pt-20">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-12 grid gap-6 rounded-[2rem] glass-card p-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
        <div class="space-y-4">
          <p class="uppercase tracking-[0.35em] text-sm font-semibold text-kkr-red">Registrasi</p>
          <h1 class="text-4xl font-semibold leading-tight text-kkr-dark sm:text-5xl">Daftar Sekarang</h1>
          <p class="max-w-2xl text-kkr-dark/80">Bergabunglah bersama kami dalam KKR RPPI yang penuh kedamaian dan sukacita. Silakan lengkapi formulir di bawah ini.</p>
        </div>
        <div class="rounded-[1.75rem] glass-card p-6">
          <p class="text-sm uppercase tracking-[0.3em] text-kkr-maroon/80">Informasi Tiket</p>
          <p class="mt-4 text-3xl font-semibold text-kkr-dark">GRATIS</p>
          <p class="mt-3 text-sm text-kkr-dark/70">Event ini diselenggarakan secara gratis untuk semua peserta.</p>
          <div class="mt-6 space-y-4 rounded-[1.75rem] bg-white/80 p-5">
            <div>
              <p class="text-sm font-semibold text-kkr-dark">Daftar Tiket Tersedia</p>
              <div id="ticket-info" class="mt-2 space-y-2"></div>
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-10 lg:grid-cols-[1.3fr_0.9fr]">
        <div class="rounded-[2rem] glass-card p-8 sm:p-10">
          <RegistrationForm />
        </div>
        <aside class="space-y-6">
          <div class="rounded-[2rem] glass-card p-8 text-center">
            <img src="/logo.png" alt="Logo Gereja" class="mx-auto h-14 w-14 sm:h-16 sm:w-16 rounded-full border-2 border-kkr-gold/40 bg-white/10 p-1 object-contain shadow-lg shadow-kkr-gold/20" id="reg-logo" />
            <p class="mt-4 text-sm uppercase tracking-[0.3em] text-kkr-red">Detail Pendaftaran</p>
            <h2 class="mt-4 text-2xl font-semibold text-kkr-dark">Selangkah lagi untuk konfirmasi tiket</h2>
            <p class="mt-4 text-kkr-dark/70 leading-7">Isi data diri dengan benar untuk mendapatkan tiket KKR RPPI.</p>
          </div>

          <div class="rounded-[2rem] glass-card p-8">
            <div class="flex items-center gap-3">
              <img src="/logo.png" alt="Logo Gereja" class="h-10 w-10 rounded-full border border-kkr-gold/30 bg-white/10 p-0.5 object-contain shrink-0" id="reg-loc-logo" />
              <p class="text-sm uppercase tracking-[0.3em] text-kkr-maroon/80">Lokasi Acara</p>
            </div>
            <p id="reg-venue" class="mt-4 text-lg font-semibold text-kkr-dark">Memuat...</p>
            <p id="reg-address" class="mt-3 text-sm text-kkr-dark/70"></p>
            <div class="mt-6 overflow-hidden rounded-[1.5rem] border border-white/20 relative">
              <iframe id="reg-maps" class="aspect-[16/9] w-full" style="filter:grayscale(0.15) contrast(1.05)" loading="lazy" allowfullscreen referrerpolicy="strict-origin-when-cross-origin"></iframe>
              <div class="pointer-events-none absolute inset-0 rounded-[1.5rem] ring-1 ring-inset ring-black/5"></div>
            </div>
            <a id="gmaps-link" href="#" target="_blank" rel="noopener" class="mt-3 inline-flex items-center gap-2 text-sm text-kkr-red hover:underline">Buka di Google Maps &rarr;</a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <script>
    function escapeHtml(str) {
      if (str == null) return "";
      return String(str).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }

    function setGmaps(url, mapsLink) {
      var iframe = document.getElementById("reg-maps");
      var gmapLink = document.getElementById("gmaps-link");
      if (iframe && url) {
        iframe.src = url;
      }
      if (gmapLink && mapsLink) {
        gmapLink.href = mapsLink;
      }
    }

    async function osmCoords(venue, mapsLink) {
      try {
        var params = "venue=" + encodeURIComponent(venue || "Lokasi Acara");
        if (mapsLink) params += "&mapsLink=" + encodeURIComponent(mapsLink);
        var res = await fetch("/api/geocode?" + params);
        var data = await res.json();
        return data;
      } catch(e) {}
      return null;
    }

    async function loadSettings() {
      try {
        const res = await fetch("/api/settings");
        const d = await res.json();
        const s = d.settings || {};
        const venue = s.locVenue || "Kediri";
        const mapsLink = s.locMapsLink || "";
        const logoUrl = s.churchLogo || "/logo.png";
        document.getElementById("reg-logo") && (document.getElementById("reg-logo").src = logoUrl);
        document.getElementById("reg-loc-logo") && (document.getElementById("reg-loc-logo").src = logoUrl);
        document.getElementById("reg-venue").textContent = venue;
        document.getElementById("reg-address").textContent = "Lihat peta di bawah";
        osmCoords(venue, mapsLink).then(function(data) {
          if (data && data.url) {
            setGmaps(data.url, mapsLink);
          }
        });
      } catch {}
    }

    async function loadTickets() {
      try {
        const res = await fetch("/api/tickets");
        const d = await res.json();
        const list = d.tickets || [];
        const info = document.getElementById("ticket-info");
        info.innerHTML = list.map(t => {
          const habis = t.remaining <= 0;
          return '<div class="flex items-center justify-between rounded-xl ' + (habis ? "bg-red-50 border border-red-200" : "bg-white/90 border border-white/30") + ' px-4 py-3 text-sm">' +
            '<span class="font-medium ' + (habis ? "text-red-700" : "text-kkr-dark") + '">' + escapeHtml(t.name) + '</span>' +
            '<span class="' + (habis ? "text-red-600 font-semibold" : "text-kkr-dark/70") + '">' + (habis ? "Habis" : "Sisa " + t.remaining) + '</span>' +
          "</div>";
        }).join("");
      } catch {}
    }

    document.addEventListener("DOMContentLoaded", function() { loadSettings(); loadTickets(); setInterval(loadTickets, 10000); });
  </script>
</PublicLayout>
