---
import PublicLayout from "../layouts/PublicLayout.astro";
---

<PublicLayout title="Halaman Tidak Ditemukan | KKR RPPI">
  <div class="flex min-h-[70vh] items-center justify-center px-6">
    <div class="text-center max-w-lg">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-white/10 mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-kkr-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <h1 class="text-6xl sm:text-8xl font-black text-white leading-none tracking-tight">404</h1>
      <p class="mt-4 text-xl text-kkr-light/80 font-medium">Halaman tidak ditemukan</p>
      <p class="mt-2 text-kkr-light/60">Halaman yang Anda cari mungkin telah dipindahkan atau tidak tersedia.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/" class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-kkr-maroon to-kkr-red px-6 py-3 text-sm font-semibold text-white transition hover:shadow-xl">
          Kembali ke Beranda
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </a>
        <a href="/registration" class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/20">
          Daftar Sekarang
        </a>
      </div>
    </div>
  </div>
</PublicLayout>
