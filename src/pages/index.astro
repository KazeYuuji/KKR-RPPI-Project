          return;
        }

        let currentIndex = 0;
        const storyLabel = (document.getElementById("section-label-story")?.textContent) || "Story Pembicara";
        const btnPrev = container.dataset.btnPrev || "Sebelumnya";
        const btnNext = container.dataset.btnNext || "Selanjutnya";

        function renderSpeaker(index) {
          const s = list[index];
          const total = list.length;
          container.innerHTML = `
            <div class="glass-card rounded-3xl p-8 sm:p-10 md:p-12">
              <div class="grid gap-8 sm:grid-cols-[1fr_1.8fr] sm:items-center">
                <div class="flex flex-col items-center sm:items-start text-center sm:text-left">
                  ${s.photo_url
                    ? `<img src="${escapeHtml(sanitizeUrl(s.photo_url))}" loading="lazy" decoding="async" class="w-40 h-40 sm:w-48 sm:h-48 md:w-56 md:h-56 rounded-2xl object-cover shadow-xl ring-2 ring-white/20" alt="${escapeHtml(s.name)}" />`
                    : `<div class="w-40 h-40 sm:w-48 sm:h-48 md:w-56 md:h-56 rounded-2xl bg-gradient-to-br from-kkr-light/80 to-white flex items-center justify-center shadow-xl ring-2 ring-white/20"><svg xmlns="http://www.w3.org/2000/svg" class="w-20 h-20 text-kkr-red/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg></div>`
                  }
                  ${s.title ? `<span class="inline-block text-[11px] font-semibold uppercase tracking-wider text-kkr-red bg-kkr-light/80 px-3 py-1 rounded-full mt-5">${escapeHtml(s.title)}</span>` : ""}
                  <h3 class="text-2xl sm:text-3xl font-bold text-kkr-dark mt-2">${escapeHtml(s.name)}</h3>
                  ${s.organization ? `<p class="text-base text-kkr-dark/60 mt-1">${escapeHtml(s.organization)}</p>` : ""}
                  ${s.tags && typeof s.tags === 'string' ? `<div class="flex flex-wrap gap-2 mt-4 justify-center sm:justify-start">${s.tags.split(",").map(t => `<span class="text-[11px] bg-kkr-light text-kkr-red px-3 py-1 rounded-full font-semibold">${escapeHtml(t.trim())}</span>`).join("")}</div>` : ""}
                  ${s.description ? `<p class="mt-4 text-sm text-kkr-dark/70 leading-relaxed">${escapeHtml(s.description)}</p>` : ""}
                </div>
                <div class="relative flex flex-col justify-center ${s.story ? '' : 'items-center justify-center'}">
                  ${s.story ? `
                    <svg class="absolute -top-2 -left-1 w-9 h-9 text-kkr-red/15" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/></svg>
                    <p class="text-sm sm:text-base text-kkr-dark/80 leading-8 italic pl-10">${escapeHtml(s.story)}</p>
                  ` : `<p class="text-sm text-kkr-dark/40 italic">Belum ada kisah.</p>`}
                </div>
              </div>
              ${total > 1 ? `
              <div class="flex items-center justify-center gap-5 mt-8 pt-5 border-t border-kkr-light/40">
                <button id="sp-prev" class="rounded-full bg-kkr-light/60 hover:bg-kkr-light px-5 py-2.5 text-sm font-semibold text-kkr-dark transition active:scale-95" ${index === 0 ? 'disabled style="opacity:0.3;cursor:not-allowed"' : ''}>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 inline -ml-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
                  ${escapeHtml(btnPrev)}
