        }

        // Event info card labels
        if (s.eventCardLabelPada && safe("event-card-label-pada")) safe("event-card-label-pada").textContent = s.eventCardLabelPada;
        if (s.eventCardLabelPukul && safe("event-card-label-pukul")) safe("event-card-label-pukul").textContent = s.eventCardLabelPukul;
