                <span class="text-sm text-kkr-dark/40 font-semibold tabular-nums">${index + 1} / ${total}</span>
                <button id="sp-next" class="rounded-full bg-kkr-light/60 hover:bg-kkr-light px-5 py-2.5 text-sm font-semibold text-kkr-dark transition active:scale-95" ${index === total - 1 ? 'disabled style="opacity:0.3;cursor:not-allowed"' : ''}>
