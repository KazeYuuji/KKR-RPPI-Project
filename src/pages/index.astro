        if (s.ctaDesc && safe("cta-desc")) safe("cta-desc").textContent = s.ctaDesc;

        // Section labels and headings
        if (s.sectionLabelSpeakers && safe("section-label-speakers")) safe("section-label-speakers").textContent = s.sectionLabelSpeakers;
        if (s.sectionHeadingSpeakers && safe("section-heading-speakers")) safe("section-heading-speakers").textContent = s.sectionHeadingSpeakers;
        if (s.sectionLabelStory && safe("section-label-story")) safe("section-label-story").textContent = s.sectionLabelStory;
        if (s.btnSpeakerPrev && safe("speaker-grid")) safe("speaker-grid").dataset.btnPrev = s.btnSpeakerPrev;
        if (s.btnSpeakerNext && safe("speaker-grid")) safe("speaker-grid").dataset.btnNext = s.btnSpeakerNext;
        if (s.sectionLabelAltar && safe("section-label-altar")) safe("section-label-altar").textContent = s.sectionLabelAltar;
        if (s.sectionHeadingAltar && safe("section-heading-altar")) safe("section-heading-altar").textContent = s.sectionHeadingAltar;
        if (s.sectionDescAltar && safe("section-desc-altar")) safe("section-desc-altar").textContent = s.sectionDescAltar;
