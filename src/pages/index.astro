          if (total > 1) {
            document.getElementById("sp-prev")?.addEventListener("click", () => {
              if (currentIndex > 0) { currentIndex--; renderSpeaker(currentIndex); }
            });
            document.getElementById("sp-next")?.addEventListener("click", () => {
              if (currentIndex < total - 1) { currentIndex++; renderSpeaker(currentIndex); }
            });
          }
        }

        renderSpeaker(0);
      } catch {
        document.getElementById("speaker-grid").innerHTML = `<div class="text-center py-12 text-red-500"><p>Gagal memuat pembicara.</p></div>`;
      }
    }

    function marquee(el) {
      if (!el) return;
      el.classList.add("mq-track");
      let pos = 0, running = true, id = null;
      function tick() {
        if (!running) return;
        pos -= 0.5;
        const full = el.scrollWidth / 2;
        if (pos <= -full || Math.abs(pos) >= full) { pos = 0; }
        el.style.transform = "translateX(" + pos + "px)";
        id = requestAnimationFrame(tick);
      }
      el.addEventListener("mouseenter", function () {
        running = false;
        if (id) cancelAnimationFrame(id);
      });
      el.addEventListener("mouseleave", function () {
        if (id) cancelAnimationFrame(id);
        running = true;
        id = requestAnimationFrame(tick);
      });
      id = requestAnimationFrame(tick);
    }

    async function loadAltarServers() {
