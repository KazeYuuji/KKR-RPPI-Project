---
import PublicLayout from "../layouts/PublicLayout.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import Countdown from "../components/Countdown.astro";
import ChatBot from "../components/ChatBot.astro";

---

<PublicLayout title="KKR RPPI | Kebangunan Rohani dalam Yesus Kristus" description="KKR RPPI mempersatukan pelajar, alumni, dan masyarakat dalam kebangunan rohani Yesus Kristus.">
  <div class="space-y-16 sm:space-y-24 pb-24">
    <!-- Hero -->
    <section id="home" class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
      <div class="absolute inset-0 z-0 overflow-hidden">
        <video autoplay muted loop playsinline preload="metadata" poster="/logo-small.png" class="h-full w-full object-cover" src="/videos/hero-bg.mp4"></video>
      </div>
      <div class="absolute inset-0 bg-gradient-to-br from-kkr-dark/85 via-kkr-purple/40 to-kkr-maroon/20"></div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 w-full">
        <div class="grid gap-12 lg:grid-cols-1 lg:items-center justify-items-center">
          <div class="space-y-8 text-white relative z-10 animate-fade-in text-center">
            <p id="hero-subtitle-label" class="section-text text-sm uppercase tracking-[0.3em]">Ibadah Kebaktian Kebangunan Rohani</p>
            <h1 id="hero-heading" class="hero-text-shadow text-5xl sm:text-6xl md:text-7xl xl:text-[6rem] font-black leading-[0.9] tracking-[-0.04em]">
              <span id="hero-line1" class="text-white">TRUST</span><br />
              <span id="hero-line2" class="text-kkr-gold">IN</span><br />
              <span id="hero-line3" class="text-kkr-light">GOD</span>
            </h1>
            <div id="hero-titles" class="space-y-1 max-w-xl mx-auto hidden">
              <p id="hero-title1" class="text-lg text-white/80"></p>
              <p id="hero-title2" class="text-xl text-kkr-red font-semibold"></p>
            </div>
            <div class="max-w-xl space-y-4 mx-auto">
              <p id="hero-verse" class="hero-copy text-lg sm:text-xl leading-9 max-w-3xl">Percayalah kepada TUHAN dengan segenap hatimu dan janganlah bersandar kepada pengertianmu sendiri.</p>
              <p id="hero-verse-ref" class="text-sm uppercase tracking-[0.24em] text-kkr-gold">Amsal 3:5</p>
            </div>
            <div id="hero-event-info" class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-white/80 justify-center"></div>
            <div class="flex flex-wrap gap-4 justify-center">
              <a href="/registration" class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-kkr-maroon to-kkr-red px-7 py-4 text-sm font-semibold text-white shadow-xl shadow-kkr-maroon/30 transition hover:-translate-y-0.5 hover:shadow-2xl">
                <span id="btn-hero-primary">Daftar Sekarang</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
              <a href="#about" class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-7 py-4 text-sm font-semibold text-white transition hover:bg-white/20 hover:text-white">
                <span id="btn-hero-secondary">Info Acara</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Tentang Acara -->
    <ScrollReveal>
      <section id="about" class="scroll-mt-20 mx-auto max-w-7xl px-6">
        <div class="grid gap-10 lg:grid-cols-[1fr_0.8fr] items-start">
          <div class="glass-card space-y-6 rounded-[2.5rem] p-8 sm:p-10">
            <div class="flex items-center gap-3">
              <span class="inline-block w-8 h-px bg-kkr-red"></span>
              <span id="about-section-label" class="text-sm font-semibold uppercase tracking-[0.25em] text-kkr-red">Tentang Acara</span>
            </div>
            <h2 id="about-heading" class="text-3xl sm:text-4xl font-semibold text-kkr-dark leading-tight">KKR dengan Sukacita & Syukur</h2>
            <div class="space-y-6 max-w-prose">
              <p id="about-desc1" class="text-kkr-dark/90 leading-8">KKR RPPI 2025/2026 adalah kebaktian kebangunan rohani yang mempersatukan pelajar, alumni, dan masyarakat dari berbagai sekolah di Kediri. Sebuah momen untuk merenungkan kasih Tuhan dan mengalami pembaharuan iman.</p>
              <p id="about-desc2" class="text-kkr-dark/90 leading-8">Bersama pembicara tamu dari Surabaya, kita akan merenungkan makna kebangunan rohani yang sesungguhnya — bahwa pertobatan dan pembaharuan membawa kita lebih dekat kepada Tuhan, sesuai dengan firman dalam 2 Tawarikh 7:14.</p>
            </div>
            <div id="about-cards" class="grid gap-4 sm:grid-cols-2 mt-6 hidden">
              <div class="rounded-xl bg-kkr-light/50 p-5 border border-kkr-light/60">
                <h4 id="about-card1-title" class="font-semibold text-kkr-dark"></h4>
                <p id="about-card1-desc" class="text-sm text-kkr-dark/70 mt-1 leading-relaxed"></p>
              </div>
              <div class="rounded-xl bg-kkr-light/50 p-5 border border-kkr-light/60">
                <h4 id="about-card2-title" class="font-semibold text-kkr-dark"></h4>
                <p id="about-card2-desc" class="text-sm text-kkr-dark/70 mt-1 leading-relaxed"></p>
              </div>
            </div>
            <blockquote id="about-blockquote" class="border-l-4 border-kkr-red pl-6 py-3 italic text-kkr-dark/80">
              "Jika umat-Ku yang disebut dengan nama-Ku merendahkan diri, berdoa dan mencari wajah-Ku, maka Aku akan mendengar dari sorga."
              <br/><span id="about-blockquote-ref" class="text-sm not-italic text-kkr-dark/60 font-medium">— 2 Tawarikh 7:14</span>
            </blockquote>

          </div>

          <div class="space-y-4">
            <div class="rounded-[2.5rem] border border-kkr-light/30 bg-white p-8 shadow-2xl shadow-black/30">
              <div class="space-y-8">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex items-center gap-4">
                    <div class="flex items-center gap-3">
                      <img src="/logo-small.png" alt="KKR RPPI" class="h-16 w-16 sm:h-20 sm:w-20 rounded-2xl border border-kkr-gold/40 bg-white/90 p-2 object-contain shadow-lg shadow-kkr-gold/20" />
                      <img src="/logo-header.png" alt="KKR RPPI" class="h-16 w-16 sm:h-20 sm:w-20 rounded-full border-2 border-kkr-gold/40 bg-white/90 p-1.5 object-contain shadow-lg shadow-kkr-gold/20" />
                    </div>
                    <div id="event-card-brand-container" class="flex flex-col">
                      <span class="text-lg sm:text-xl font-bold text-kkr-dark leading-tight">KKR</span>
                      <span class="text-lg sm:text-xl font-bold text-kkr-gold leading-tight">RPPI</span>
                    </div>
                  </div>
                  <span id="event-card-badge" class="shrink-0 inline-flex items-center gap-2 rounded-full bg-kkr-gold/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-kkr-red">Terbuka untuk umum</span>
                </div>
                <div class="space-y-3">
                  <p id="event-card-label-pada" class="text-xs uppercase tracking-[0.24em] text-kkr-maroon/60">Pada</p>
                  <h2 id="event-card-date" class="text-4xl font-semibold text-kkr-dark">Memuat...</h2>
                  <p id="event-card-venue" class="text-sm text-kkr-maroon/70">Memuat...</p>
                </div>
                <div class="grid gap-4 sm:grid-cols-2">
                  <div class="rounded-[2rem] bg-kkr-dark/90 p-5 border border-white/10">
                    <p id="event-card-label-pukul" class="text-xs uppercase tracking-[0.22em] text-kkr-gold/90">Pukul</p>
                    <p id="event-card-time" class="mt-2 text-2xl font-semibold text-white">Memuat...</p>
                  </div>
                  <div class="rounded-[2rem] bg-kkr-purple/90 p-5 border border-white/10">
                    <p id="event-card-label-tempat" class="text-xs uppercase tracking-[0.22em] text-kkr-light">Tempat</p>
                    <p id="event-card-place" class="mt-2 text-2xl font-semibold text-white">Memuat...</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </ScrollReveal>

    <!-- Pembicara (dinamis dari DB) -->
    <ScrollReveal>
      <section id="speakers" class="scroll-mt-20 mx-auto max-w-7xl px-6">
        <div class="text-center max-w-2xl mx-auto space-y-4 mb-12">
          <div class="flex items-center justify-center gap-3">
            <span class="inline-block w-8 h-px bg-kkr-red"></span>
            <span id="section-label-speakers" class="text-sm font-semibold uppercase tracking-[0.25em] text-white">Pembicara</span>
            <span class="inline-block w-8 h-px bg-kkr-red"></span>
          </div>
          <h2 id="section-heading-speakers" class="text-3xl sm:text-4xl font-semibold text-white">Bersama Pembicara Rohani</h2>
          <div class="w-12 h-0.5 bg-gradient-to-r from-kkr-red to-kkr-gold mx-auto rounded-full"></div>
        </div>

        <span id="section-label-story" class="hidden">Story Pembicara</span>

        <div id="speaker-grid" class="w-full max-w-5xl mx-auto">
          <div class="col-span-full text-center py-12 text-white/50" id="speaker-skeleton">
            <div class="inline-block w-8 h-8 border-2 border-kkr-maroon border-t-transparent rounded-full animate-spin"></div>
            <p class="mt-3 text-sm">Memuat pembicara...</p>
          </div>
        </div>
      </section>
    </ScrollReveal>

    <!-- Pelayan Altar -->
    <ScrollReveal>
      <section id="altar" class="scroll-mt-20 mx-auto max-w-7xl px-6">
        <div class="text-center max-w-2xl mx-auto space-y-4 mb-12">
          <div class="flex items-center justify-center gap-3">
            <span class="inline-block w-8 h-px bg-kkr-red"></span>
            <span id="section-label-altar" class="text-sm font-semibold uppercase tracking-[0.25em] text-white">Pelayan Altar</span>
            <span class="inline-block w-8 h-px bg-kkr-red"></span>
          </div>
          <h2 id="section-heading-altar" class="text-3xl sm:text-4xl font-semibold text-white">Pelayan Altar KKR RPPI</h2>
          <p id="section-desc-altar" class="section-text-muted max-w-xl mx-auto">Para pelayan altar yang melayani dalam kebangunan rohani</p>
          <div class="w-12 h-0.5 bg-gradient-to-r from-kkr-red to-kkr-gold mx-auto rounded-full"></div>
        </div>

        <div id="altar-grid" class="w-full">
          <div class="text-center py-12 text-white/50" id="altar-skeleton">
            <div class="inline-block w-8 h-8 border-2 border-kkr-maroon border-t-transparent rounded-full animate-spin"></div>
            <p class="mt-3 text-sm">Memuat pelayan altar...</p>
          </div>
        </div>
      </section>
    </ScrollReveal>

    <!-- Sponsor Section -->
    <ScrollReveal>
      <section id="sponsors" class="scroll-mt-20 mx-auto max-w-7xl px-6">
        <div class="text-center max-w-2xl mx-auto space-y-4 mb-12">
          <div class="flex items-center justify-center gap-3">
            <span class="inline-block w-8 h-px bg-kkr-red"></span>
            <span id="section-label-sponsors" class="text-sm font-semibold uppercase tracking-[0.25em] text-white">Sponsor & Mitra</span>
            <span class="inline-block w-8 h-px bg-kkr-red"></span>
          </div>
          <h2 id="section-heading-sponsors" class="text-3xl sm:text-4xl font-semibold text-white">Didukung oleh</h2>
          <p id="section-desc-sponsors" class="section-text-muted max-w-xl mx-auto">Para sponsor dan mitra yang mendukung terselenggaranya KKR RPPI 2026</p>
          <div class="w-12 h-0.5 bg-gradient-to-r from-kkr-red to-kkr-gold mx-auto rounded-full"></div>
        </div>

        <!-- Sponsor Marquee -->
        <div id="sponsor-grid" class="overflow-hidden" style="mask-image: linear-gradient(to right, transparent 0, black 40px, black calc(100% - 40px), transparent 100%);">
          <div class="text-center py-12 text-white/50" id="sponsor-skeleton">
            <div class="inline-block w-8 h-8 border-2 border-kkr-maroon border-t-transparent rounded-full animate-spin"></div>
            <p class="mt-3 text-sm">Memuat sponsor...</p>
          </div>
          <div class="sponsor-track flex gap-6 hidden" style="width: max-content;">
            <div class="flex gap-6 items-stretch" data-copy="1"></div>
            <div class="flex gap-6 items-stretch" data-copy="2" aria-hidden="true"></div>
          </div>
        </div>

        <div class="text-center mt-10">
          <a href="#contact" class="inline-flex items-center gap-2 rounded-full bg-kkr-red px-8 py-4 text-sm font-semibold text-white transition hover:bg-kkr-maroon">
            <span id="btn-sponsor-contact">Tertarik jadi Sponsor? Hubungi Kami</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </section>
    </ScrollReveal>

    <!-- Countdown -->
    <Countdown />

    <!-- Lokasi -->
    <ScrollReveal>
      <section id="location" class="scroll-mt-20 mx-auto max-w-7xl px-6">
        <div class="text-center max-w-2xl mx-auto space-y-4 mb-12">
          <div class="flex items-center justify-center gap-3">
            <span class="inline-block w-8 h-px bg-kkr-red"></span>
            <span id="section-label-location" class="text-sm font-semibold uppercase tracking-[0.25em] text-white">Lokasi & Waktu</span>
            <span class="inline-block w-8 h-px bg-kkr-red"></span>
          </div>
          <div class="w-12 h-0.5 bg-gradient-to-r from-kkr-red to-kkr-gold mx-auto rounded-full"></div>
        </div>

        <div class="grid gap-5 lg:grid-cols-2 items-stretch">
          <div class="rounded-2xl bg-kkr-dark/70 backdrop-blur-md p-4 sm:p-5 border border-white/10">
            <div class="flex items-center gap-2 mb-3">
              <span class="w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white shrink-0"><svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
              <span class="text-[10px] font-semibold uppercase tracking-[0.2em] text-white">Lokasi & Waktu</span>
            </div>
            <h2 id="loc-venue" class="text-lg sm:text-xl font-semibold text-white">Memuat...</h2>
            <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm">
              <div class="flex items-start gap-2">
                <span class="w-6 h-6 rounded-lg bg-white/10 flex items-center justify-center text-white shrink-0 mt-0.5"><svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span>
                <div>
                  <p id="loc-label-alamat" class="text-[10px] font-semibold uppercase tracking-wider text-white/60">Alamat</p>
                  <p id="loc-address" class="text-xs text-white/90">Memuat...</p>
                </div>
              </div>
              <div class="flex items-start gap-2">
                <span class="w-6 h-6 rounded-lg bg-white/10 flex items-center justify-center text-white shrink-0 mt-0.5"><svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span>
                <div>
                  <p id="loc-label-tanggal" class="text-[10px] font-semibold uppercase tracking-wider text-white/60">Tanggal</p>
                  <p id="loc-date" class="text-xs text-white/90">Memuat...</p>
                </div>
              </div>
              <div class="flex items-start gap-2">
                <span class="w-6 h-6 rounded-lg bg-white/10 flex items-center justify-center text-white shrink-0 mt-0.5"><svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
                <div>
                  <p id="loc-label-waktu" class="text-[10px] font-semibold uppercase tracking-wider text-white/60">Waktu</p>
                  <p id="loc-time" class="text-xs text-white/90">Memuat...</p>
                </div>
              </div>
              <div class="flex items-start gap-2">
                <span class="w-6 h-6 rounded-lg bg-white/10 flex items-center justify-center text-white shrink-0 mt-0.5"><svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M2 12h20"/></svg></span>
                <div>
                  <p id="loc-label-batas-daftar" class="text-[10px] font-semibold uppercase tracking-wider text-white/60">Batas Daftar</p>
                  <p id="reg-deadline" class="text-xs text-white/90">Memuat...</p>
                </div>
              </div>
            </div>
            <div class="mt-3 flex items-start gap-2 border-t border-white/10 pt-3">
              <span class="w-6 h-6 rounded-lg bg-white/10 flex items-center justify-center text-white shrink-0"><svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
              <div>
                <p id="loc-label-kontak" class="text-[10px] font-semibold uppercase tracking-wider text-white/60">Kontak</p>
                <p id="loc-phone" class="text-xs text-white/90">Memuat...</p>
                <a id="loc-wa" href="#" target="_blank" class="text-xs text-white/80 hover:text-white font-medium">Memuat...</a>
              </div>
            </div>
            <div class="mt-3">
              <a id="loc-maps-btn" href="#" target="_blank" class="inline-flex items-center gap-1.5 rounded-lg border border-white/20 bg-white/10 px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-white/20">
                <span id="loc-btn-maps-text">Buka di Google Maps</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </a>
            </div>
          </div>

          <div class="overflow-hidden rounded-2xl glass-card h-full min-h-[280px]">
            <div class="relative h-full w-full">
              <iframe id="loc-maps-iframe" class="absolute inset-0 h-full w-full" src="" loading="lazy" referrerpolicy="strict-origin-when-cross-origin" style="filter:grayscale(0.15) contrast(1.05)"></iframe>
              <div class="pointer-events-none absolute inset-0 rounded-2xl ring-1 ring-inset ring-black/5"></div>
            </div>
          </div>
        </div>
      </section>
    </ScrollReveal>

    <!-- CTA -->
    <ScrollReveal>
      <section id="contact" class="mx-auto max-w-7xl px-6">
        <div class="rounded-[2.5rem] bg-gradient-to-br from-kkr-dark via-kkr-purple to-kkr-maroon p-8 sm:p-14 text-white shadow-2xl shadow-kkr-dark/30 relative overflow-hidden">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(251,207,232,.08),_transparent_50%)]"></div>
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_right,_rgba(219,234,254,.05),_transparent_50%)]"></div>
          <div class="relative grid gap-8 lg:grid-cols-[1.3fr_0.9fr] lg:items-center">
            <div>
              <div class="flex items-center gap-3">
                <span class="inline-block w-8 h-px bg-kkr-red"></span>
                <span id="section-label-cta" class="text-sm font-semibold uppercase tracking-[0.3em] text-white/80">Siap Bergabung?</span>
              </div>
              <h2 id="cta-title" class="mt-4 text-3xl sm:text-4xl font-semibold">Daftar sekarang, dan ikuti KKR dalam kasih Kristus.</h2>
              <p id="cta-desc" class="mt-4 max-w-xl text-white/70 leading-relaxed">Isi formulir pendaftaran, pilih tiket, dan amankan tempatmu dalam KKR RPPI yang penuh sukacita dan berkat.</p>
            </div>
            <div class="space-y-4">
              <div class="rounded-xl border border-white/10 bg-white/5 p-5 backdrop-blur-sm">
                <p id="cta-contact-label" class="text-xs uppercase tracking-[0.2em] text-kkr-light font-semibold">Kontak</p>
                <p class="mt-2 text-lg font-semibold" id="cta-email">kkrrppi@gmail.com</p>
                <p class="text-white/70 text-sm" id="cta-phone">Memuat...</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </ScrollReveal>
  </div>

  <!-- Sponsor Detail Modal -->
  <div id="sponsor-modal" class="hidden fixed inset-0 z-[70] items-center justify-center bg-black/40 backdrop-blur-md p-4">
    <div class="relative w-full max-w-lg rounded-[2rem] glass-card animate-scale-in">
      <button id="sp-modal-close" class="absolute right-5 top-5 z-10 rounded-full bg-white/20 px-3 py-2 text-sm text-white/80 transition hover:bg-white/30">Tutup</button>
      <div class="p-8 text-center">
        <div class="relative inline-flex items-center justify-center mb-2">
          <div class="absolute inset-0 bg-gradient-to-br from-kkr-gold/30 to-kkr-light/30 rounded-full blur-xl"></div>
