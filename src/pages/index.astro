  <script>
    function escapeHtml(str) {
      if (!str) return "";
      return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }

    async function setEmbedMap(venue, mapsLink) {
      try {
        var params = "venue=" + encodeURIComponent(venue || "Lokasi Acara");
        if (mapsLink) params += "&mapsLink=" + encodeURIComponent(mapsLink);
        var res = await fetch("/api/geocode?" + params);
        var data = await res.json();
        return { url: data?.url || "" };
      } catch(e) {
        return { url: "" };
      }
    }

    function sanitizeUrl(url) {
      if (!url) return "";
      try {
        const parsed = new URL(url, window.location.origin);
        if (parsed.protocol !== "http:" && parsed.protocol !== "https:") return "";
        return parsed.href;
      } catch { return ""; }
    }

    function safe(id) { return document.getElementById(id); }

    async function loadSettings() {
      try {
        const s = await (window.__SETTINGS_CACHE || fetch("/api/settings").then(r => r.json()).then(d => d.settings || {}));
