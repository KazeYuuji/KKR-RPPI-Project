---
import PublicLayout from "../layouts/PublicLayout.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import Countdown from "../components/Countdown.astro";
import ChatBot from "../components/ChatBot.astro";

---

<PublicLayout title="KKR RPPI | Kebangunan Rohani dalam Yesus Kristus" description="KKR RPPI mempersatukan pelajar, alumni, dan masyarakat dalam kebangunan rohani Yesus Kristus.">
  <div class="space-y-16 sm:space-y-24 pb-24">
    <!-- Hero -->
    <section id="home" class="relative min-h-[90vh] flex items-center overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-kkr-dark/85 via-kkr-purple/40 to-kkr-maroon/20"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(243,159,90,0.18),transparent_25%),radial-gradient(circle_at_bottom_right,_rgba(232,188,185,0.16),transparent_22%)]"></div>
      <div class="absolute left-0 top-0 h-full w-full bg-[linear-gradient(180deg,rgba(29,26,57,0.18),rgba(255,255,255,0))]"></div>
      <div class="absolute top-20 left-10 w-64 h-64 rounded-full bg-kkr-gold/20 blur-3xl"></div>
      <div class="absolute bottom-24 right-10 w-80 h-80 rounded-full bg-kkr-red/20 blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 w-full">
        <div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
          <div class="space-y-8 text-white relative z-10 animate-fade-in">
            <p class="text-sm uppercase tracking-[0.3em] text-kkr-light">Ibadah Kebaktian Kebangunan Rohani</p>
            <h1 id="hero-heading" class="hero-text-shadow text-5xl sm:text-6xl md:text-7xl xl:text-[6rem] font-black leading-[0.9] tracking-[-0.04em]">
              <span id="hero-line1">TRUST</span><br />
              <span id="hero-line2">IN</span><br />
              <span id="hero-line3">GOD</span>
            </h1>
            <div class="max-w-xl space-y-4">
              <p class="hero-copy text-lg sm:text-xl leading-9 max-w-3xl">Percayalah kepada TUHAN dengan segenap hatimu dan janganlah bersandar kepada pengertianmu sendiri.</p>
              <p class="text-sm uppercase tracking-[0.24em] text-kkr-gold">Amsal 3:5</p>
            </div>
            <div class="flex flex-wrap gap-4">
              <a href="/registration" class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-kkr-maroon to-kkr-red px-7 py-4 text-sm font-semibold text-white shadow-xl shadow-kkr-maroon/30 transition hover:-translate-y-0.5 hover:shadow-2xl">
                Daftar Sekarang
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
              <a href="#about" class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-7 py-4 text-sm font-semibold text-white transition hover:bg-white/20 hover:text-white">
                Info Acara
              </a>
            </div>
          </div>

          <div class="relative z-10 animate-fade-in-up">
            <div class="rounded-[2.5rem] border border-white/20 bg-white/10 p-8 shadow-2xl shadow-black/25 backdrop-blur-xl">
              <div class="space-y-8">
                <div class="flex items-center justify-between gap-4">
                  <span class="inline-flex items-center gap-2 rounded-full bg-kkr-gold/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-kkr-gold">Terbuka untuk umum</span>
                  <div class="flex items-center gap-3">
                    <img src="/logo.png" alt="KKR RPPI" class="h-12 w-12 rounded-2xl border border-kkr-gold/40 bg-white/90 p-2 object-contain shadow-lg shadow-kkr-gold/20" />
                    <span class="text-sm font-semibold text-kkr-light/90">KKR RPPI</span>
                  </div>
                </div>
                <div class="space-y-3">
                  <p id="hero-day" class="text-xs uppercase tracking-[0.24em] text-kkr-light/70">Pada</p>
                  <h2 id="hero-date" class="text-4xl font-semibold text-white">Memuat...</h2>
                  <p id="hero-venue" class="text-sm text-kkr-light/70">Memuat...</p>
                </div>
                <div class="grid gap-4 sm:grid-cols-2">
                  <div class="rounded-[2rem] bg-kkr-dark/90 p-5 border border-white/10">
                    <p class="text-xs uppercase tracking-[0.22em] text-kkr-gold/90">Pukul</p>
                    <p id="hero-time" class="mt-2 text-2xl font-semibold text-white">Memuat...</p>
                  </div>
                  <div class="rounded-[2rem] bg-kkr-purple/90 p-5 border border-white/10">
                    <p class="text-xs uppercase tracking-[0.22em] text-kkr-light">Tempat</p>
                    <p id="hero-place" class="mt-2 text-2xl font-semibold text-white">Memuat...</p>
                  </div>
                </div>
              </div>
            </div>
            <div class="pointer-events-none absolute -right-16 top-10 h-40 w-40 rounded-full bg-kkr-gold/20 blur-3xl"></div>
            <div class="pointer-events-none absolute -left-12 bottom-10 h-48 w-48 rounded-full bg-kkr-red/15 blur-3xl"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Tentang Acara -->
    <ScrollReveal>
      <section id="about" class="scroll-mt-20 mx-auto max-w-7xl px-6">
        <div class="grid gap-10 lg:grid-cols-[1fr_0.8fr] items-start">
          <div class="glass-card space-y-6 rounded-[2.5rem] p-8 sm:p-10">
            <div class="flex items-center gap-3">
              <span class="inline-block w-8 h-px bg-kkr-red"></span>
              <span class="text-sm font-semibold uppercase tracking-[0.25em] text-kkr-red">Tentang Acara</span>
            </div>
            <h2 id="about-heading" class="text-3xl sm:text-4xl font-semibold text-kkr-dark leading-tight">KKR dengan Sukacita & Syukur</h2>
            <div class="space-y-6 max-w-prose">
              <p id="about-desc1" class="text-kkr-dark/90 leading-8">KKR RPPI 2025/2026 adalah kebaktian kebangunan rohani yang mempersatukan pelajar, alumni, dan masyarakat dari berbagai sekolah di Kediri. Sebuah momen untuk merenungkan kasih Tuhan dan mengalami pembaharuan iman.</p>
              <p id="about-desc2" class="text-kkr-dark/90 leading-8">Bersama pembicara tamu dari Surabaya, kita akan merenungkan makna kebangunan rohani yang sesungguhnya — bahwa pertobatan dan pembaharuan membawa kita lebih dekat kepada Tuhan, sesuai dengan firman dalam 2 Tawarikh 7:14.</p>
            </div>
            <blockquote id="about-blockquote" class="border-l-4 border-kkr-red pl-6 py-3 italic text-kkr-dark/80">
              "Jika umat-Ku yang disebut dengan nama-Ku merendahkan diri, berdoa dan mencari wajah-Ku, maka Aku akan mendengar dari sorga."
              <br/><span id="about-blockquote-ref" class="text-sm not-italic text-kkr-maroon/60 font-medium">— 2 Tawarikh 7:14</span>
            </blockquote>
          </div>

          <div class="space-y-4">
            <div class="rounded-2xl bg-gradient-to-br from-kkr-dark via-kkr-purple to-kkr-maroon p-6 sm:p-8 text-white shadow-2xl shadow-kkr-dark/20">
              <span class="text-3xl">🎶</span>
              <h3 id="about-card1-title" class="mt-4 text-xl font-semibold">Pujian & Penyembahan</h3>
              <p id="about-card1-desc" class="mt-2 text-sm text-white/70 leading-relaxed">Nikmati pujian dan penyembahan yang membawa hati kita lebih dekat kepada Tuhan, mengalami kebangunan rohani dalam Yesus Kristus.</p>
            </div>
            <div class="rounded-2xl glass-card p-6 sm:p-8 transition hover:shadow-xl hover:border-white/50">
              <span class="text-3xl">🤝</span>
              <h3 id="about-card2-title" class="mt-4 text-xl font-semibold text-kkr-dark">Persekutuan Lintas Sekolah</h3>
              <p id="about-card2-desc" class="mt-2 text-sm text-kkr-maroon leading-relaxed">Acara ini mempertemukan siswa-siswi dari berbagai sekolah di Kediri dan sekitarnya untuk membangun persaudaraan dan memperkuat ikatan iman dalam Tuhan Yesus.</p>
            </div>
          </div>
        </div>
      </section>
    </ScrollReveal>

    <!-- Pembicara (dinamis dari DB) -->
    <ScrollReveal>
      <section id="speakers" class="scroll-mt-20 mx-auto max-w-7xl px-6">
        <div class="text-center max-w-2xl mx-auto space-y-4 mb-12">
          <div class="flex items-center justify-center gap-3">
            <span class="inline-block w-8 h-px bg-kkr-red"></span>
            <span class="text-sm font-semibold uppercase tracking-[0.25em] text-kkr-red">Pembicara</span>
            <span class="inline-block w-8 h-px bg-kkr-red"></span>
          </div>
          <h2 class="text-3xl sm:text-4xl font-semibold text-white">Bersama Pembicara Rohani</h2>
          <div class="w-12 h-0.5 bg-gradient-to-r from-kkr-red to-kkr-gold mx-auto rounded-full"></div>
        </div>

        <div id="speaker-grid" class="w-full">
          <div class="col-span-full text-center py-12 text-kkr-maroon/60">
            <div class="inline-block w-8 h-8 border-2 border-kkr-maroon border-t-transparent rounded-full animate-spin"></div>
            <p class="mt-3 text-sm">Memuat pembicara...</p>
          </div>
        </div>
      </section>
    </ScrollReveal>

    <!-- Pelayan Altar -->
    <ScrollReveal>
      <section id="altar" class="scroll-mt-20 mx-auto max-w-7xl px-6">
        <div class="text-center max-w-2xl mx-auto space-y-4 mb-12">
          <div class="flex items-center justify-center gap-3">
            <span class="inline-block w-8 h-px bg-kkr-red"></span>
            <span class="text-sm font-semibold uppercase tracking-[0.25em] text-kkr-red">Pelayan Altar</span>
            <span class="inline-block w-8 h-px bg-kkr-red"></span>
          </div>
          <h2 class="text-3xl sm:text-4xl font-semibold text-white">Pelayan Altar KKR RPPI</h2>
          <p class="text-kkr-light/80">Para pelayan altar yang melayani dalam kebangunan rohani</p>
          <div class="w-12 h-0.5 bg-gradient-to-r from-kkr-red to-kkr-gold mx-auto rounded-full"></div>
        </div>

        <div id="altar-grid" class="w-full">
          <div class="text-center py-12 text-kkr-maroon/60">
            <div class="inline-block w-8 h-8 border-2 border-kkr-maroon border-t-transparent rounded-full animate-spin"></div>
            <p class="mt-3 text-sm">Memuat pelayan altar...</p>
          </div>
        </div>
      </section>
    </ScrollReveal>

    <!-- Sponsor Section -->
    <ScrollReveal>
      <section id="sponsors" class="scroll-mt-20 mx-auto max-w-7xl px-6">
        <div class="text-center max-w-2xl mx-auto space-y-4 mb-12">
          <div class="flex items-center justify-center gap-3">
            <span class="inline-block w-8 h-px bg-kkr-red"></span>
            <span class="text-sm font-semibold uppercase tracking-[0.25em] text-kkr-red">Sponsor & Mitra</span>
            <span class="inline-block w-8 h-px bg-kkr-red"></span>
          </div>
          <h2 class="text-3xl sm:text-4xl font-semibold text-white">Didukung oleh</h2>
          <p class="text-kkr-light/80">Para sponsor dan mitra yang mendukung terselenggaranya KKR RPPI 2026</p>
          <div class="w-12 h-0.5 bg-gradient-to-r from-kkr-red to-kkr-gold mx-auto rounded-full"></div>
        </div>

        <!-- Sponsor Marquee -->
        <div id="sponsor-grid" class="overflow-hidden" style="mask-image: linear-gradient(to right, transparent 0, black 40px, black calc(100% - 40px), transparent 100%);">
          <div class="sponsor-track flex gap-6" style="width: max-content; animation: scroll-left 30s linear infinite;">
            <div class="flex gap-6 items-stretch" data-copy="1"></div>
            <div class="flex gap-6 items-stretch" data-copy="2" aria-hidden="true"></div>
          </div>
        </div>

        <div class="text-center mt-10">
          <a href="#contact" class="inline-flex items-center gap-2 rounded-full bg-kkr-red px-8 py-4 text-sm font-semibold text-white transition hover:bg-kkr-maroon">
            Tertarik jadi Sponsor? Hubungi Kami
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </section>
    </ScrollReveal>

    <!-- Countdown -->
    <Countdown />

    <!-- Lokasi -->
    <ScrollReveal>
      <section id="location" class="scroll-mt-20 mx-auto max-w-7xl px-6">
        <div class="text-center max-w-2xl mx-auto space-y-4 mb-12">
          <div class="flex items-center justify-center gap-3">
            <span class="inline-block w-8 h-px bg-kkr-red"></span>
            <span class="text-sm font-semibold uppercase tracking-[0.25em] text-kkr-red">Lokasi & Waktu</span>
            <span class="inline-block w-8 h-px bg-kkr-red"></span>
          </div>
          <div class="w-12 h-0.5 bg-gradient-to-r from-kkr-red to-kkr-gold mx-auto rounded-full"></div>
        </div>

        <div class="grid gap-8 lg:grid-cols-[1fr_0.9fr] items-start">
          <div class="rounded-[2.5rem] glass-card p-6 sm:p-8">
            <div class="flex items-center gap-2 mb-4">
              <span class="text-2xl">📍</span>
              <span class="text-sm font-semibold uppercase tracking-[0.2em] text-kkr-red">Temui Kami di Sini</span>
            </div>
            <h2 id="loc-venue" class="text-2xl sm:text-3xl font-semibold text-kkr-dark">Memuat...</h2>
            <div class="mt-6 space-y-4 divide-y divide-kkr-light/30">
              <div class="flex items-start gap-4 pb-4">
                <span class="text-xl shrink-0 mt-0.5">🏫</span>
                <div>
                  <p class="font-medium text-kkr-dark">Alamat</p>
                  <p id="loc-address" class="text-sm text-kkr-maroon">Memuat...</p>
                </div>
              </div>
              <div class="flex items-start gap-4 py-4">
                <span class="text-xl shrink-0 mt-0.5">📅</span>
                <div>
                  <p class="font-medium text-kkr-dark">Tanggal</p>
                  <p id="loc-date" class="text-sm text-kkr-maroon">Memuat...</p>
                </div>
              </div>
              <div class="flex items-start gap-4 py-4">
                <span class="text-xl shrink-0 mt-0.5">⏰</span>
                <div>
                  <p class="font-medium text-kkr-dark">Waktu</p>
                  <p id="loc-time" class="text-sm text-kkr-maroon">Memuat...</p>
                </div>
              </div>
              <div class="flex items-start gap-4 py-4">
                <span class="text-xl shrink-0 mt-0.5">⏳</span>
                <div>
                  <p class="font-medium text-kkr-dark">Batas Pendaftaran</p>
                  <p id="reg-deadline" class="text-sm text-kkr-maroon">Memuat...</p>
                </div>
              </div>
              <div class="flex items-start gap-4 pt-4">
                <span class="text-xl shrink-0 mt-0.5">📞</span>
                <div>
                  <p class="font-medium text-kkr-dark">Kontak</p>
                  <p id="loc-phone" class="text-sm text-kkr-maroon">Memuat...</p>
                  <a id="loc-wa" href="#" target="_blank" class="text-sm text-kkr-red hover:text-kkr-red font-medium">Memuat...</a>
                </div>
              </div>
            </div>
            <div class="mt-6 flex flex-wrap gap-3">
              <a id="loc-maps-btn" href="#" target="_blank" class="inline-flex items-center gap-2 rounded-xl border border-kkr-light/80 px-5 py-3 text-sm font-semibold text-kkr-purple transition hover:bg-white hover:border-kkr-red">
                Buka di Google Maps
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </a>
              <a href="/registration" class="inline-flex items-center gap-2 rounded-xl bg-kkr-red px-5 py-3 text-sm font-semibold text-white transition hover:bg-kkr-maroon">Daftar Sekarang</a>
            </div>
          </div>

          <div class="overflow-hidden rounded-[2.5rem] glass-card h-[400px]">
            <iframe id="loc-maps-iframe" class="h-full w-full" src="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        </div>
      </section>
    </ScrollReveal>

    <!-- CTA -->
    <ScrollReveal>
      <section id="contact" class="mx-auto max-w-7xl px-6">
        <div class="rounded-[2.5rem] bg-gradient-to-br from-kkr-dark via-kkr-purple to-kkr-maroon p-8 sm:p-14 text-white shadow-2xl shadow-kkr-dark/30 relative overflow-hidden">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(251,207,232,.08),_transparent_50%)]"></div>
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_right,_rgba(219,234,254,.05),_transparent_50%)]"></div>
          <div class="relative grid gap-8 lg:grid-cols-[1.3fr_0.9fr] lg:items-center">
            <div>
              <div class="flex items-center gap-3">
                <span class="inline-block w-8 h-px bg-kkr-red"></span>
                <span class="text-sm font-semibold uppercase tracking-[0.3em] text-kkr-light">Siap Bergabung?</span>
              </div>
              <h2 id="cta-title" class="mt-4 text-3xl sm:text-4xl font-semibold">Daftar sekarang, dan ikuti KKR dalam kasih Kristus.</h2>
              <p id="cta-desc" class="mt-4 max-w-xl text-white/70 leading-relaxed">Isi formulir pendaftaran, pilih tiket, dan amankan tempatmu dalam KKR RPPI yang penuh sukacita dan berkat.</p>
            </div>
            <div class="space-y-4">
              <a href="/registration" class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-kkr-gold to-kkr-gold px-8 py-4 text-sm font-semibold text-kkr-dark shadow-lg shadow-kkr-gold/30 transition hover:shadow-xl hover:shadow-kkr-gold/40 hover:-translate-y-0.5">
                Daftar Sekarang
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
              <div class="rounded-xl border border-white/10 bg-white/5 p-5 backdrop-blur-sm">
                <p class="text-xs uppercase tracking-[0.2em] text-kkr-light font-semibold">Kontak</p>
                <p class="mt-2 text-lg font-semibold" id="cta-email">kkrrppi@gmail.com</p>
                <p class="text-white/70 text-sm" id="cta-phone">Memuat...</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </ScrollReveal>
  </div>

  <!-- Sponsor Detail Modal -->
  <div id="sponsor-modal" class="hidden fixed inset-0 z-[70] items-center justify-center bg-black/40 backdrop-blur-md p-4">
    <div class="relative w-full max-w-lg rounded-[2rem] glass-card animate-scale-in">
      <button id="sp-modal-close" class="absolute right-5 top-5 z-10 rounded-full bg-white/20 px-3 py-2 text-sm text-white/80 transition hover:bg-white/30">Tutup</button>
      <div class="p-8 text-center">
        <div class="relative inline-flex items-center justify-center mb-2">
          <div class="absolute inset-0 bg-gradient-to-br from-kkr-gold/30 to-kkr-light/30 rounded-full blur-xl"></div>
          <img id="sp-modal-logo" class="hidden w-32 h-32 rounded-full object-cover border-2 border-white/30 bg-white/30 shadow-lg" alt="" />
        </div>
        <h3 id="sp-modal-name" class="mt-4 text-2xl font-semibold text-kkr-dark"></h3>
      </div>
      <div id="sp-modal-desc-wrap" class="hidden px-8 pb-6 text-left">
        <p id="sp-modal-desc" class="text-kkr-dark/80 leading-7 text-sm break-words"></p>
      </div>
      <div id="sp-modal-web-wrap" class="hidden px-8 pb-8 pt-4 text-center border-t border-white/20">
        <a id="sp-modal-web" href="#" target="_blank" class="hidden inline-flex items-center gap-1.5 rounded-xl bg-kkr-red px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-kkr-maroon">Kunjungi Website <span>↗</span></a>
      </div>
    </div>
  </div>

  <!-- Floating Components -->
  <ChatBot />

  <script>
    function deriveEmbedUrl(link, venue) {
      if (!link) return `https://www.google.com/maps?q=${encodeURIComponent(venue || "Lokasi Acara")}&output=embed`;
      if (link.includes("output=embed")) return link;
      if (link.includes("google.com/maps")) {
        if (link.includes("?")) return link + "&output=embed";
        return `https://www.google.com/maps?q=${encodeURIComponent(venue || "Lokasi Acara")}&output=embed`;
      }
      return `https://www.google.com/maps?q=${encodeURIComponent(venue || "Lokasi Acara")}&output=embed`;
    }

    function safe(id) { return document.getElementById(id); }

    async function loadSettings() {
      try {
        const res = await fetch("/api/settings");
        const d = await res.json();
        const s = d.settings || {};
        const venue = s.locVenue || "SMK PGRI 1 Kediri";
        const date = s.locDate || "Sabtu, 10 Januari 2026";
        const time = s.locTime || "08:00 - 12:30 WIB";
        const regDeadline = s.regDeadline || "29 Desember 2025";
        const mapsLink = s.locMapsLink || "https://maps.app.goo.gl/RCzwb8tiKNdVwXA59";
        const mapsSrc = s.locMaps || deriveEmbedUrl(mapsLink, venue);
        const email = s.contactEmail || "kkrrppi@gmail.com";
        const phone = s.contactPhone || "(0354) 682433";
        const wa = s.contactWa || "6285800753804";
        if (s.heroTitle1 && safe("hero-title1")) safe("hero-title1").textContent = s.heroTitle1;
        if (s.heroTitle2 && safe("hero-title2")) safe("hero-title2").textContent = s.heroTitle2;
        if (s.heroHeading1 && safe("hero-line1")) safe("hero-line1").textContent = s.heroHeading1;
        if (s.heroHeading2 && safe("hero-line2")) safe("hero-line2").textContent = s.heroHeading2;
        if (s.heroHeading3 && safe("hero-line3")) safe("hero-line3").textContent = s.heroHeading3;
        if (safe("hero-verse")) {
          const vt = s.heroVerseText || "Percayalah kepada TUHAN dengan segenap hatimu dan janganlah bersandar kepada pengertianmu sendiri.";
          const ref = s.heroVerseRef || "Amsal 3:5";
          safe("hero-verse").textContent = vt;
          if (safe("hero-verse-ref")) safe("hero-verse-ref").textContent = "— " + ref;
        }
        if (s.heroSubtitle && safe("hero-subtitle")) {
          const parts = s.heroSubtitle.split("—");
          safe("hero-verse").textContent = parts[0].trim();
          if (parts[1] && safe("hero-verse-ref")) safe("hero-verse-ref").textContent = "— " + parts[1].trim();
        }
        if (s.locDate && safe("hero-date")) safe("hero-date").textContent = s.locDate;
        if (s.locTime && safe("hero-time")) safe("hero-time").textContent = s.locTime;
        if (safe("hero-venue")) safe("hero-venue").textContent = venue;
        if (safe("hero-place")) safe("hero-place").textContent = venue.split(",")[0] || venue;
        if (s.aboutTitle && safe("about-heading")) safe("about-heading").textContent = s.aboutTitle;
        if (s.aboutDesc1 && safe("about-desc1")) safe("about-desc1").textContent = s.aboutDesc1;
        if (s.aboutDesc2 && safe("about-desc2")) safe("about-desc2").textContent = s.aboutDesc2;
        if (s.ctaTitle && safe("cta-title")) safe("cta-title").textContent = s.ctaTitle;
        if (s.ctaDesc && safe("cta-desc")) safe("cta-desc").textContent = s.ctaDesc;
        if (s.aboutCard1Title && safe("about-card1-title")) safe("about-card1-title").textContent = s.aboutCard1Title;
        if (s.aboutCard1Desc && safe("about-card1-desc")) safe("about-card1-desc").textContent = s.aboutCard1Desc;
        if (s.aboutCard2Title && safe("about-card2-title")) safe("about-card2-title").textContent = s.aboutCard2Title;
        if (s.aboutCard2Desc && safe("about-card2-desc")) safe("about-card2-desc").textContent = s.aboutCard2Desc;
        if (s.aboutBlockquote && safe("about-blockquote")) {
          const bq = s.aboutBlockquote;
          const parts = bq.split("—");
          safe("about-blockquote").innerHTML = (parts[0] ? `"${parts[0].trim()}"` : "") + '<br/><span id="about-blockquote-ref" class="text-sm not-italic text-kkr-maroon/60 font-medium">— ' + (parts[1] ? parts[1].trim() : "") + "</span>";
        }
        if (safe("hero-location")) safe("hero-location").textContent = venue;
        if (safe("loc-venue")) safe("loc-venue").textContent = venue;
        if (safe("loc-address")) safe("loc-address").textContent = "Lihat peta di bawah";
        if (safe("loc-date")) safe("loc-date").textContent = date;
        if (safe("loc-time")) safe("loc-time").textContent = time;
        if (safe("reg-deadline")) safe("reg-deadline").textContent = regDeadline;
        if (safe("loc-phone")) safe("loc-phone").textContent = phone;
        if (safe("loc-wa")) { safe("loc-wa").href = "https://wa.me/" + wa; safe("loc-wa").textContent = "WhatsApp: +" + wa; }
        if (safe("loc-maps-btn")) safe("loc-maps-btn").href = mapsLink;
        if (safe("loc-maps-iframe")) safe("loc-maps-iframe").src = mapsSrc;
        if (safe("cta-email")) safe("cta-email").textContent = email;
        if (safe("cta-phone")) safe("cta-phone").textContent = phone;
      } catch {}
    }

    async function loadSpeakers() {
      try {
        const res = await fetch("/api/speakers");
        const d = await res.json();
        const container = document.getElementById("speaker-grid");
        const list = (d.speakers || []).filter(s => s.is_active);
        if (!list.length) {
          container.innerHTML = `<div class="text-center py-12 text-kkr-maroon/60"><p class="text-sm">Belum ada pembicara.</p></div>`;
          return;
        }
        const makeCard = (baseClass) => s => `
          <div class="${baseClass}">
            ${s.photo_url
              ? `<img src="${s.photo_url}" class="w-28 h-28 rounded-full object-cover mx-auto shadow-lg shadow-kkr-light/50 border-2 border-white" />`
              : `<div class="w-28 h-28 rounded-full bg-gradient-to-br from-kkr-light/80 to-white mx-auto flex items-center justify-center text-5xl shadow-lg shadow-kkr-light/50">✝️</div>`
            }
            <div class="mt-5 space-y-1">
              ${s.title ? `<span class="inline-block text-xs font-semibold uppercase tracking-wider text-kkr-red bg-kkr-light px-3 py-1 rounded-full">${s.title}</span>` : ""}
              <h3 class="text-2xl font-semibold text-kkr-dark mt-2">${s.name}</h3>
              ${s.organization ? `<p class="text-kkr-maroon/80 text-sm">${s.organization}</p>` : ""}
            </div>
            ${s.description ? `<div class="mt-4"><p class="text-sm text-kkr-maroon leading-relaxed text-center max-w-xs mx-auto break-words">${s.description}</p></div>` : '<div class="flex-1"></div>'}
            ${s.tags ? `<div class="flex flex-wrap justify-center gap-2 mt-5">${s.tags.split(",").map(t => `<span class="text-xs bg-kkr-light text-kkr-red px-3 py-1 rounded-full font-medium">${t.trim()}</span>`).join("")}</div>` : ""}
          </div>`;
        if (list.length > 3) {
          const base = "rounded-[2.5rem] glass-card p-5 sm:p-8 text-center hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 shrink-0 w-[280px] sm:w-[320px] flex flex-col";
          const html = list.map(makeCard(base)).join("");
          container.innerHTML = `
            <div class="overflow-hidden" style="mask-image: linear-gradient(to right, transparent 0, black 40px, black calc(100% - 40px), transparent 100%);">
              <div class="flex gap-4 sm:gap-6" style="width: max-content; animation: scroll-left 30s linear infinite;">
                <div class="flex gap-4 sm:gap-6">${html}</div>
                <div class="flex gap-4 sm:gap-6" aria-hidden="true">${html}</div>
              </div>
            </div>`;
        } else {
          const base = "rounded-[2.5rem] glass-card p-6 sm:p-8 text-center hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 w-full flex flex-col";
          const html = list.map(makeCard(base)).join("");
          if (list.length === 1) {
            container.innerHTML = `<div class="flex justify-center">${html}</div>`;
          } else {
            const gridCols = list.length === 2 ? "sm:grid-cols-2 max-w-2xl" : "sm:grid-cols-3 max-w-4xl";
            container.innerHTML = `<div class="grid gap-6 ${gridCols} mx-auto">${html}</div>`;
          }
        }
      } catch {
        document.getElementById("speaker-grid").innerHTML = `<div class="text-center py-12 text-red-500"><p>Gagal memuat pembicara.</p></div>`;
      }
    }

    async function loadAltarServers() {
      try {
        const res = await fetch("/api/altar-servers");
        const d = await res.json();
        const container = document.getElementById("altar-grid");
        const list = (d.altarServers || []).filter(s => s.is_active);
        if (!list.length) {
          container.innerHTML = `<div class="text-center py-12 text-kkr-maroon/60"><p class="text-sm">Belum ada pelayan altar.</p></div>`;
          return;
        }
        const makeCard = (baseClass) => s => `
          <div class="${baseClass}">
            ${s.photo_url
              ? `<img src="${s.photo_url}" class="w-20 h-20 rounded-full object-cover mx-auto shadow-md shadow-kkr-light/40 border-2 border-white" />`
              : `<div class="w-20 h-20 rounded-full bg-gradient-to-br from-kkr-light/80 to-white mx-auto flex items-center justify-center text-2xl shadow-md shadow-kkr-light/40">🕯️</div>`
            }
            <div class="mt-3 space-y-0.5">
              ${s.title ? `<span class="inline-block text-[10px] font-semibold uppercase tracking-wider text-kkr-red bg-kkr-light px-2 py-0.5 rounded-full">${s.title}</span>` : ""}
              <h3 class="text-base font-semibold text-kkr-dark mt-1">${s.name}</h3>
              ${s.organization ? `<p class="text-kkr-maroon/70 text-xs">${s.organization}</p>` : ""}
            </div>
            ${s.description ? `<div class="mt-2"><p class="text-xs text-kkr-maroon leading-relaxed text-center max-w-[200px] mx-auto break-words">${s.description}</p></div>` : '<div class="flex-1"></div>'}
            ${s.tags ? `<div class="flex flex-wrap justify-center gap-1.5 mt-3">${s.tags.split(",").map(t => `<span class="text-[10px] bg-kkr-light text-kkr-red px-2 py-0.5 rounded-full font-medium">${t.trim()}</span>`).join("")}</div>` : ""}
          </div>`;
        if (list.length > 3) {
          const base = "rounded-2xl glass-card p-4 sm:p-5 text-center hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 shrink-0 w-[200px] sm:w-[220px] flex flex-col";
          const html = list.map(makeCard(base)).join("");
          container.innerHTML = `
            <div class="overflow-hidden" style="mask-image: linear-gradient(to right, transparent 0, black 40px, black calc(100% - 40px), transparent 100%);">
              <div class="flex gap-3 sm:gap-4" style="width: max-content; animation: scroll-left 30s linear infinite;">
                <div class="flex gap-3 sm:gap-4">${html}</div>
                <div class="flex gap-3 sm:gap-4" aria-hidden="true">${html}</div>
              </div>
            </div>`;
        } else {
          const base = "rounded-2xl glass-card p-4 sm:p-5 text-center hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 w-full flex flex-col";
          const html = list.map(makeCard(base)).join("");
          if (list.length === 1) {
            container.innerHTML = `<div class="flex justify-center max-w-[260px] mx-auto">${html}</div>`;
          } else {
            const gridCols = list.length === 2 ? "sm:grid-cols-2 max-w-xl" : "sm:grid-cols-3 max-w-3xl";
            container.innerHTML = `<div class="grid gap-4 ${gridCols} mx-auto">${html}</div>`;
          }
        }
      } catch {
        document.getElementById("altar-grid").innerHTML = `<div class="text-center py-12 text-red-500"><p>Gagal memuat pelayan altar.</p></div>`;
      }
    }

    let allSponsors = [];

    async function loadSponsors() {
      try {
        const res = await fetch("/api/sponsors");
        const data = await res.json();
        allSponsors = data.sponsors || [];
        const list = allSponsors;
        if (!list.length) {
          document.getElementById("sponsor-grid").innerHTML = `<div class="text-center py-12 text-kkr-maroon/60"><p class="text-sm">Belum ada sponsor. Jadilah yang pertama!</p></div>`;
          return;
        }
        const card = (s) =>
          `<div class="sponsor-card flex items-center gap-4 rounded-2xl glass-card px-6 py-5 shrink-0 min-w-[260px] cursor-pointer transition-all duration-300 hover:shadow-2xl hover:-translate-y-1" data-id="${s.id}">
            ${s.logo_url ? `<img src="${s.logo_url}" class="w-12 h-12 rounded-xl object-cover shrink-0" />` : `<div class="w-12 h-12 rounded-xl bg-gradient-to-br from-kkr-light to-white border border-kkr-light/50 flex items-center justify-center text-xl shrink-0">🏢</div>`}
            <div class="min-w-0">
              <p class="font-semibold text-kkr-dark truncate">${s.name}</p>
            </div>
          </div>`;
        const html = list.map(card).join("");
        if (list.length <= 3) {
          const container = document.getElementById("sponsor-grid");
          container.innerHTML = '';
          container.style.maskImage = 'none';
          const gridCols = list.length === 1 ? "flex justify-center" : (list.length === 2 ? "grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-xl mx-auto" : "grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl mx-auto");
          container.innerHTML = `<div class="${gridCols}">${html}</div>`;
        } else {
          document.querySelector('[data-copy="1"]').innerHTML = html;
          document.querySelector('[data-copy="2"]').innerHTML = html;
        }
      } catch {
        document.getElementById("sponsor-grid").innerHTML = `<div class="text-center py-12 text-red-500"><p>Gagal memuat data sponsor.</p></div>`;
      }
    }

    document.addEventListener("click", (e) => {
      const card = e.target.closest(".sponsor-card");
      if (!card) return;
      const id = card.dataset.id;
      const sponsor = allSponsors.find(s => s.id == id);
      if (!sponsor) return;
      const modal = document.getElementById("sponsor-modal");
      const logoEl = document.getElementById("sp-modal-logo");
      if (sponsor.logo_url) {
        logoEl.src = sponsor.logo_url;
        logoEl.alt = sponsor.name + " logo";
        logoEl.classList.remove("hidden");
      } else {
        logoEl.classList.add("hidden");
      }
      document.getElementById("sp-modal-name").textContent = sponsor.name;
      const descEl = document.getElementById("sp-modal-desc");
      const descWrap = document.getElementById("sp-modal-desc-wrap");
      if (sponsor.description) {
        descEl.textContent = sponsor.description;
        descWrap.classList.remove("hidden");
      } else {
        descWrap.classList.add("hidden");
      }
      const webWrap = document.getElementById("sp-modal-web-wrap");
      const webLink = document.getElementById("sp-modal-web");
      if (sponsor.website) {
        webLink.href = sponsor.website;
        webWrap.classList.remove("hidden");
      } else {
        webWrap.classList.add("hidden");
      }
      modal.classList.remove("hidden");
      modal.classList.add("flex");
    });

    document.getElementById("sp-modal-close")?.addEventListener("click", () => {
      const modal = document.getElementById("sponsor-modal");
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    });

    document.getElementById("sponsor-modal")?.addEventListener("click", (e) => {
      if (e.target === e.currentTarget) {
        const modal = document.getElementById("sponsor-modal");
        modal.classList.add("hidden");
        modal.classList.remove("flex");
      }
    });

    document.addEventListener("DOMContentLoaded", () => { loadSettings(); loadSpeakers(); loadAltarServers(); loadSponsors(); });
  </script>
</PublicLayout>
