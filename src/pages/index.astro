      } catch {
        document.getElementById("altar-grid").innerHTML = `<div class="text-center py-12 text-red-500"><p>Gagal memuat pelayan altar.</p></div>`;
      }
    }

    let allSponsors = [];

    async function loadSponsors() {
      try {
        const res = await fetch("/api/sponsors");
        const data = await res.json();
        allSponsors = data.sponsors || [];
        const list = allSponsors;
        if (!list.length) {
          document.getElementById("sponsor-grid").innerHTML = `<div class="text-center py-12 text-white/50"><p class="text-sm">Belum ada sponsor. Jadilah yang pertama!</p></div>`;
          return;
        }
        document.getElementById("sponsor-skeleton")?.classList.add("hidden");
        const card = (s) =>
          `<div class="sponsor-card flex items-center gap-4 rounded-2xl glass-card px-6 py-5 shrink-0 min-w-[260px] cursor-pointer transition-all duration-300 hover:shadow-2xl hover:-translate-y-1" data-id="${s.id}">
            ${s.logo_url ? `<img src="${escapeHtml(sanitizeUrl(s.logo_url))}" loading="lazy" decoding="async" class="w-12 h-12 rounded-xl object-cover shrink-0" alt="${escapeHtml(s.name)}" />` : `<div class="w-12 h-12 rounded-xl bg-gradient-to-br from-kkr-light to-white border border-kkr-light/50 flex items-center justify-center shrink-0"><svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-kkr-red/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></div>`}
            <div class="min-w-0">
              <p class="font-semibold text-kkr-dark truncate">${escapeHtml(s.name)}</p>
            </div>
          </div>`;
        const html = list.map(card).join("");
        if (list.length <= 3) {
          const container = document.getElementById("sponsor-grid");
          container.innerHTML = '';
          container.style.maskImage = 'none';
          const gridCols = list.length === 1 ? "flex justify-center" : (list.length === 2 ? "grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-xl mx-auto" : "grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl mx-auto");
          container.innerHTML = `<div class="${gridCols}">${html}</div>`;
        } else {
          document.querySelector('[data-copy="1"]').innerHTML = html;
          document.querySelector('[data-copy="2"]').innerHTML = html;
          const track = document.querySelector(".sponsor-track");
          track?.classList.remove("hidden");
          if (track) setTimeout(function() { marquee(track); }, 50);
        }
      } catch {
        document.getElementById("sponsor-grid").innerHTML = `<div class="text-center py-12 text-red-500"><p>Gagal memuat data sponsor.</p></div>`;
      }
    }

    document.addEventListener("click", (e) => {
      const card = e.target.closest(".sponsor-card");
      if (!card) return;
      const id = card.dataset.id;
      const sponsor = allSponsors.find(s => s.id == id);
      if (!sponsor) return;
      const modal = document.getElementById("sponsor-modal");
      const logoEl = document.getElementById("sp-modal-logo");
      if (sponsor.logo_url) {
        logoEl.src = sanitizeUrl(sponsor.logo_url);
        logoEl.alt = escapeHtml(sponsor.name) + " logo";
        logoEl.classList.remove("hidden");
      } else {
        logoEl.classList.add("hidden");
      }
      document.getElementById("sp-modal-name").textContent = sponsor.name;
      const descEl = document.getElementById("sp-modal-desc");
      const descWrap = document.getElementById("sp-modal-desc-wrap");
      if (sponsor.description) {
        descEl.textContent = sponsor.description;
        descWrap.classList.remove("hidden");
      } else {
        descWrap.classList.add("hidden");
      }
      const webWrap = document.getElementById("sp-modal-web-wrap");
      const webLink = document.getElementById("sp-modal-web");
      if (sponsor.website) {
        try { webLink.href = sanitizeUrl(new URL(sponsor.website).href); } catch { webLink.href = "#"; }
        webWrap.classList.remove("hidden");
      } else {
        webWrap.classList.add("hidden");
      }
      modal.classList.remove("hidden");
      modal.classList.add("flex");
    });

    document.getElementById("sp-modal-close")?.addEventListener("click", () => {
      const modal = document.getElementById("sponsor-modal");
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    });

    document.getElementById("sponsor-modal")?.addEventListener("click", (e) => {
      if (e.target === e.currentTarget) {
        const modal = document.getElementById("sponsor-modal");
        modal.classList.add("hidden");
        modal.classList.remove("flex");
      }
    });

    document.addEventListener("DOMContentLoaded", () => {
      loadSettings();
      loadSpeakers();
      loadAltarServers();
      loadSponsors();
    });
  </script>
</PublicLayout>
