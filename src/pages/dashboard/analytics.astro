---
import AdminLayout from "../../layouts/AdminLayout.astro";
import StatCard from "../../components/dashboard/StatCard.astro";

const usersIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`;
const trendIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`;
const ticketIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`;
const clockIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`;
---

<AdminLayout title="Analytics">
  <div class="space-y-8 animate-fade-in">
    <!-- Header -->
    <div class="rounded-2xl border border-kkr-light/50 bg-white p-6 sm:p-8 shadow-sm">
      <div class="flex items-center gap-2 mb-1">
        <span class="w-1.5 h-1.5 rounded-full bg-kkr-red"></span>
        <span class="text-xs font-semibold uppercase tracking-wider text-kkr-maroon/60">Analytics</span>
      </div>
      <h2 class="text-2xl sm:text-3xl font-semibold text-kkr-dark">Ringkasan Data</h2>
      <p class="mt-1 text-sm text-kkr-maroon/80">Pemantauan data pendaftaran dan partisipasi acara.</p>
    </div>

    <!-- Stat Cards -->
    <div id="stats-grid" class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5">
      <StatCard label="Total Pendaftar" value="—" icon={usersIcon} colorIndex={0} />
      <StatCard label="Sudah Check-in" value="—" icon={trendIcon} colorIndex={1} />
      <StatCard label="Total Sponsor" value="—" icon={ticketIcon} colorIndex={2} />
      <StatCard label="Check-in Rate" value="—" icon={clockIcon} colorIndex={3} />
    </div>

    <!-- Charts Row -->
    <div class="grid gap-6 lg:grid-cols-2">
      <!-- Bar Chart (ticket distribution) -->
      <div class="rounded-2xl border border-kkr-light/50 bg-white p-6 shadow-sm">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h3 class="text-base font-semibold text-kkr-dark">Pendaftaran per Tiket</h3>
            <p class="text-xs text-kkr-maroon/80 mt-0.5">Distribusi pemilihan tiket</p>
          </div>
          <span class="text-[10px] font-semibold uppercase tracking-wider text-kkr-maroon/60 bg-white px-2.5 py-1 rounded-full">Live</span>
        </div>
        <div id="ticket-chart" class="flex items-end justify-around gap-3 h-52 pt-2">
          <div class="flex-1 flex flex-col items-center gap-2 h-full justify-end">
            <span id="chart-ticket-0-val" class="text-xs font-bold text-kkr-maroon">0</span>
            <div id="chart-ticket-0-bar" class="w-full bg-gradient-to-t from-kkr-red to-kkr-maroon rounded-lg transition-all duration-700 ease-out min-h-[4px] max-h-[200px]" style="height: 4px"></div>
            <span id="chart-ticket-0-label" class="text-xs text-kkr-maroon/80 text-center leading-tight font-medium">Memuat...</span>
          </div>
          <div class="flex-1 flex flex-col items-center gap-2 h-full justify-end">
            <span id="chart-ticket-1-val" class="text-xs font-bold text-kkr-maroon">0</span>
            <div id="chart-ticket-1-bar" class="w-full bg-gradient-to-t from-blue-500 to-blue-300 rounded-lg transition-all duration-700 ease-out min-h-[4px] max-h-[200px]" style="height: 4px"></div>
            <span id="chart-ticket-1-label" class="text-xs text-kkr-maroon/80 text-center leading-tight font-medium">Memuat...</span>
          </div>
          <div class="flex-1 flex flex-col items-center gap-2 h-full justify-end">
            <span id="chart-ticket-2-val" class="text-xs font-bold text-kkr-maroon">0</span>
            <div id="chart-ticket-2-bar" class="w-full bg-gradient-to-t from-kkr-gold to-kkr-gold rounded-lg transition-all duration-700 ease-out min-h-[4px] max-h-[200px]" style="height: 4px"></div>
            <span id="chart-ticket-2-label" class="text-xs text-kkr-maroon/80 text-center leading-tight font-medium">Memuat...</span>
          </div>
        </div>
      </div>

      <!-- Donut-style status distribution -->
      <div class="rounded-2xl border border-kkr-light/50 bg-white p-6 shadow-sm">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h3 class="text-base font-semibold text-kkr-dark">Distribusi Status</h3>
            <p class="text-xs text-kkr-maroon/80 mt-0.5">Status pendaftaran peserta</p>
          </div>
        </div>
        <div class="space-y-5" id="status-distribution">
          <div class="flex items-center gap-4 text-sm">
            <span class="w-3 h-3 rounded-full bg-kkr-red shrink-0"></span>
            <span class="text-kkr-maroon flex-1">Sudah Check-in</span>
            <span class="font-semibold text-kkr-dark">
              <span id="stat-checkin-pct">0</span>%
              <span class="font-normal text-kkr-maroon/60">(<span id="stat-checkin">0</span>)</span>
            </span>
          </div>
          <div class="flex items-center gap-4 text-sm">
            <span class="w-3 h-3 rounded-full bg-kkr-gold shrink-0"></span>
            <span class="text-kkr-maroon flex-1">Belum Check-in</span>
            <span class="font-semibold text-kkr-dark">
              <span id="stat-unchecked-pct">0</span>%
              <span class="font-normal text-kkr-maroon/60">(<span id="stat-unchecked">0</span>)</span>
            </span>
          </div>
        </div>
        <div class="mt-6 w-full h-3 bg-kkr-light/40 rounded-full overflow-hidden flex">
          <div id="bar-checkin" class="h-full bg-kkr-red transition-all duration-700" style="width: 0%"></div>
          <div id="bar-unchecked" class="h-full bg-kkr-gold transition-all duration-700" style="width: 0%"></div>
        </div>
      </div>
    </div>

    <!-- Summary Table -->
    <div class="rounded-2xl border border-kkr-light/50 bg-white shadow-sm overflow-hidden">
      <div class="p-5 sm:p-6 border-b border-kkr-light/30">
        <h3 class="text-base font-semibold text-kkr-dark">Ringkasan Event</h3>
        <p class="text-xs text-kkr-maroon/80 mt-0.5">Data keseluruhan acara KKR RPPI</p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead>
            <tr class="bg-white text-kkr-maroon/80 text-xs uppercase tracking-wider">
              <th class="py-3.5 px-6 font-semibold text-left">Metrik</th>
              <th class="py-3.5 px-6 font-semibold text-left">Nilai</th>
              <th class="py-3.5 px-6 font-semibold text-left">Deskripsi</th>
            </tr>
          </thead>
          <tbody>
            {[
              { metric: "Total Pendaftar", desc: "Semua peserta yang mendaftar" },
              { metric: "Belum Check-in", desc: "Peserta yang belum check-in" },
              { metric: "Sudah Check-in", desc: "Peserta yang sudah check-in" },
              { metric: "Sponsor Aktif", desc: "Sponsor yang terdaftar dan aktif" },
              { metric: "Pembicara", desc: "Pembicara yang terdaftar dan aktif" },
            ].map((row) => (
              <tr class="border-b border-slate-50 hover:bg-white/30 transition-colors">
                <td class="py-3.5 px-6 font-medium text-kkr-dark">{row.metric}</td>
                <td class="py-3.5 px-6 font-semibold text-kkr-dark text-lg tabular-nums" data-stat>—</td>
                <td class="py-3.5 px-6 text-kkr-maroon/80">{row.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    async function loadAnalyticsStats() {
      try {
        const res = await fetch("/api/stats");
        const d = await res.json();
        const total = d.totalRegistrants || 0;
        const checkedIn = d.checkedIn || 0;
        const unchecked = total - checkedIn;

        // Stat cards
        const cards = document.querySelectorAll("#stats-grid > div");
        if (cards.length >= 4) {
          const vals = [total, checkedIn, d.sponsorCount || 0, total > 0 ? Math.round((checkedIn / total) * 100) + "%" : "0%"];
          cards.forEach((card, i) => { const el = card.querySelector(".text-2xl"); if (el) el.textContent = vals[i] ?? "—"; });
        }

        // Table stats
        const cells = document.querySelectorAll("[data-stat]");
        if (cells.length >= 5) {
          cells[0].textContent = total;
          cells[1].textContent = unchecked;
          cells[2].textContent = checkedIn;
        }

        // Load sponsor & speaker counts for table
        try {
          const spRes = await fetch("/api/sponsors");
          const spData = await spRes.json();
          cells[3].textContent = (spData.sponsors || []).filter(s => s.is_active).length;
        } catch {}
        try {
          const spkRes = await fetch("/api/speakers");
          const spkData = await spkRes.json();
          cells[4].textContent = (spkData.speakers || []).filter(s => s.is_active).length;
        } catch {}

        // Status distribution
        const cPct = total > 0 ? Math.round((checkedIn / total) * 100) : 0;
        const uPct = total > 0 ? Math.round((unchecked / total) * 100) : 0;
        document.getElementById("stat-checkin-pct").textContent = cPct;
        document.getElementById("stat-unchecked-pct").textContent = uPct;
        document.getElementById("stat-checkin").textContent = checkedIn;
        document.getElementById("stat-unchecked").textContent = unchecked;
        document.getElementById("bar-checkin").style.width = cPct + "%";
        document.getElementById("bar-unchecked").style.width = uPct + "%";
      } catch {}
    }

    async function loadTicketChart() {
      try {
        const res = await fetch("/api/registrants");
        const d = await res.json();
        const list = d.registrants || [];
        const countMap = {};
        list.forEach(r => { const t = r.ticket || "unknown"; countMap[t] = (countMap[t] || 0) + 1; });
        const entries = Object.entries(countMap).sort((a, b) => b[1] - a[1]).slice(0, 3);
        const maxVal = Math.max(...entries.map(([, c]) => c), 1);
        const colors = ["from-kkr-red to-kkr-maroon", "from-blue-500 to-blue-300", "from-kkr-gold to-kkr-gold"];
        for (let i = 0; i < 3; i++) {
          const valEl = document.getElementById(`chart-ticket-${i}-val`);
          const barEl = document.getElementById(`chart-ticket-${i}-bar`);
          const labelEl = document.getElementById(`chart-ticket-${i}-label`);
          if (entries[i]) {
            const [name, count] = entries[i];
            labelEl.textContent = name;
            valEl.textContent = count;
            barEl.style.height = Math.max(4, (count / maxVal) * 180) + "px";
            barEl.className = `w-full bg-gradient-to-t ${colors[i] || colors[2]} rounded-lg transition-all duration-700 ease-out`;
          } else {
            labelEl.textContent = "—";
            valEl.textContent = "0";
            barEl.style.height = "4px";
          }
        }
      } catch {}
    }

    document.addEventListener("DOMContentLoaded", () => { loadAnalyticsStats(); loadTicketChart(); });
  </script>
</AdminLayout>
