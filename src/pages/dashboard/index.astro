---
import AdminLayout from "../../layouts/AdminLayout.astro";
import StatCard from "../../components/dashboard/StatCard.astro";

const userIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`;
const checkIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>`;
const clockIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`;
const pinIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`;
const ticketIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`;
---

<AdminLayout title="Dashboard">
  <div class="space-y-8 animate-fade-in">
    <!-- Welcome -->
    <div class="rounded-2xl glass-card p-6 sm:p-8">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            <span class="text-xs font-semibold uppercase tracking-wider text-kkr-maroon/60">Admin Panel</span>
          </div>
          <h2 class="mt-2 text-2xl sm:text-3xl font-semibold text-kkr-dark">Selamat datang, Admin</h2>
          <p class="mt-1 text-sm text-kkr-maroon/80">Kelola pendaftaran, sponsor, dan pengaturan acara KKR RPPI 2026.</p>
        </div>
        <div class="flex gap-3">
          <a href="/#sponsors" target="_blank" class="inline-flex items-center gap-1.5 rounded-xl border border-kkr-light/50 bg-white px-4 py-2.5 text-sm font-semibold text-kkr-maroon shadow-sm transition hover:bg-white hover:border-kkr-light/80">Lihat Sponsor</a>
          <a href="/" target="_blank" class="inline-flex items-center gap-1.5 rounded-xl bg-gradient-to-r from-kkr-maroon to-kkr-red px-4 py-2.5 text-sm font-semibold text-white shadow-sm shadow-kkr-light/50 transition hover:shadow-md hover:shadow-kkr-light/50">Lihat Website</a>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div id="stats-grid" class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5">
      <StatCard label="Total Pendaftar" value="—" icon={userIcon} colorIndex={0} />
      <StatCard label="Sudah Check-in" value="—" icon={checkIcon} colorIndex={1} />
      <StatCard label="Belum Check-in" value="—" icon={clockIcon} colorIndex={2} />
      <StatCard label="Sponsor" value="—" icon={pinIcon} colorIndex={3} />
    </div>

    <!-- Analytics Ringkasan -->
    <div class="grid gap-6 lg:grid-cols-[1fr_1.5fr]">
      <div class="rounded-2xl glass-card p-5 sm:p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-semibold text-kkr-dark">Distribusi Status</h3>
          <span id="checkin-rate" class="text-xs font-semibold text-kkr-maroon/60">—</span>
        </div>
        <div class="flex items-center gap-4 text-sm mb-3">
          <div class="flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-kkr-red shrink-0"></span>
            <span class="text-kkr-maroon">Check-in</span>
            <span class="font-semibold text-kkr-dark" id="summary-checked">0</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-kkr-gold shrink-0"></span>
            <span class="text-kkr-maroon">Belum</span>
            <span class="font-semibold text-kkr-dark" id="summary-unchecked">0</span>
          </div>
        </div>
        <div class="w-full h-2.5 bg-kkr-light/40 rounded-full overflow-hidden flex">
          <div id="summary-bar-checkin" class="h-full bg-kkr-red transition-all duration-700 rounded-l-full" style="width:0%"></div>
          <div id="summary-bar-unchecked" class="h-full bg-kkr-gold transition-all duration-700 rounded-r-full" style="width:0%"></div>
        </div>
      </div>
      <div class="rounded-2xl glass-card p-5 sm:p-6">
        <h3 class="text-sm font-semibold text-kkr-dark mb-4">Ringkasan Data</h3>
        <div class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm" id="summary-metrics">
          <div class="flex justify-between">
            <span class="text-kkr-maroon">Total Pendaftar</span>
            <span class="font-semibold text-kkr-dark tabular-nums" id="metric-total">—</span>
          </div>
          <div class="flex justify-between">
            <span class="text-kkr-maroon">Check-in Rate</span>
            <span class="font-semibold text-kkr-dark tabular-nums" id="metric-rate">—</span>
          </div>
          <div class="flex justify-between">
            <span class="text-kkr-maroon">Sponsor Aktif</span>
            <span class="font-semibold text-kkr-dark tabular-nums" id="metric-sponsors">—</span>
          </div>
          <div class="flex justify-between">
            <span class="text-kkr-maroon">Pembicara Aktif</span>
            <span class="font-semibold text-kkr-dark tabular-nums" id="metric-speakers">—</span>
          </div>
          <div class="flex justify-between">
            <span class="text-kkr-maroon">Pelayan Altar</span>
            <span class="font-semibold text-kkr-dark tabular-nums" id="metric-altar">—</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Grid -->
    <div class="grid gap-6 xl:grid-cols-[1.5fr_1fr]">
      <!-- Registrants Table -->
      <div class="rounded-2xl glass-card overflow-hidden">
        <div class="p-5 sm:p-6 border-b border-white/20">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <h3 class="text-lg font-semibold text-kkr-dark">Daftar Peserta</h3>
              <p class="text-sm text-kkr-maroon/80 mt-0.5">Data peserta yang telah mendaftar</p>
            </div>
            <span class="inline-flex items-center gap-1.5 text-xs text-emerald-600 bg-emerald-50 px-3 py-1.5 rounded-full font-medium">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
              Live dari database
            </span>
          </div>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead>
              <tr class="text-kkr-dark/80 text-xs uppercase tracking-wider">
                <th class="py-3.5 px-5 font-semibold text-left">Nama</th>
                <th class="py-3.5 px-5 font-semibold text-left hidden sm:table-cell">Sekolah</th>
                <th class="py-3.5 px-5 font-semibold text-left">Tiket</th>
                <th class="py-3.5 px-5 font-semibold text-left hidden md:table-cell">Check-in</th>
                <th class="py-3.5 px-5 font-semibold text-right">Aksi</th>
              </tr>
            </thead>
            <tbody id="registrant-rows" class="divide-y divide-kkr-light/30">
              <tr><td colspan="6" class="py-12 text-center text-kkr-maroon/60 text-sm">Memuat data...</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Sidebar Widgets -->
      <div class="space-y-5">
        <!-- Tickets -->
        <div class="rounded-2xl glass-card p-5 sm:p-6">
          <div class="flex items-center gap-2.5 mb-1">
            <span class="w-8 h-8 rounded-xl bg-kkr-light flex items-center justify-center text-kkr-red" set:html={ticketIcon} />
            <h3 class="text-base font-semibold text-kkr-dark">Stok Tiket</h3>
          </div>
          <p class="text-sm text-kkr-maroon/80 mt-0.5">Event gratis — semua tiket tanpa biaya.</p>
          <div id="ticket-mini-list" class="mt-4 space-y-2.5"></div>
          <a href="/dashboard/tickets" class="mt-3 inline-flex items-center gap-1.5 text-sm font-medium text-kkr-red hover:text-kkr-red transition-colors">
            Kelola Tiket
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>

        <!-- Check-in -->
        <div class="rounded-2xl glass-card p-5 sm:p-6">
          <div class="flex items-center gap-2.5 mb-1">
            <span class="w-8 h-8 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <h3 class="text-base font-semibold text-kkr-dark">Check-in Cepat</h3>
          </div>
          <p class="text-sm text-kkr-maroon/80 mt-0.5">Scan QR tiket atau masukkan ID manual.</p>
          <form id="checkin-form" class="mt-4 space-y-3">
            <div class="relative">
              <input id="checkin-id" type="text" placeholder="Masukkan ID tiket..." class="w-full rounded-xl border border-kkr-light/50 bg-white pl-4 pr-10 py-3 text-sm text-kkr-dark outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" />
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 absolute right-3.5 top-1/2 -translate-y-1/2 text-kkr-maroon/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </div>
            <div class="flex gap-2">
              <button class="flex-1 rounded-xl bg-kkr-dark px-4 py-3 text-sm font-semibold text-white transition hover:bg-kkr-purple active:scale-[0.98]">Cari & Check-in</button>
              <button type="button" id="scan-qr-btn" class="rounded-xl bg-emerald-100 px-4 py-3 text-sm font-semibold text-emerald-700 transition hover:bg-emerald-200 active:scale-[0.98] shrink-0 flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><rect x="7" y="7" width="10" height="10" rx="2"/></svg>
                Scan
              </button>
            </div>
            <div id="qr-reader" class="hidden rounded-xl overflow-hidden border border-kkr-light/50 relative bg-black">
              <video id="qr-video" class="w-full h-full object-cover" playsinline autoplay muted></video>
              <canvas id="qr-canvas" class="hidden"></canvas>
              <div id="qr-overlay" class="absolute inset-0 flex items-center justify-center pointer-events-none">
                <div class="w-48 h-48 border-2 border-white/60 rounded-xl"></div>
              </div>
            </div>
            <div id="checkin-result" class="rounded-xl p-3 text-sm hidden"></div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Camera Permission Modal -->
  <div id="camera-modal" class="fixed inset-0 z-[200] flex items-center justify-center bg-black/50 backdrop-blur-sm hidden p-4">
    <div class="w-full max-w-sm rounded-2xl bg-white p-6 shadow-2xl text-center space-y-5">
      <div class="mx-auto w-16 h-16 rounded-2xl bg-emerald-50 flex items-center justify-center">
        <svg class="w-8 h-8 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
          <circle cx="12" cy="13" r="4"/>
        </svg>
      </div>
      <div>
        <h3 class="text-lg font-semibold text-kkr-dark" id="camera-modal-title">Akses Kamera</h3>
        <p class="mt-1.5 text-sm text-kkr-maroon/80" id="camera-modal-desc">Izinkan akses kamera untuk memindai QR code tiket.</p>
      </div>
      <div id="camera-modal-detail" class="hidden text-xs text-kkr-maroon/50 bg-kkr-light/20 rounded-lg p-2 break-words"></div>
      <div id="camera-modal-steps" class="hidden text-left rounded-xl bg-amber-50 border border-amber-200 p-3.5 text-sm text-kkr-maroon space-y-2">
        <p class="font-semibold text-amber-800">Ikuti langkah ini:</p>
        <div class="space-y-1 text-amber-700">
          <p><span class="font-semibold">Chrome/Android:</span> Ketuk ikon gembok 🔒 di kiri atas → <b>Izin Situs</b> → <b>Kamera</b> → <b>Izinkan</b></p>
          <p><span class="font-semibold">Safari (iPhone):</span> <b>Pengaturan</b> → <b>Safari</b> → <b>Kamera</b> → <b>Izinkan</b></p>
          <p><span class="font-semibold">Samsung Internet:</span> Ketuk ikon 🔒 atau menu (⋮) → <b>Izin Situs</b> → <b>Kamera</b> → <b>Izinkan</b></p>
        </div>
      </div>
      <div class="flex flex-col gap-2">
        <button id="camera-modal-allow" class="w-full rounded-xl bg-gradient-to-r from-kkr-maroon to-kkr-red px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:shadow-md active:scale-[0.98]">
          Izinkan Kamera
        </button>
        <button id="camera-modal-cancel" class="w-full rounded-xl px-4 py-2.5 text-sm font-medium text-kkr-maroon/70 transition hover:text-kkr-maroon active:scale-[0.98]">
          Batal
        </button>
      </div>
    </div>
  </div>

  <div id="toast-container" class="fixed top-4 right-4 z-[100] flex flex-col gap-2 pointer-events-none"></div>

  <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js" defer></script>
  <script type="module">
    let mediaStream = null;
    let animFrameId = null;
    let qrScanning = false;

    function escapeHtml(str) {
      if (str == null) return "";
      return String(str).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }

    function toast(msg, type) {
      if (type == null) type = "success";
      const c = document.getElementById("toast-container");
      const el = document.createElement("div");
      el.className = "pointer-events-auto flex items-center gap-2.5 rounded-xl px-4 py-3 text-sm font-medium shadow-lg transition-all duration-300 animate-slide-up " + (type === "success" ? "bg-emerald-50 text-emerald-800 border border-emerald-200" : "bg-red-50 text-red-800 border border-red-200");
      el.innerHTML = (type === "success" ? '<svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>' : '<svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>');
      el.appendChild(document.createTextNode(" " + msg));
      c.appendChild(el);
      setTimeout(function() { el.style.opacity = "0"; el.style.transform = "translateX(100%)"; setTimeout(function() { el.remove(); }, 300); }, 3000);
    }

    function showCameraModal() {
      document.getElementById("camera-modal").classList.remove("hidden");
      document.getElementById("camera-modal-title").textContent = "Akses Kamera Diperlukan";
      document.getElementById("camera-modal-desc").textContent = "Izinkan akses kamera untuk memindai QR code tiket.";
      document.getElementById("camera-modal-steps").classList.add("hidden");
      var detailEl = document.getElementById("camera-modal-detail");
      if (detailEl) detailEl.classList.add("hidden");
      document.getElementById("camera-modal-allow").textContent = "Izinkan Kamera";
      document.getElementById("camera-modal-allow").disabled = false;
    }

    function showBlockedWithError(msgs) {
      document.getElementById("camera-modal").classList.remove("hidden");
      document.getElementById("camera-modal-title").textContent = "Kamera Tidak Dapat Diakses";
      document.getElementById("camera-modal-desc").textContent = msgs.join(" ");
      document.getElementById("camera-modal-steps").classList.remove("hidden");
      var errorEl = document.getElementById("camera-modal-detail");
      if (errorEl) { errorEl.textContent = msgs.join(" | "); errorEl.classList.remove("hidden"); }
      document.getElementById("camera-modal-allow").textContent = "Coba Lagi";
      document.getElementById("camera-modal-allow").disabled = false;
    }

    function hideCameraModal() {
      document.getElementById("camera-modal").classList.add("hidden");
    }

    function decodeFrame(video, canvas) {
      canvas.width = video.videoWidth;
      canvas.height = video.videoHeight;
      var ctx = canvas.getContext("2d");
      if (!ctx) return null;
      ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
      var imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
      var code = jsQR(imageData.data, imageData.width, imageData.height, { inversionAttempts: "dontInvert" });
      return (code && code.data) || null;
    }

    async function detectBarcode(video) {
      if (!window.BarcodeDetector) return null;
      try {
        var detector = new BarcodeDetector({ formats: ["qr_code"] });
        var barcodes = await detector.detect(video);
        return barcodes.length > 0 ? barcodes[0].rawValue : null;
      } catch (e) { return null; }
    }

    function scanLoop(video, canvas) {
      if (!qrScanning) return;
      animFrameId = requestAnimationFrame(function() { scanLoop(video, canvas); });

      detectBarcode(video).then(function(result) {
        if (result) {
          document.getElementById("checkin-id").value = result;
          var form = document.getElementById("checkin-form");
          if (form.requestSubmit) form.requestSubmit(); else form.submit();
          stopQrScanner();
          return;
        }
        try {
          var decoded = decodeFrame(video, canvas);
          if (decoded) {
            document.getElementById("checkin-id").value = decoded;
            var form = document.getElementById("checkin-form");
            if (form.requestSubmit) form.requestSubmit(); else form.submit();
            stopQrScanner();
          }
        } catch(e) {}
      }).catch(function() {});
    }

    function startCamera(stream, btn, readerEl, video, canvas) {
      readerEl.classList.remove("hidden");
      readerEl.style.height = "320px";
      hideCameraModal();

      video.srcObject = stream;
      mediaStream = stream;

      video.onloadedmetadata = function() {
        video.play().then(function() {
          qrScanning = true;
          btn.textContent = "Tutup";
          btn.disabled = false;
          scanLoop(video, canvas);
        }).catch(function() {
          showBlockedWithError(["Gagal memutar kamera."]);
          btn.textContent = "Scan"; btn.disabled = false;
        });
      };
    }

    async function tryCamera() {
      var btn = document.getElementById("scan-qr-btn");
      var readerEl = document.getElementById("qr-reader");
      var video = document.getElementById("qr-video");
      var canvas = document.getElementById("qr-canvas");

      btn.disabled = true;
      btn.textContent = "Mengakses kamera...";

      if (!navigator.mediaDevices) {
        showBlockedWithError(["Browser tidak mendukung akses kamera."]);
        btn.textContent = "Scan"; btn.disabled = false; return;
      }
      if (!window.isSecureContext) {
        showBlockedWithError(["Kamera hanya bisa diakses pada koneksi HTTPS."]);
        btn.textContent = "Scan"; btn.disabled = false; return;
      }

      var stream;
      try {
        stream = await navigator.mediaDevices.getUserMedia({
          video: { facingMode: { ideal: "environment" } }
        });
      } catch (err) {
        var name = err.name || "";
        var msgs = [];
        if (name === "NotAllowedError" || name === "PermissionDeniedError") {
          msgs.push("Akses kamera ditolak oleh browser.");
          msgs.push("Klik 'Coba Lagi' setelah mengizinkan di pengaturan.");
        } else {
          msgs.push("Error: " + (err.message || name || "unknown"));
        }
        showBlockedWithError(msgs);
        btn.textContent = "Scan"; btn.disabled = false;
        return;
      }

      startCamera(stream, btn, readerEl, video, canvas);
    }

    async function requestCamera() {
      var btn = document.getElementById("scan-qr-btn");
      var readerEl = document.getElementById("qr-reader");
      var video = document.getElementById("qr-video");
      var canvas = document.getElementById("qr-canvas");

      btn.disabled = true;
      btn.textContent = "Mengakses kamera...";

      var stream;
      try {
        stream = await navigator.mediaDevices.getUserMedia({
          video: { facingMode: { ideal: "environment" } }
        });
      } catch (e) {
        showBlockedWithError(["Akses kamera tetap ditolak. Periksa pengaturan browser."]);
        btn.textContent = "Scan"; btn.disabled = false;
        return;
      }

      startCamera(stream, btn, readerEl, video, canvas);
    }

    function stopQrScanner() {
      var readerEl = document.getElementById("qr-reader");
      var video = document.getElementById("qr-video");
      var btn = document.getElementById("scan-qr-btn");

      qrScanning = false;
      if (animFrameId) { cancelAnimationFrame(animFrameId); animFrameId = null; }
      if (mediaStream) {
        mediaStream.getTracks().forEach(function(t) { t.stop(); });
        mediaStream = null;
      }
      video.srcObject = null;
      readerEl.classList.add("hidden");
      readerEl.style.height = "";
      btn.textContent = "Scan";
      btn.disabled = false;
    }

    async function loadStats() {
      try {
        var res = await fetch("/api/stats");
        var d = await res.json();
        var cards = document.querySelectorAll("#stats-grid > div");
        var tr = d.totalRegistrants || 0;
        var ci = d.checkedIn || 0;
        if (cards.length >= 4) {
          var values = [tr, ci, tr - ci, d.sponsorCount || 0];
          cards.forEach(function(card, i) {
            var valEl = card.querySelector(".text-2xl");
            if (valEl && values[i] !== undefined) {
              var target = values[i];
              var current = 0;
              var step = Math.max(1, Math.floor(target / 30));
              var interval = setInterval(function() {
                current = Math.min(current + step, target);
                valEl.textContent = current;
                if (current >= target) clearInterval(interval);
              }, 30);
            }
          });
        }

        var uc = tr - ci;
        var rate = tr > 0 ? Math.round((ci / tr) * 100) : 0;
        document.getElementById("summary-checked").textContent = ci;
        document.getElementById("summary-unchecked").textContent = uc;
        document.getElementById("checkin-rate").textContent = rate + "% check-in";
        document.getElementById("summary-bar-checkin").style.width = rate + "%";
        document.getElementById("summary-bar-unchecked").style.width = (100 - rate) + "%";
        document.getElementById("metric-total").textContent = tr;
        document.getElementById("metric-rate").textContent = rate + "%";

        try { var r = await fetch("/api/sponsors"); var rd = await r.json(); document.getElementById("metric-sponsors").textContent = (rd.sponsors || []).filter(function(s){return s.is_active}).length; } catch(e) {}
        try { var r = await fetch("/api/speakers"); var rd = await r.json(); document.getElementById("metric-speakers").textContent = (rd.speakers || []).filter(function(s){return s.is_active}).length; } catch(e) {}
        try { var r = await fetch("/api/altar-servers"); var rd = await r.json(); document.getElementById("metric-altar").textContent = (rd.altarServers || []).filter(function(s){return s.is_active}).length; } catch(e) {}
      } catch(e) {}
    }

    async function loadRegistrants() {
      try {
        var res = await fetch("/api/registrants");
        var d = await res.json();
        var list = d.registrants || [];
        var tbody = document.getElementById("registrant-rows");
        if (!list.length) {
          tbody.innerHTML = '<tr><td colspan="5" class="py-12 text-center text-kkr-maroon/60 text-sm">Belum ada pendaftar.</td></tr>';
          return;
        }
        tbody.innerHTML = list.map(function(r) {
          return '<tr class="hover:bg-white/50 transition-colors">' +
            '<td class="py-3.5 px-5"><div class="flex items-center gap-2.5"><div class="w-8 h-8 rounded-full bg-gradient-to-br from-kkr-light to-kkr-light flex items-center justify-center text-xs font-bold text-kkr-red shrink-0">' + escapeHtml(r.name.charAt(0).toUpperCase()) + '</div><span class="font-medium text-kkr-dark">' + escapeHtml(r.name) + '</span></div></td>' +
            '<td class="py-3.5 px-5 text-kkr-maroon hidden sm:table-cell">' + escapeHtml(r.school || "") + '</td>' +
            '<td class="py-3.5 px-5 text-kkr-maroon">' + escapeHtml(r.ticket) + '</td>' +
            '<td class="py-3.5 px-5 hidden md:table-cell"><span class="inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-semibold ' + (r.checked_in ? 'bg-kkr-dark text-white' : 'bg-kkr-light/40 text-kkr-maroon') + '">' + (r.checked_in ? '✓ Checked-in' : '— Belum') + '</span></td>' +
            '<td class="py-3.5 px-5 text-right">' + (r.checked_in ? '<span class="inline-flex items-center gap-1 rounded-lg px-2.5 py-1.5 text-xs font-semibold bg-kkr-dark text-white"><svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Done</span>' : '<button data-action="checkin" data-id="' + escapeHtml(String(r.id)) + '" class="rounded-lg px-2.5 py-1.5 text-xs font-semibold transition bg-emerald-100 text-emerald-700 hover:bg-emerald-200">CI</button>') + '</td>' +
            '</tr>';
        }).join("");
      } catch(e) {}
    }

    async function loadTickets() {
      try {
        var res = await fetch("/api/tickets");
        var d = await res.json();
        var container = document.getElementById("ticket-mini-list");
        var list = d.tickets || [];
        container.innerHTML = list.map(function(t) {
          return '<div class="flex items-center justify-between rounded-xl border border-kkr-light/30 bg-white/50 p-3.5 transition hover:border-kkr-light/50">' +
            '<div class="flex items-center gap-3"><div class="w-2 h-2 rounded-full ' + (t.remaining > 0 ? 'bg-emerald-400' : 'bg-red-400') + '"></div><div><p class="text-sm font-semibold text-kkr-dark">' + escapeHtml(t.name) + '</p><p class="text-xs text-kkr-maroon/80 mt-0.5">Sisa: ' + t.remaining + ' tiket</p></div></div>' +
            '<span class="text-xs font-semibold px-2.5 py-1 rounded-full ' + (t.remaining > 0 ? 'bg-emerald-50 text-emerald-700' : 'bg-red-50 text-red-700') + '">' + (t.remaining > 0 ? 'Tersedia' : 'Habis') + '</span></div>';
        }).join("");
      } catch(e) {}
    }

    document.getElementById("registrant-rows")?.addEventListener("click", async function(e) {
      var btn = e.target.closest("button[data-action]");
      if (!btn) return;
      var id = btn.dataset.id;
      try {
        var res = await fetch("/api/registrants", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ id: id, action: "checkin" }) });
        if (res.ok) { loadRegistrants(); loadStats(); toast("Check-in berhasil!"); }
        else { var d = await res.json(); toast(d.error || "Gagal", "error"); }
      } catch(e) { toast("Gagal check-in", "error"); }
    });

    document.getElementById("checkin-form")?.addEventListener("submit", async function(e) {
      e.preventDefault();
      var code = document.getElementById("checkin-id").value.trim();
      if (!code) return;
      var resultEl = document.getElementById("checkin-result");
      resultEl.className = "rounded-xl p-3 text-sm";
      try {
        var res = await fetch("/api/registrants", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ id: code, action: "checkin" }) });
        var d = await res.json();
        if (res.ok) {
          var name = d.registrant?.name || "Peserta ditemukan";
          resultEl.className = "rounded-xl p-3 text-sm bg-emerald-50 text-emerald-700 border border-emerald-200";
          resultEl.textContent = name + " — Check-in berhasil!";
          loadRegistrants(); loadStats();
        } else {
          resultEl.className = "rounded-xl p-3 text-sm bg-red-50 text-red-700 border border-red-200";
          resultEl.textContent = d.error || "ID tidak ditemukan";
        }
      } catch(e) {
        resultEl.className = "rounded-xl p-3 text-sm bg-red-50 text-red-700 border border-red-200";
        resultEl.textContent = "Terjadi kesalahan";
      }
      resultEl.classList.remove("hidden");
    });

    document.getElementById("scan-qr-btn")?.addEventListener("click", function() {
      if (qrScanning) { stopQrScanner(); }
      else { tryCamera(); }
    });

    document.getElementById("camera-modal-allow")?.addEventListener("click", requestCamera);
    document.getElementById("camera-modal-cancel")?.addEventListener("click", function() {
      hideCameraModal();
      document.getElementById("scan-qr-btn").disabled = false;
    });

    document.addEventListener("DOMContentLoaded", function() { loadStats(); loadRegistrants(); loadTickets(); });
  </script>
</AdminLayout>
