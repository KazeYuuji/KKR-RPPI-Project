---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Kelola Sponsor">
  <div class="space-y-8 animate-fade-in">
    <!-- Header -->
    <div class="glass-card p-6 sm:p-8">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <div class="flex items-center gap-2 mb-1">
            <span class="w-1.5 h-1.5 rounded-full bg-kkr-red"></span>
            <span class="text-xs font-semibold uppercase tracking-wider text-kkr-maroon/60">Sponsor</span>
          </div>
          <h2 class="text-2xl sm:text-3xl font-semibold text-kkr-dark">Daftar Sponsor & Mitra</h2>
          <p class="mt-1 text-sm text-kkr-maroon">Tambah, edit, atau hapus sponsor yang tampil di halaman publik.</p>
        </div>
        <a href="/#sponsors" target="_blank" class="inline-flex items-center gap-1.5 rounded-xl border border-kkr-light/50 bg-white px-4 py-2.5 text-sm font-semibold text-kkr-maroon shadow-sm transition hover:bg-white hover:border-kkr-light/80">Lihat Halaman Publik</a>
      </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-[1fr_1.8fr] min-w-0">
      <!-- Form -->
      <div class="glass-card p-5 sm:p-6 h-fit lg:sticky lg:top-24">
        <h3 class="text-base font-semibold text-kkr-dark" id="form-title">Tambah Sponsor</h3>
        <p class="text-xs text-kkr-maroon mt-0.5" id="form-subtitle">Lengkapi data sponsor baru.</p>
        <form id="sponsor-form" class="mt-5 space-y-4">
          <input type="hidden" id="sp-id" />
          <div>
            <label class="block text-xs font-semibold text-kkr-purple mb-1.5 uppercase tracking-wider">Nama Sponsor *</label>
            <input id="sp-name" required class="w-full rounded-xl border border-kkr-light/50 bg-white px-4 py-2.5 text-sm text-kkr-dark outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20 placeholder:text-kkr-maroon/60" placeholder="Nama sekolah/perusahaan" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-kkr-purple mb-1.5 uppercase tracking-wider">Deskripsi</label>
            <textarea id="sp-desc" rows="2" class="w-full rounded-xl border border-kkr-light/50 bg-white px-4 py-2.5 text-sm text-kkr-dark outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20 placeholder:text-kkr-maroon/60" placeholder="Deskripsi singkat"></textarea>
          </div>
          <div>
            <label class="block text-xs font-semibold text-kkr-purple mb-1.5 uppercase tracking-wider">Website</label>
            <input id="sp-web" class="w-full rounded-xl border border-kkr-light/50 bg-white px-4 py-2.5 text-sm text-kkr-dark outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20 placeholder:text-kkr-maroon/60" placeholder="https://" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-kkr-purple mb-1.5 uppercase tracking-wider">Logo Sponsor</label>
            <div class="flex items-center gap-2">
              <input id="sp-logo" class="flex-1 min-w-0 rounded-xl border border-kkr-light/50 bg-white px-4 py-2.5 text-sm text-kkr-dark outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20 placeholder:text-kkr-maroon/60" placeholder="URL logo" />
              <button type="button" id="upload-logo-btn" class="rounded-xl bg-kkr-light/40 hover:bg-kkr-light/60 px-4 py-2.5 text-sm font-semibold text-kkr-maroon transition-colors shrink-0">Upload</button>
            </div>
            <input type="file" id="logo-file-input" accept="image/*" class="hidden" />
            <div id="logo-preview" class="mt-2 hidden">
              <img id="logo-preview-img" class="w-16 h-16 rounded-xl object-contain border border-kkr-light/50 bg-white shadow-sm" />
            </div>
          </div>
          <div class="flex gap-2 pt-1">
            <button type="submit" class="flex-1 rounded-xl bg-gradient-to-r from-kkr-maroon to-kkr-red px-4 py-2.5 text-sm font-semibold text-white shadow-sm shadow-kkr-light/50 transition hover:shadow-md active:scale-[0.98]">Simpan Sponsor</button>
            <button type="button" id="cancel-edit" class="hidden rounded-xl border border-kkr-light/50 bg-white px-4 py-2.5 text-sm font-semibold text-kkr-maroon hover:bg-white transition-colors">Batal</button>
          </div>
        </form>
      </div>

      <!-- List -->
      <div id="sponsor-list" class="space-y-3 min-w-0">
        <div class="glass-card p-8 text-center text-kkr-maroon/60">
          <div class="inline-block w-6 h-6 border-2 border-kkr-maroon border-t-transparent rounded-full animate-spin"></div>
          <p class="mt-2 text-sm">Memuat sponsor...</p>
        </div>
      </div>
    </div>
  </div>

  <div id="toast-container" class="fixed top-4 right-4 z-[100] flex flex-col gap-2 pointer-events-none"></div>

  <script>
    function escapeHtml(str) {
      if (str == null) return "";
      return String(str).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }

    function sanitizeUrl(url) {
      if (!url) return "";
      if (/^\s*javascript:/i.test(url)) return "";
      return url;
    }

    function toast(msg, type = "success") {
      const c = document.getElementById("toast-container");
      const el = document.createElement("div");
      el.className = `pointer-events-auto toast-enter rounded-xl px-5 py-3 text-sm font-medium shadow-lg ${type === "success" ? "bg-emerald-600 text-white shadow-emerald-300/30" : "bg-red-600 text-white shadow-red-300/30"}`;
      el.textContent = msg;
      c.appendChild(el);
      setTimeout(() => { el.className = el.className.replace("toast-enter", "toast-exit"); setTimeout(() => el.remove(), 300); }, 3000);
    }

    async function uploadFile(file) {
      const fd = new FormData(); fd.append("file", file);
      const res = await fetch("/api/upload", { method: "POST", body: fd });
      const d = await res.json();
      return d.url || null;
    }

    async function loadSponsors() {
      try {
        const res = await fetch("/api/sponsors");
        const d = await res.json();
        const list = d.sponsors || [];
        const container = document.getElementById("sponsor-list");
        if (!list.length) {
          container.innerHTML = `<div class="glass-card p-8 sm:p-12 text-center"><svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-kkr-red/60 mx-auto mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg><p class="text-kkr-maroon font-medium">Belum ada sponsor</p><p class="text-sm text-kkr-maroon/60 mt-1">Tambah sponsor pertama Anda melalui form di samping.</p></div>`;
          return;
        }
        container.innerHTML = list.map((s) => `
          <div class="glass-card p-4 sm:p-5 transition-all duration-200 hover:shadow-md" data-id="${escapeHtml(String(s.id))}">
            <div class="flex items-start gap-3 sm:gap-4">
              ${s.logo_url ? `<img src="${escapeHtml(sanitizeUrl(s.logo_url))}" loading="lazy" decoding="async" class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl object-contain border border-kkr-light/50 bg-white shadow-sm shrink-0" />` : `<div class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-white border border-kkr-light/50 flex items-center justify-center shrink-0 shadow-sm"><svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 sm:w-6 sm:h-6 text-kkr-red/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></div>`}
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <h4 class="font-semibold text-kkr-dark truncate">${escapeHtml(s.name)}</h4>
                  <span class="inline-flex items-center gap-1 text-[10px] font-medium ${s.is_active ? 'text-emerald-600' : 'text-kkr-maroon/60'}"><span class="w-1 h-1 rounded-full ${s.is_active ? 'bg-emerald-500' : 'bg-slate-300'}"></span>${s.is_active ? 'Aktif' : 'Nonaktif'}</span>
                </div>
                ${s.description ? `<p class="mt-1.5 text-sm text-kkr-maroon line-clamp-2">${escapeHtml(s.description)}</p>` : ""}
                ${s.website ? `<a href="${escapeHtml(sanitizeUrl(s.website))}" target="_blank" rel="noopener noreferrer" class="mt-1.5 inline-flex items-center gap-1 text-xs text-kkr-red hover:text-kkr-red font-medium truncate max-w-full">${escapeHtml(s.website)} <span>↗</span></a>` : ""}
              </div>
              <div class="flex items-start gap-1 shrink-0 pt-1">
                <button data-action="toggle" data-id="${escapeHtml(String(s.id))}" class="rounded-lg border px-3 py-1.5 text-xs font-semibold transition-colors shadow-sm ${s.is_active ? 'bg-white border-kkr-light/50 text-amber-600 hover:bg-amber-50 hover:border-amber-200' : 'bg-white border-kkr-light/50 text-emerald-600 hover:bg-emerald-50 hover:border-emerald-200'}">${s.is_active ? 'Nonaktif' : 'Aktif'}</button>
                <button data-action="edit" data-id="${escapeHtml(String(s.id))}" class="rounded-lg bg-white border border-kkr-light/50 px-3 py-1.5 text-xs font-semibold text-kkr-maroon hover:bg-white hover:border-kkr-light/80 transition-colors shadow-sm">Edit</button>
                <button data-action="delete" data-id="${escapeHtml(String(s.id))}" class="rounded-lg bg-white border border-kkr-light/50 px-3 py-1.5 text-xs font-semibold text-red-600 hover:bg-red-50 hover:border-red-200 transition-colors shadow-sm">Hapus</button>
              </div>
            </div>
          </div>
        `).join("");
      } catch {
        document.getElementById("sponsor-list").innerHTML = `<div class="rounded-2xl border border-red-200 bg-red-50 p-6 text-center text-red-600"><p>Gagal memuat data sponsor.</p></div>`;
      }
    }

    function fillForm(s) {
      document.getElementById("sp-id").value = s.id;
      document.getElementById("sp-name").value = s.name;
      document.getElementById("sp-desc").value = s.description || "";
      document.getElementById("sp-web").value = s.website || "";
      document.getElementById("sp-logo").value = s.logo_url || "";
      document.getElementById("form-title").textContent = "Edit Sponsor";
      document.getElementById("form-subtitle").textContent = "Perbarui data sponsor.";
      document.getElementById("cancel-edit").classList.remove("hidden");
      if (s.logo_url) { document.getElementById("logo-preview").classList.remove("hidden"); document.getElementById("logo-preview-img").src = s.logo_url; }
      else { document.getElementById("logo-preview").classList.add("hidden"); }
      document.getElementById("sponsor-form").scrollIntoView({ behavior: "smooth" });
    }

    document.getElementById("sponsor-form")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const id = document.getElementById("sp-id").value;
      const payload = { name: document.getElementById("sp-name").value.trim(), description: document.getElementById("sp-desc").value.trim(), website: document.getElementById("sp-web").value.trim(), logo_url: document.getElementById("sp-logo").value.trim() };
      try {
        const url = id ? `/api/sponsors/${id}` : "/api/sponsors";
        const method = id ? "PUT" : "POST";
        const res = await fetch(url, { method, headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) });
        if (res.ok) {
          toast(id ? "Sponsor diperbarui" : "Sponsor ditambahkan");
          document.getElementById("sponsor-form").reset(); document.getElementById("sp-id").value = "";
          document.getElementById("form-title").textContent = "Tambah Sponsor"; document.getElementById("form-subtitle").textContent = "Lengkapi data sponsor baru.";
          document.getElementById("cancel-edit").classList.add("hidden"); document.getElementById("logo-preview").classList.add("hidden");
          loadSponsors();
        } else { toast("Gagal menyimpan", "error"); }
      } catch { toast("Gagal menyimpan", "error"); }
    });

    document.getElementById("cancel-edit")?.addEventListener("click", () => {
      document.getElementById("sponsor-form").reset(); document.getElementById("sp-id").value = "";
      document.getElementById("form-title").textContent = "Tambah Sponsor"; document.getElementById("form-subtitle").textContent = "Lengkapi data sponsor baru.";
      document.getElementById("cancel-edit").classList.add("hidden"); document.getElementById("logo-preview").classList.add("hidden");
    });

    document.getElementById("sponsor-list")?.addEventListener("click", async (e) => {
      const btn = e.target.closest("button[data-action]");
      if (!btn) return;
      const id = btn.dataset.id;
      if (btn.dataset.action === "delete") {
        if (!confirm("Hapus sponsor ini?")) return;
        try { const res = await fetch(`/api/sponsors/${id}`, { method: "DELETE" }); if (res.ok) { toast("Sponsor dihapus"); loadSponsors(); } } catch { toast("Gagal menghapus", "error"); }
      }
      if (btn.dataset.action === "toggle") {
        try { await fetch(`/api/sponsors/${id}`, { method: "PUT", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ is_active: btn.textContent.trim() === "Nonaktif" ? false : true }) }); loadSponsors(); } catch { toast("Gagal memperbarui", "error"); }
      }
      if (btn.dataset.action === "edit") {
        try { const res = await fetch(`/api/sponsors/${id}`); const d = await res.json(); if (d.sponsor) fillForm(d.sponsor); } catch { toast("Gagal memuat data", "error"); }
      }
    });

    document.getElementById("upload-logo-btn")?.addEventListener("click", () => document.getElementById("logo-file-input").click());
    document.getElementById("logo-file-input")?.addEventListener("change", async (e) => {
      const file = e.target.files?.[0]; if (!file) return;
      try { const url = await uploadFile(file); if (url) { document.getElementById("sp-logo").value = url; document.getElementById("logo-preview").classList.remove("hidden"); document.getElementById("logo-preview-img").src = url; toast("Logo berhasil diupload"); } } catch { toast("Gagal upload logo", "error"); }
      e.target.value = "";
    });

    document.addEventListener("DOMContentLoaded", loadSponsors);
  </script>
</AdminLayout>
