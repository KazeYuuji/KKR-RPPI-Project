---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Kelola Pembicara">
  <div class="space-y-8 animate-fade-in">
    <!-- Header -->
    <div class="glass-card p-6 sm:p-8">
      <div>
        <div class="flex items-center gap-2 mb-1">
          <span class="w-1.5 h-1.5 rounded-full bg-kkr-red"></span>
          <span class="text-xs font-semibold uppercase tracking-wider text-kkr-maroon/60">Pembicara</span>
        </div>
        <h2 class="text-2xl sm:text-3xl font-semibold text-kkr-dark">Manajemen Pembicara</h2>
        <p class="mt-1 text-sm text-kkr-maroon">Tambah, edit, atau hapus pembicara yang tampil di halaman publik.</p>
      </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-[1fr_1.8fr] min-w-0">
      <!-- Form -->
      <div class="glass-card p-5 sm:p-6 h-fit lg:sticky lg:top-24">
        <h3 class="text-base font-semibold text-kkr-dark" id="form-title">Tambah Pembicara</h3>
        <p class="text-xs text-kkr-maroon mt-0.5" id="form-subtitle">Lengkapi data pembicara baru.</p>
        <form id="speaker-form" class="mt-5 space-y-4">
          <input type="hidden" id="sp-id" />
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-semibold text-kkr-purple mb-1.5 uppercase tracking-wider">Nama *</label>
              <input id="sp-name" required class="w-full rounded-xl border border-kkr-light/50 bg-white px-4 py-2.5 text-sm text-kkr-dark outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20 placeholder:text-kkr-maroon/60" placeholder="Nama pembicara" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-kkr-purple mb-1.5 uppercase tracking-wider">Title</label>
              <input id="sp-title" class="w-full rounded-xl border border-kkr-light/50 bg-white px-4 py-2.5 text-sm text-kkr-dark outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20 placeholder:text-kkr-maroon/60" placeholder="Pendeta / Dosen" />
            </div>
          </div>
          <div>
            <label class="block text-xs font-semibold text-kkr-purple mb-1.5 uppercase tracking-wider">Organisasi</label>
            <input id="sp-org" class="w-full rounded-xl border border-kkr-light/50 bg-white px-4 py-2.5 text-sm text-kkr-dark outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20 placeholder:text-kkr-maroon/60" placeholder="Gereja / Institusi" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-kkr-purple mb-1.5 uppercase tracking-wider">Deskripsi</label>
            <textarea id="sp-desc" rows="3" class="w-full rounded-xl border border-kkr-light/50 bg-white px-4 py-2.5 text-sm text-kkr-dark outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20 placeholder:text-kkr-maroon/60" placeholder="Deskripsi singkat"></textarea>
          </div>
          <div>
            <label class="block text-xs font-semibold text-kkr-purple mb-1.5 uppercase tracking-wider">Story Pembicara</label>
            <textarea id="sp-story" rows="5" class="w-full rounded-xl border border-kkr-light/50 bg-white px-4 py-2.5 text-sm text-kkr-dark outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20 placeholder:text-kkr-maroon/60" placeholder="Cerita atau kesaksian dari pembicara..."></textarea>
          </div>
          <div>
            <label class="block text-xs font-semibold text-kkr-purple mb-1.5 uppercase tracking-wider">Tags (pisahkan koma)</label>
            <input id="sp-tags" class="w-full rounded-xl border border-kkr-light/50 bg-white px-4 py-2.5 text-sm text-kkr-dark outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20 placeholder:text-kkr-maroon/60" placeholder="Kebangunan Rohani, Iman, Pelayanan" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-kkr-purple mb-1.5 uppercase tracking-wider">Foto</label>
            <div class="flex items-center gap-2">
              <input id="sp-photo" class="flex-1 min-w-0 rounded-xl border border-kkr-light/50 bg-white px-4 py-2.5 text-sm text-kkr-dark outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20 placeholder:text-kkr-maroon/60" placeholder="URL foto" />
              <button type="button" id="upload-photo-btn" class="rounded-xl bg-kkr-light/40 hover:bg-kkr-light/60 px-4 py-2.5 text-sm font-semibold text-kkr-maroon transition-colors shrink-0">Upload</button>
            </div>
            <input type="file" id="photo-file-input" accept="image/*" class="hidden" />
            <div id="photo-preview" class="mt-2 hidden">
              <img id="photo-preview-img" class="w-20 h-20 rounded-xl object-cover border border-kkr-light/50 shadow-sm" />
            </div>
          </div>
          <div class="flex gap-2 pt-1">
            <button type="submit" class="flex-1 rounded-xl bg-gradient-to-r from-kkr-maroon to-kkr-red px-4 py-2.5 text-sm font-semibold text-white shadow-sm shadow-kkr-light/50 transition hover:shadow-md active:scale-[0.98]">Simpan Pembicara</button>
            <button type="button" id="cancel-edit" class="hidden rounded-xl border border-kkr-light/50 bg-white px-4 py-2.5 text-sm font-semibold text-kkr-maroon hover:bg-white transition-colors">Batal</button>
          </div>
        </form>
      </div>

      <!-- List -->
      <div id="speaker-list" class="space-y-3 min-w-0">
        <div class="glass-card p-8 text-center text-kkr-maroon/60">
          <div class="inline-block w-6 h-6 border-2 border-kkr-maroon border-t-transparent rounded-full animate-spin"></div>
          <p class="mt-2 text-sm">Memuat pembicara...</p>
        </div>
      </div>
    </div>
  </div>

  <div id="toast-container" class="fixed top-4 right-4 z-[100] flex flex-col gap-2 pointer-events-none"></div>

  <script>
    function escapeHtml(str) {
      const div = document.createElement("div");
      div.textContent = str;
      return div.innerHTML;
    }

    function sanitizeUrl(url) {
      if (!url) return "";
      try { const u = new URL(url); return (u.protocol === "http:" || u.protocol === "https:") ? url : ""; } catch { return ""; }
    }

    function toast(msg, type = "success") {
      const c = document.getElementById("toast-container");
      const el = document.createElement("div");
      el.className = `pointer-events-auto toast-enter rounded-xl px-5 py-3 text-sm font-medium shadow-lg ${type === "success" ? "bg-emerald-600 text-white shadow-emerald-300/30" : "bg-red-600 text-white shadow-red-300/30"}`;
      el.textContent = msg;
      c.appendChild(el);
      setTimeout(() => { el.className = el.className.replace("toast-enter", "toast-exit"); setTimeout(() => el.remove(), 300); }, 3000);
    }

    async function uploadFile(file) {
      const fd = new FormData(); fd.append("file", file);
      const res = await fetch("/api/upload", { method: "POST", body: fd });
      const d = await res.json();
      return d.url || null;
    }

    async function loadSpeakers() {
      try {
        const res = await fetch("/api/speakers");
        const d = await res.json();
        const list = d.speakers || [];
        const container = document.getElementById("speaker-list");
        if (!list.length) {
          container.innerHTML = `<div class="glass-card p-8 sm:p-12 text-center"><svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-kkr-red/60 mx-auto mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg><p class="text-kkr-maroon font-medium">Belum ada pembicara</p><p class="text-sm text-kkr-maroon/60 mt-1">Tambah pembicara pertama Anda melalui form di samping.</p></div>`;
          return;
        }
        container.innerHTML = list.map((s) => `
          <div class="glass-card p-4 sm:p-5 transition-all duration-200 hover:shadow-md" data-id="${escapeHtml(String(s.id))}">
            <div class="flex items-start gap-3 sm:gap-4">
              ${s.photo_url ? `<img src="${escapeHtml(sanitizeUrl(s.photo_url))}" loading="lazy" decoding="async" class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl object-cover border border-kkr-light/50 shadow-sm shrink-0" />` : `<div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-gradient-to-br from-blue-50 to-kkr-light border border-kkr-light/50 flex items-center justify-center shrink-0 shadow-sm"><svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-kkr-red/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg></div>`}
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <h4 class="font-semibold text-kkr-dark truncate">${escapeHtml(s.name)}</h4>
                  <span class="inline-flex items-center gap-1 text-[10px] font-medium ${s.is_active ? 'text-emerald-600' : 'text-kkr-maroon/60'}"><span class="w-1 h-1 rounded-full ${s.is_active ? 'bg-emerald-500' : 'bg-slate-300'}"></span>${s.is_active ? 'Aktif' : 'Nonaktif'}</span>
                </div>
                ${s.title || s.organization ? `<p class="text-xs text-kkr-maroon/80 mt-0.5 truncate">${escapeHtml([s.title, s.organization].filter(Boolean).join(" · "))}</p>` : ""}
                ${s.description ? `<p class="mt-1.5 text-sm text-kkr-maroon line-clamp-2">${escapeHtml(s.description)}</p>` : ""}
                ${s.tags && typeof s.tags === 'string' ? `<div class="flex flex-wrap gap-1 mt-2">${s.tags.split(",").map(t => `<span class="text-[10px] bg-kkr-light text-kkr-red px-2 py-0.5 rounded-full font-medium">${escapeHtml(t.trim())}</span>`).join("")}</div>` : ""}
              </div>
              <div class="flex items-start gap-1 shrink-0 pt-1">
                <button data-action="edit" data-id="${escapeHtml(String(s.id))}" class="rounded-lg bg-white border border-kkr-light/50 px-3 py-1.5 text-xs font-semibold text-kkr-maroon hover:bg-white hover:border-kkr-light/80 transition-colors shadow-sm">Edit</button>
                <button data-action="delete" data-id="${escapeHtml(String(s.id))}" class="rounded-lg bg-white border border-kkr-light/50 px-3 py-1.5 text-xs font-semibold text-red-600 hover:bg-red-50 hover:border-red-200 transition-colors shadow-sm">Hapus</button>
              </div>
            </div>
          </div>
        `).join("");
      } catch {
        document.getElementById("speaker-list").innerHTML = `<div class="rounded-2xl border border-red-200 bg-red-50 p-6 text-center text-red-600"><p>Gagal memuat data pembicara.</p></div>`;
      }
    }

    function fillForm(s) {
      document.getElementById("sp-id").value = s.id;
      document.getElementById("sp-name").value = s.name;
      document.getElementById("sp-title").value = s.title || "";
      document.getElementById("sp-org").value = s.organization || "";
      document.getElementById("sp-desc").value = s.description || "";
      document.getElementById("sp-story").value = s.story || "";
      document.getElementById("sp-tags").value = s.tags || "";
      document.getElementById("sp-photo").value = s.photo_url || "";
      document.getElementById("form-title").textContent = "Edit Pembicara";
      document.getElementById("form-subtitle").textContent = "Perbarui data pembicara.";
      document.getElementById("cancel-edit").classList.remove("hidden");
      if (s.photo_url) { document.getElementById("photo-preview").classList.remove("hidden"); document.getElementById("photo-preview-img").src = s.photo_url; }
      else { document.getElementById("photo-preview").classList.add("hidden"); }
      document.getElementById("speaker-form").scrollIntoView({ behavior: "smooth" });
    }

    document.getElementById("speaker-form")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const id = document.getElementById("sp-id").value;
      const payload = { name: document.getElementById("sp-name").value.trim(), title: document.getElementById("sp-title").value.trim(), organization: document.getElementById("sp-org").value.trim(), description: document.getElementById("sp-desc").value.trim(), story: document.getElementById("sp-story").value.trim(), photo_url: document.getElementById("sp-photo").value.trim(), tags: document.getElementById("sp-tags").value.trim() };
      try {
        const url = id ? `/api/speakers/${id}` : "/api/speakers";
        const method = id ? "PUT" : "POST";
        const res = await fetch(url, { method, headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) });
        if (res.ok) {
          toast(id ? "Pembicara diperbarui" : "Pembicara ditambahkan");
          document.getElementById("speaker-form").reset(); document.getElementById("sp-id").value = "";
          document.getElementById("form-title").textContent = "Tambah Pembicara"; document.getElementById("form-subtitle").textContent = "Lengkapi data pembicara baru.";
          document.getElementById("cancel-edit").classList.add("hidden"); document.getElementById("photo-preview").classList.add("hidden");
          loadSpeakers();
        } else { toast("Gagal menyimpan", "error"); }
      } catch { toast("Gagal menyimpan", "error"); }
    });

    document.getElementById("cancel-edit")?.addEventListener("click", () => {
      document.getElementById("speaker-form").reset(); document.getElementById("sp-id").value = "";
      document.getElementById("form-title").textContent = "Tambah Pembicara"; document.getElementById("form-subtitle").textContent = "Lengkapi data pembicara baru.";
      document.getElementById("cancel-edit").classList.add("hidden"); document.getElementById("photo-preview").classList.add("hidden");
    });

    document.getElementById("speaker-list")?.addEventListener("click", async (e) => {
      const btn = e.target.closest("button[data-action]");
      if (!btn) return;
      const id = btn.dataset.id;
      if (btn.dataset.action === "delete") {
        if (!confirm("Hapus pembicara ini?")) return;
        try { const res = await fetch(`/api/speakers/${id}`, { method: "DELETE" }); if (res.ok) { toast("Pembicara dihapus"); loadSpeakers(); } } catch { toast("Gagal menghapus", "error"); }
      }
      if (btn.dataset.action === "edit") {
        try { const res = await fetch(`/api/speakers/${id}`); const d = await res.json(); if (d.speaker) fillForm(d.speaker); } catch { toast("Gagal memuat data", "error"); }
      }
    });

    document.getElementById("upload-photo-btn")?.addEventListener("click", () => document.getElementById("photo-file-input")?.click());
    document.getElementById("photo-file-input")?.addEventListener("change", async (e) => {
      const file = e.target.files?.[0]; if (!file) return;
      try { const url = await uploadFile(file); if (url) { document.getElementById("sp-photo").value = url; document.getElementById("photo-preview").classList.remove("hidden"); document.getElementById("photo-preview-img").src = url; toast("Foto berhasil diupload"); } } catch { toast("Gagal upload foto", "error"); }
      e.target.value = "";
    });

    document.addEventListener("DOMContentLoaded", loadSpeakers);
  </script>
</AdminLayout>
