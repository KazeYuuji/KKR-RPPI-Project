---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Pengaturan">
  <div class="space-y-8 animate-fade-in max-w-3xl">
    <!-- Location Settings -->
    <div class="glass-card p-6 sm:p-8">
      <div class="flex items-center gap-3 mb-1">
        <span class="w-8 h-8 rounded-xl bg-kkr-light/40 flex items-center justify-center text-kkr-red shrink-0"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
        <h2 class="text-xl font-semibold text-kkr-dark">Lokasi Tempat</h2>
      </div>
      <p class="text-sm text-kkr-maroon mt-1">Masukkan nama tempat dan link Google Maps. Peta akan otomatis ditampilkan di website.</p>
      <form id="location-form" class="mt-6 space-y-4">
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">Nama Tempat</label>
          <input id="loc-venue" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="SMK PGRI 1 Kediri" />
        </div>
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">URL Google Maps</label>
          <input id="loc-maps-link" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="https://maps.app.goo.gl/RCzwb8tiKNdVwXA59" />
          <p class="text-xs text-kkr-maroon/60 mt-1">Link Google Maps (bisa dari share/bagikan atau URL maps). Embed peta akan otomatis dibuat.</p>
        </div>
        <button type="submit" class="rounded-xl bg-kkr-red px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-kkr-maroon">Simpan Lokasi</button>
      </form>
    </div>

    <!-- Landing Page Sections -->
    <div class="glass-card p-6 sm:p-8">
      <div class="flex items-center gap-3 mb-1">
        <span class="w-8 h-8 rounded-xl bg-kkr-light/40 flex items-center justify-center text-kkr-red shrink-0"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg></span>
        <h2 class="text-xl font-semibold text-kkr-dark">Teks Setiap Section</h2>
      </div>
      <p class="text-sm text-kkr-maroon mt-1">Sesuaikan label, judul, dan deskripsi setiap section di halaman utama.</p>
      <form id="sections-form" class="mt-6 space-y-6">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-kkr-purple mb-3">Section Pembicara</p>
          <div class="grid gap-4 sm:grid-cols-3">
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Label</label>
              <input id="section-label-speakers" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Pembicara" />
            </div>
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Judul</label>
              <input id="section-heading-speakers" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Bersama Pembicara Rohani" />
            </div>
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Label Kisah</label>
              <input id="section-label-story" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Story Pembicara" />
            </div>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 mt-4">
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Tombol Sebelumnya</label>
              <input id="btn-speaker-prev" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Sebelumnya" />
            </div>
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Tombol Selanjutnya</label>
              <input id="btn-speaker-next" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Selanjutnya" />
            </div>
          </div>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-kkr-purple mb-3">Section Pelayan Altar</p>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Label</label>
              <input id="section-label-altar" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Pelayan Altar" />
            </div>
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Judul</label>
              <input id="section-heading-altar" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Pelayan Altar KKR RPPI" />
            </div>
          </div>
          <div class="mt-4">
            <label class="block text-sm font-medium text-kkr-purple mb-1">Deskripsi</label>
            <textarea id="section-desc-altar" rows="2" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Para pelayan altar yang melayani dalam kebangunan rohani"></textarea>
          </div>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-kkr-purple mb-3">Section Sponsor</p>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Label</label>
              <input id="section-label-sponsors" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Sponsor & Mitra" />
            </div>
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Judul</label>
              <input id="section-heading-sponsors" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Didukung oleh" />
            </div>
          </div>
          <div class="mt-4">
            <label class="block text-sm font-medium text-kkr-purple mb-1">Deskripsi</label>
            <textarea id="section-desc-sponsors" rows="2" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Para sponsor dan mitra yang mendukung terselenggaranya KKR RPPI 2026"></textarea>
          </div>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-kkr-purple mb-3">Section Lainnya</p>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Label Lokasi</label>
              <input id="section-label-location" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Lokasi & Waktu" />
            </div>
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Label CTA</label>
              <input id="section-label-cta" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Siap Bergabung?" />
            </div>
          </div>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-kkr-purple mb-3">Teks Tombol</p>
          <div class="grid gap-4 sm:grid-cols-3">
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Tombol Hero (Utama)</label>
              <input id="btn-hero-primary" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Daftar Sekarang" />
            </div>
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Tombol Hero (Kedua)</label>
              <input id="btn-hero-secondary" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Info Acara" />
            </div>
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Tombol Sponsor</label>
              <input id="btn-sponsor-contact" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Tertarik jadi Sponsor? Hubungi Kami" />
            </div>
          </div>
        </div>
        <button type="submit" class="rounded-xl bg-kkr-red px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-kkr-maroon">Simpan Semua Teks Section</button>
      </form>
    </div>

    <!-- Countdown Text -->
    <div class="glass-card p-6 sm:p-8">
      <div class="flex items-center gap-3 mb-1">
        <span class="w-8 h-8 rounded-xl bg-kkr-light/40 flex items-center justify-center text-kkr-red shrink-0"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
        <h2 class="text-xl font-semibold text-kkr-dark">Teks Countdown</h2>
      </div>
      <p class="text-sm text-kkr-maroon mt-1">Sesuaikan teks yang muncul di bagian countdown.</p>
      <form id="countdown-form" class="mt-6 space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Subtitle Countdown</label>
            <input id="countdown-subtitle" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Waktu Terus Berjalan" />
          </div>
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Judul Countdown</label>
            <input id="countdown-heading" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Jangan Lewatkan!" />
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Label Pendaftaran</label>
            <input id="countdown-reg-label" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Segera Ditutup" />
          </div>
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Deskripsi Pendaftaran</label>
            <input id="countdown-reg-desc" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Batas Pendaftaran Tiket" />
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Label Acara</label>
            <input id="countdown-event-label" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Hari H" />
          </div>
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Deskripsi Acara</label>
            <input id="countdown-event-desc" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Menuju Puncak Acara" />
          </div>
        </div>
        <button type="submit" class="rounded-xl bg-kkr-red px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-kkr-maroon">Simpan Teks Countdown</button>
      </form>
    </div>

    <!-- Event Schedule -->
    <div class="glass-card p-6 sm:p-8">
      <div class="flex items-center gap-3 mb-1">
        <span class="w-8 h-8 rounded-xl bg-kkr-light/40 flex items-center justify-center text-kkr-red shrink-0"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span>
        <h2 class="text-xl font-semibold text-kkr-dark">Jadwal Acara</h2>
      </div>
      <p class="text-sm text-kkr-maroon mt-1">Pilih tanggal dan waktu acara. Tampilan tanggal akan dibuat otomatis.</p>
      <form id="schedule-form" class="mt-6 space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Tanggal & Jam Mulai Acara</label>
            <input id="event-date-iso" type="datetime-local" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" />
          </div>
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Jam Selesai Acara</label>
            <input id="event-time-end" type="time" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" />
          </div>
        </div>
        <div class="rounded-xl bg-kkr-light/30 p-4 text-sm text-kkr-maroon/80 space-y-1">
          <p><strong>Preview tampilan:</strong></p>
          <p id="preview-date" class="text-kkr-dark">Tanggal: —</p>
          <p id="preview-time" class="text-kkr-dark">Waktu: —</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">Batas Akhir Pendaftaran</label>
          <input id="reg-deadline-iso" type="datetime-local" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" />
          <p id="preview-deadline" class="text-xs text-kkr-maroon/60 mt-1">Tampilan: —</p>
        </div>
        <button type="submit" class="rounded-xl bg-kkr-red px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-kkr-maroon">Simpan Jadwal</button>
      </form>
    </div>

    <!-- Contact Settings -->
    <div class="glass-card p-6 sm:p-8">
      <div class="flex items-center gap-3 mb-1">
        <span class="w-8 h-8 rounded-xl bg-kkr-light/40 flex items-center justify-center text-kkr-red shrink-0"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
        <h2 class="text-xl font-semibold text-kkr-dark">Kontak</h2>
      </div>
      <p class="text-sm text-kkr-maroon mt-1">Informasi kontak yang ditampilkan di website.</p>
      <form id="contact-form" class="mt-6 space-y-4">
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">Email</label>
          <input id="contact-email" type="email" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="kkrrppi@gmail.com" />
        </div>
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">Telepon</label>
          <input id="contact-phone" type="tel" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="(0354) 682433" />
        </div>
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">Nomor WhatsApp (dengan kode negara)</label>
          <input id="contact-wa" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="6285800753804" />
        </div>
        <button type="submit" class="rounded-xl bg-kkr-red px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-kkr-maroon">Simpan Kontak</button>
      </form>
    </div>

    <!-- Landing Page Text -->
    <div class="glass-card p-6 sm:p-8">
      <div class="flex items-center gap-3 mb-1">
        <span class="w-8 h-8 rounded-xl bg-kkr-light/40 flex items-center justify-center text-kkr-red shrink-0"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></span>
        <h2 class="text-xl font-semibold text-kkr-dark">Teks Landing Page</h2>
      </div>
      <p class="text-sm text-kkr-maroon mt-1">Sesuaikan teks yang muncul di halaman utama dan halaman pendaftaran.</p>
      <form id="text-form" class="mt-6 space-y-4">
        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Hero Heading (baris 1)</label>
            <input id="hero-heading1" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="TRUST" />
          </div>
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Hero Heading (baris 2)</label>
            <input id="hero-heading2" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="IN" />
          </div>
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Hero Heading (baris 3)</label>
            <input id="hero-heading3" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="GOD" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">Label Subtitle Hero</label>
          <input id="hero-subtitle-label" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Ibadah Kebaktian Kebangunan Rohani" />
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Judul Hero (baris 1)</label>
            <input id="hero-title1" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Terang dalam" />
          </div>
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Judul Hero (baris 2, warna merah)</label>
            <input id="hero-title2" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Kasih Kristus" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">Subtitle Hero (ayat + ref)</label>
          <textarea id="hero-subtitle" rows="2" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder='"Jika umat-Ku yang disebut dengan nama-Ku merendahkan diri, berdoa dan mencari wajah-Ku, maka Aku akan mendengar dari sorga." — 2 Tawarikh 7:14'></textarea>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Judul Tentang Acara</label>
