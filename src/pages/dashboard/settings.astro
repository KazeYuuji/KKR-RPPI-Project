        setVal("event-card-badge", s.eventCardBadge || "");
        setVal("hero-subtitle-label", s.heroSubtitleLabel || "");

        // Section texts
        setVal("section-label-speakers", s.sectionLabelSpeakers || "");
        setVal("section-heading-speakers", s.sectionHeadingSpeakers || "");
        setVal("section-label-story", s.sectionLabelStory || "");
