        setVal("section-label-cta", s.sectionLabelCta || "");
        setVal("btn-hero-primary", s.btnHeroPrimary || "");
        setVal("btn-hero-secondary", s.btnHeroSecondary || "");
        setVal("btn-sponsor-contact", s.btnSponsorContact || "");

        // Countdown texts
        setVal("countdown-subtitle", s.countdownSubtitle || "");
        setVal("countdown-heading", s.countdownHeading || "");
        setVal("countdown-reg-label", s.countdownRegLabel || "");
