          heroTitle1: document.getElementById("hero-title1").value.trim(),
          heroTitle2: document.getElementById("hero-title2").value.trim(),
          heroHeading1: document.getElementById("hero-heading1").value.trim(),
          heroHeading2: document.getElementById("hero-heading2").value.trim(),
          heroHeading3: document.getElementById("hero-heading3").value.trim(),
          heroSubtitle: document.getElementById("hero-subtitle").value.trim(),
          aboutTitle: document.getElementById("about-title").value.trim(),
          aboutDesc1: document.getElementById("about-desc1").value.trim(),
          aboutDesc2: document.getElementById("about-desc2").value.trim(),
          ctaTitle: document.getElementById("cta-title").value.trim(),
          ctaDesc: document.getElementById("cta-desc").value.trim(),
          aboutCard1Title: document.getElementById("about-card1-title").value.trim(),
          aboutCard1Desc: document.getElementById("about-card1-desc").value.trim(),
          aboutCard2Title: document.getElementById("about-card2-title").value.trim(),
          aboutCard2Desc: document.getElementById("about-card2-desc").value.trim(),
          aboutBlockquote: document.getElementById("about-blockquote").value.trim(),
        })});
        if (res.ok) toast("Teks berhasil disimpan!");
        else throw new Error();
      } catch { toast("Gagal menyimpan teks", "error"); }
      btn.disabled = false; btn.textContent = "Simpan Teks";
    });

    document.addEventListener("DOMContentLoaded", () => { loadSettings(); loadTickets(); });
  </script>
