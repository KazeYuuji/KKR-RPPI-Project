          eventCardLabelPukul: document.getElementById("event-card-label-pukul").value.trim(),
          eventCardLabelTempat: document.getElementById("event-card-label-tempat").value.trim(),
          eventCardBrand: document.getElementById("event-card-brand").value.trim(),
          locSubLabelAlamat: document.getElementById("loc-sub-label-alamat").value.trim(),
          locSubLabelTanggal: document.getElementById("loc-sub-label-tanggal").value.trim(),
          locSubLabelWaktu: document.getElementById("loc-sub-label-waktu").value.trim(),
          locSubLabelBatasDaftar: document.getElementById("loc-sub-label-batas-daftar").value.trim(),
          locSubLabelKontak: document.getElementById("loc-sub-label-kontak").value.trim(),
          locBtnMaps: document.getElementById("loc-btn-maps").value.trim(),
          ctaContactLabel: document.getElementById("cta-contact-label").value.trim(),
        })});
        if (res.ok) toast("Teks berhasil disimpan!");
        else throw new Error();
      } catch { toast("Gagal menyimpan teks", "error"); }
      btn.disabled = false; btn.textContent = "Simpan Teks";
    });

    document.getElementById("reg-form")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector("button[type=submit]");
      btn.disabled = true; btn.textContent = "Menyimpan...";
      try {
        const res = await fetch("/api/settings", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({
          regSectionLabel: document.getElementById("reg-section-label").value.trim(),
          regHeading: document.getElementById("reg-heading").value.trim(),
          regDescription: document.getElementById("reg-description").value.trim(),
          regSidebarBadge: document.getElementById("reg-sidebar-badge").value.trim(),
          regSidebarTitle: document.getElementById("reg-sidebar-title").value.trim(),
          regSidebarDesc: document.getElementById("reg-sidebar-desc").value.trim(),
          regLocationLabel: document.getElementById("reg-location-label").value.trim(),
          regMapsBtnText: document.getElementById("reg-maps-btn-text").value.trim(),
        })});
        if (res.ok) toast("Teks pendaftaran berhasil disimpan!");
        else throw new Error();
      } catch { toast("Gagal menyimpan teks pendaftaran", "error"); }
      btn.disabled = false; btn.textContent = "Simpan Teks Pendaftaran";
    });

    document.getElementById("admin-account-form")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const errorEl = document.getElementById("admin-account-error");
      const btn = e.target.querySelector("button[type=submit]");
      errorEl.classList.add("hidden");
      btn.disabled = true; btn.textContent = "Menyimpan...";

      const current_password = document.getElementById("admin-current-password").value;
      const new_username = document.getElementById("admin-username").value.trim();
      const new_password = document.getElementById("admin-password").value;

      if (!current_password) {
        errorEl.textContent = "Password saat ini wajib diisi";
        errorEl.classList.remove("hidden");
        btn.disabled = false; btn.textContent = "Simpan Perubahan";
        return;
      }

      if (new_password && new_password.length < 8) {
        errorEl.textContent = "Password baru minimal 8 karakter";
        errorEl.classList.remove("hidden");
        btn.disabled = false; btn.textContent = "Simpan Perubahan";
        return;
      }

      if (!new_username && !new_password) {
        errorEl.textContent = "Isi username baru dan/atau password baru";
        errorEl.classList.remove("hidden");
        btn.disabled = false; btn.textContent = "Simpan Perubahan";
        return;
      }

      try {
        const res = await fetch("/api/auth/change-credentials", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ current_password, new_username: new_username || undefined, new_password: new_password || undefined }),
        });
        const data = await res.json();
        if (res.ok) {
          toast(data.message || "Berhasil disimpan!");
          document.getElementById("admin-current-password").value = "";
          document.getElementById("admin-password").value = "";
        } else {
          errorEl.textContent = data.error || "Gagal menyimpan";
          errorEl.classList.remove("hidden");
        }
      } catch {
        errorEl.textContent = "Terjadi kesalahan jaringan";
        errorEl.classList.remove("hidden");
      }
      btn.disabled = false; btn.textContent = "Simpan Perubahan";
    });

    async function uploadFile(file) {
      const fd = new FormData(); fd.append("file", file);
      const res = await fetch("/api/upload", { method: "POST", body: fd });
      const d = await res.json();
      return d.url || null;
    }

    function updateLogoPreview() {
      const val = document.getElementById("church-logo").value.trim();
      if (val) {
        document.getElementById("logo-preview-settings").classList.remove("hidden");
        document.getElementById("logo-preview-settings-img").src = val;
      } else {
        document.getElementById("logo-preview-settings").classList.add("hidden");
      }
    }

    document.getElementById("church-logo")?.addEventListener("input", updateLogoPreview);
    document.getElementById("upload-logo-settings-btn")?.addEventListener("click", () => document.getElementById("logo-file-settings").click());
    document.getElementById("logo-file-settings")?.addEventListener("change", async (e) => {
      const file = e.target.files?.[0]; if (!file) return;
      try { const url = await uploadFile(file); if (url) { document.getElementById("church-logo").value = url; updateLogoPreview(); toast("Logo berhasil diupload"); } } catch { toast("Gagal upload logo", "error"); }
      e.target.value = "";
    });

    document.addEventListener("DOMContentLoaded", async () => {
      loadSettings();
      try {
        const res = await fetch("/api/auth/me");
        if (res.ok) {
          const data = await res.json();
          const el = document.getElementById("admin-current-username");
          if (el) el.textContent = data.admin?.username || "-";
        }
      } catch {}
    });
  </script>
</AdminLayout>
