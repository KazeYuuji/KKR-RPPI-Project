---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Pengaturan">
  <div class="space-y-8 animate-fade-in max-w-3xl">
    <!-- Location Settings -->
    <div class="glass-card p-6 sm:p-8">
      <div class="flex items-center gap-3 mb-1">
        <span class="text-xl">📍</span>
        <h2 class="text-xl font-semibold text-kkr-dark">Lokasi Tempat</h2>
      </div>
      <p class="text-sm text-kkr-maroon mt-1">Masukkan nama tempat dan link Google Maps. Peta akan otomatis ditampilkan di website.</p>
      <form id="location-form" class="mt-6 space-y-4">
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">Nama Tempat</label>
          <input id="loc-venue" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="SMK PGRI 1 Kediri" />
        </div>
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">URL Google Maps</label>
          <input id="loc-maps-link" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="https://maps.app.goo.gl/RCzwb8tiKNdVwXA59" />
          <p class="text-xs text-kkr-maroon/60 mt-1">Link Google Maps (bisa dari share/bagikan atau URL maps). Embed peta akan otomatis dibuat.</p>
        </div>
        <button type="submit" class="rounded-xl bg-kkr-red px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-kkr-maroon">Simpan Lokasi</button>
      </form>
    </div>

    <!-- Event Schedule -->
    <div class="glass-card p-6 sm:p-8">
      <div class="flex items-center gap-3 mb-1">
        <span class="text-xl">📅</span>
        <h2 class="text-xl font-semibold text-kkr-dark">Jadwal Acara</h2>
      </div>
      <p class="text-sm text-kkr-maroon mt-1">Pilih tanggal dan waktu acara. Tampilan tanggal akan dibuat otomatis.</p>
      <form id="schedule-form" class="mt-6 space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Tanggal & Jam Mulai Acara</label>
            <input id="event-date-iso" type="datetime-local" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" />
          </div>
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Jam Selesai Acara</label>
            <input id="event-time-end" type="time" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" />
          </div>
        </div>
        <div class="rounded-xl bg-kkr-light/30 p-4 text-sm text-kkr-maroon/80 space-y-1">
          <p>📌 <strong>Preview tampilan:</strong></p>
          <p id="preview-date" class="text-kkr-dark">Tanggal: —</p>
          <p id="preview-time" class="text-kkr-dark">Waktu: —</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">Batas Akhir Pendaftaran</label>
          <input id="reg-deadline-iso" type="datetime-local" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" />
          <p id="preview-deadline" class="text-xs text-kkr-maroon/60 mt-1">Tampilan: —</p>
        </div>
        <button type="submit" class="rounded-xl bg-kkr-red px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-kkr-maroon">Simpan Jadwal</button>
      </form>
    </div>

    <!-- Contact Settings -->
    <div class="glass-card p-6 sm:p-8">
      <div class="flex items-center gap-3 mb-1">
        <span class="text-xl">📞</span>
        <h2 class="text-xl font-semibold text-kkr-dark">Kontak</h2>
      </div>
      <p class="text-sm text-kkr-maroon mt-1">Informasi kontak yang ditampilkan di website.</p>
      <form id="contact-form" class="mt-6 space-y-4">
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">Email</label>
          <input id="contact-email" type="email" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="kkrrppi@gmail.com" />
        </div>
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">Telepon</label>
          <input id="contact-phone" type="tel" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="(0354) 682433" />
        </div>
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">Nomor WhatsApp (dengan kode negara)</label>
          <input id="contact-wa" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="6285800753804" />
        </div>
        <button type="submit" class="rounded-xl bg-kkr-red px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-kkr-maroon">Simpan Kontak</button>
      </form>
    </div>

    <!-- Landing Page Text -->
    <div class="glass-card p-6 sm:p-8">
      <div class="flex items-center gap-3 mb-1">
        <span class="text-xl">📝</span>
        <h2 class="text-xl font-semibold text-kkr-dark">Teks Landing Page</h2>
      </div>
      <p class="text-sm text-kkr-maroon mt-1">Sesuaikan teks yang muncul di halaman utama dan halaman pendaftaran.</p>
      <form id="text-form" class="mt-6 space-y-4">
        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Hero Heading (baris 1)</label>
            <input id="hero-heading1" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="TRUST" />
          </div>
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Hero Heading (baris 2)</label>
            <input id="hero-heading2" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="IN" />
          </div>
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Hero Heading (baris 3)</label>
            <input id="hero-heading3" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="GOD" />
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Judul Hero (baris 1)</label>
            <input id="hero-title1" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Terang dalam" />
          </div>
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Judul Hero (baris 2, warna merah)</label>
            <input id="hero-title2" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Kasih Kristus" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">Subtitle Hero (ayat + ref)</label>
          <textarea id="hero-subtitle" rows="2" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder='"Jika umat-Ku yang disebut dengan nama-Ku merendahkan diri, berdoa dan mencari wajah-Ku, maka Aku akan mendengar dari sorga." — 2 Tawarikh 7:14'></textarea>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Judul Tentang Acara</label>
            <input id="about-title" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="KKR dengan Sukacita & Syukur" />
          </div>
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Judul Formulir</label>
            <input id="form-title" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Formulir Pendaftaran" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">Deskripsi Tentang Acara (paragraf 1)</label>
          <textarea id="about-desc1" rows="3" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="KKR RPPI 2025/2026 adalah kebaktian kebangunan rohani yang mempersatukan pelajar, alumni, dan masyarakat..."></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">Deskripsi Tentang Acara (paragraf 2)</label>
          <textarea id="about-desc2" rows="3" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Bersama pembicara tamu dari Surabaya, kita akan merenungkan makna kebangunan rohani yang sesungguhnya..."></textarea>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Judul CTA</label>
            <input id="cta-title" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Daftar sekarang, dan ikuti KKR dalam kasih Kristus." />
          </div>
          <div>
            <label class="block text-sm font-medium text-kkr-purple mb-1">Subjudul Formulir</label>
            <textarea id="form-subtitle" rows="3" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Lengkapi data diri dan pilih tiket untuk bergabung dalam KKR RPPI."></textarea>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">Deskripsi CTA</label>
          <textarea id="cta-desc" rows="2" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Isi formulir pendaftaran, pilih tiket, dan amankan tempatmu dalam KKR RPPI yang penuh sukacita dan berkat."></textarea>
        </div>
        <div class="border-t border-kkr-light/30 pt-4">
          <p class="text-xs font-semibold uppercase tracking-wider text-kkr-purple mb-3">Kartu Samping About</p>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Judul Kartu 1</label>
              <input id="about-card1-title" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Pujian & Penyembahan" />
            </div>
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Judul Kartu 2</label>
              <input id="about-card2-title" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Persekutuan Lintas Sekolah" />
            </div>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 mt-4">
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Deskripsi Kartu 1</label>
              <textarea id="about-card1-desc" rows="3" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Nikmati pujian dan penyembahan..."></textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-kkr-purple mb-1">Deskripsi Kartu 2</label>
              <textarea id="about-card2-desc" rows="3" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder="Acara ini mempertemukan siswa-siswi..."></textarea>
            </div>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-kkr-purple mb-1">Kutipan About (blockquote)</label>
          <textarea id="about-blockquote" rows="2" class="w-full rounded-xl border border-kkr-light/80 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-kkr-red focus:ring-4 focus:ring-kkr-maroon/20" placeholder='"Jika umat-Ku yang disebut dengan nama-Ku merendahkan diri, berdoa dan mencari wajah-Ku, maka Aku akan mendengar dari sorga." — 2 Tawarikh 7:14'></textarea>
        </div>
        <button type="submit" class="rounded-xl bg-kkr-red px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-kkr-maroon">Simpan Teks</button>
      </form>
    </div>

    <!-- Ticket Manager -->
    <div class="glass-card p-6 sm:p-8">
      <div class="flex items-center gap-3 mb-1">
        <span class="text-xl">🎟️</span>
        <h2 class="text-xl font-semibold text-kkr-dark">Manajemen Tiket</h2>
      </div>
      <p class="text-sm text-kkr-maroon mt-1">Tambah, ubah, atau hapus tiket. Harga: GRATIS (event free).</p>
      <div class="mt-6 space-y-4" id="ticket-list"></div>
      <button id="add-ticket-btn" class="mt-4 w-full rounded-xl border-2 border-dashed border-kkr-light/80 px-4 py-3 text-sm font-semibold text-kkr-maroon/80 transition hover:border-kkr-red hover:text-kkr-red">+ Tambah Tiket Baru</button>
      <div id="ticket-toast" class="mt-3"></div>
    </div>

    <!-- Security -->
    <div class="glass-card p-6 sm:p-8">
      <h2 class="text-xl font-semibold text-kkr-dark">Keamanan</h2>
      <p class="text-sm text-kkr-maroon mt-1">Status keamanan akun admin.</p>
      <div class="mt-6 space-y-5">
        <div class="flex items-center justify-between py-3">
          <div>
            <p class="text-sm font-medium text-kkr-dark">Logout Otomatis</p>
            <p class="text-xs text-kkr-maroon/80">Sesi akan berakhir setelah 24 jam tidak aktif</p>
          </div>
          <span class="text-xs bg-emerald-100 text-emerald-700 px-2.5 py-1 rounded-full font-medium">Aktif</span>
        </div>
        <div class="flex items-center justify-between py-3 border-t border-kkr-light/30">
          <div>
            <p class="text-sm font-medium text-kkr-dark">Password Default</p>
            <p class="text-xs text-kkr-maroon/80">Ganti password default untuk keamanan lebih baik</p>
          </div>
          <span class="text-xs bg-kkr-gold/30 text-kkr-maroon px-2.5 py-1 rounded-full font-medium">admin123</span>
        </div>
      </div>
    </div>
  </div>

  <div id="toast-container" class="fixed top-4 right-4 z-[100] flex flex-col gap-2 pointer-events-none"></div>

  <script>
    function toast(msg, type = "success") {
      const c = document.getElementById("toast-container");
      const el = document.createElement("div");
      el.className = `pointer-events-auto toast-enter rounded-xl px-5 py-3 text-sm font-medium shadow-lg ${type === "success" ? "bg-emerald-600 text-white" : "bg-red-600 text-white"}`;
      el.textContent = msg;
      c.appendChild(el);
      setTimeout(() => { el.className = el.className.replace("toast-enter", "toast-exit"); setTimeout(() => el.remove(), 300); }, 3000);
    }

    async function loadSettings() {
      try {
        const res = await fetch("/api/settings");
        const d = await res.json();
        const s = d.settings || {};

        const setVal = (id, val) => { const el = document.getElementById(id); if (el) el.value = val; };
        setVal("loc-venue", s.locVenue || "");
        setVal("loc-maps-link", s.locMapsLink || "");
        setVal("event-date-iso", s.eventDateISO ? utcToLocal(s.eventDateISO) : "");
        setVal("event-time-end", s.eventTimeEnd || "");
        setVal("reg-deadline-iso", s.regDeadlineISO ? utcToLocal(s.regDeadlineISO) : "");
        setVal("contact-email", s.contactEmail || "");
        setVal("contact-phone", s.contactPhone || "");
        setVal("contact-wa", s.contactWa || "");
        setVal("form-title", s.formTitle || "");
        setVal("form-subtitle", s.formSubtitle || "");
        setVal("hero-heading1", s.heroHeading1 || "");
        setVal("hero-heading2", s.heroHeading2 || "");
        setVal("hero-heading3", s.heroHeading3 || "");
        setVal("hero-title1", s.heroTitle1 || "");
        setVal("hero-title2", s.heroTitle2 || "");
        setVal("hero-subtitle", s.heroSubtitle || "");
        setVal("about-title", s.aboutTitle || "");
        setVal("about-desc1", s.aboutDesc1 || "");
        setVal("about-desc2", s.aboutDesc2 || "");
        setVal("cta-title", s.ctaTitle || "");
        setVal("cta-desc", s.ctaDesc || "");
        setVal("about-card1-title", s.aboutCard1Title || "");
        setVal("about-card1-desc", s.aboutCard1Desc || "");
        setVal("about-card2-title", s.aboutCard2Title || "");
        setVal("about-card2-desc", s.aboutCard2Desc || "");
        setVal("about-blockquote", s.aboutBlockquote || "");
      } catch {}
    }

    async function loadTickets() {
      try {
        const res = await fetch("/api/tickets");
        const d = await res.json();
        const list = d.tickets || [];
        const container = document.getElementById("ticket-list");
        container.innerHTML = list.map(t => `
          <div class="glass-card rounded-xl p-4 ticket-item" data-id="${t.id}">
            <div class="grid gap-3 sm:grid-cols-[1fr_0.8fr_auto] items-end">
              <label class="text-xs text-kkr-maroon">Nama Tiket
                <input name="tname-${t.id}" type="text" value="${t.name}" class="mt-1 w-full rounded-lg border border-kkr-light/80 bg-white px-3 py-2 text-sm outline-none focus:border-kkr-red focus:ring-2 focus:ring-kkr-maroon/20" />
              </label>
              <label class="text-xs text-kkr-maroon">Jumlah Tersedia
                <input name="tremaining-${t.id}" type="number" min="0" value="${t.remaining}" class="mt-1 w-full rounded-lg border border-kkr-light/80 bg-white px-3 py-2 text-sm outline-none focus:border-kkr-red focus:ring-2 focus:ring-kkr-maroon/20" />
              </label>
              <button data-delete="${t.id}" class="shrink-0 rounded-lg bg-red-100 px-3 py-2 text-sm font-semibold text-red-700 transition hover:bg-red-200">Hapus</button>
            </div>
          </div>
        `).join("") + `<button id="save-all-tickets" class="mt-3 w-full rounded-xl bg-kkr-dark px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-kkr-purple">Simpan Semua Tiket</button>`;
      } catch {}
    }

    document.addEventListener("click", (e) => {
      const delBtn = e.target.closest("[data-delete]");
      if (delBtn) {
        const id = delBtn.getAttribute("data-delete");
        if (!confirm("Hapus tiket ini?")) return;
        fetch("/api/tickets", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ action: "delete", id }) })
          .then(r => r.ok ? (loadTickets(), toast("Tiket dihapus")) : toast("Gagal hapus", "error"))
          .catch(() => toast("Gagal hapus", "error"));
      }
    });

    document.addEventListener("click", (e) => {
      if (e.target.id === "save-all-tickets") {
        const items = document.querySelectorAll(".ticket-item");
        const tickets = [];
        items.forEach(el => {
          const id = el.dataset.id;
          tickets.push({
            id,
            name: el.querySelector(`[name="tname-${id}"]`).value,
            remaining: Number(el.querySelector(`[name="tremaining-${id}"]`).value) || 0,
          });
        });
        fetch("/api/tickets", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(tickets) })
          .then(r => r.ok ? (toast("Tiket tersimpan"), loadTickets()) : toast("Gagal simpan", "error"))
          .catch(() => toast("Gagal simpan", "error"));
      }
    });

    document.getElementById("add-ticket-btn")?.addEventListener("click", async () => {
      const name = prompt("Nama tiket baru:");
      if (!name || !name.trim()) return;
      try {
        const res = await fetch("/api/tickets", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ action: "create", name: name.trim(), remaining: 100 }) });
        if (res.ok) { toast("Tiket ditambahkan"); loadTickets(); }
        else toast("Gagal tambah tiket", "error");
      } catch { toast("Gagal tambah tiket", "error"); }
    });

    document.getElementById("location-form")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector("button[type=submit]");
      btn.disabled = true; btn.textContent = "Menyimpan...";
      try {
        const res = await fetch("/api/settings", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({
          locVenue: document.getElementById("loc-venue").value.trim(),
          locMapsLink: document.getElementById("loc-maps-link").value.trim(),
        })});
        if (res.ok) toast("Lokasi berhasil disimpan!");
        else throw new Error();
      } catch { toast("Gagal menyimpan lokasi", "error"); }
      btn.disabled = false; btn.textContent = "Simpan Lokasi";
    });

    function formatDateIndo(dateStr) {
      if (!dateStr) return "";
      let d;
      if (dateStr.endsWith("Z") || /[+-]\d{2}:\d{2}$/.test(dateStr)) {
        d = new Date(dateStr);
      } else {
        const [dp, tp] = dateStr.split("T");
        if (!dp) return "";
        const [y, m, dd] = dp.split("-").map(Number);
        const [h, min] = tp ? tp.split(":").map(Number) : [0, 0];
        d = new Date(y, m - 1, dd, h, min);
      }
      if (isNaN(d)) return "";
      return d.toLocaleDateString("id-ID", { weekday: "long", year: "numeric", month: "long", day: "numeric" });
    }

    function formatTimeRange(dateStr, endTime) {
      if (!dateStr) return "";
      let d;
      if (dateStr.endsWith("Z") || /[+-]\d{2}:\d{2}$/.test(dateStr)) {
        d = new Date(dateStr);
      } else {
        const [dp, tp] = dateStr.split("T");
        if (!dp) return "";
        const [y, m, dd] = dp.split("-").map(Number);
        const [h, min] = tp ? tp.split(":").map(Number) : [0, 0];
        d = new Date(y, m - 1, dd, h, min);
      }
      if (isNaN(d)) return "";
      const start = d.toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" });
      const end = endTime || "";
      return `${start}${end ? " - " + end : ""} WIB`;
    }

    function updatePreview() {
      const iso = document.getElementById("event-date-iso").value;
      const end = document.getElementById("event-time-end").value;
      document.getElementById("preview-date").textContent = "Tanggal: " + (formatDateIndo(iso) || "—");
      document.getElementById("preview-time").textContent = "Waktu: " + (iso ? formatTimeRange(iso, end) : "—");

      const deadlineIso = document.getElementById("reg-deadline-iso").value;
      document.getElementById("preview-deadline").textContent = "Tampilan: " + (formatDateIndo(deadlineIso) || "—");
    }

    document.getElementById("event-date-iso")?.addEventListener("change", updatePreview);
    document.getElementById("event-time-end")?.addEventListener("change", updatePreview);
    document.getElementById("reg-deadline-iso")?.addEventListener("change", updatePreview);

    function localToUTC(val) {
      if (!val) return "";
      return new Date(val).toISOString();
    }

    function utcToLocal(val) {
      if (!val) return "";
      const d = new Date(val);
      if (isNaN(d)) return "";
      const pad = n => String(n).padStart(2, "0");
      return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
    }

    document.getElementById("schedule-form")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector("button[type=submit]");
      btn.disabled = true; btn.textContent = "Menyimpan...";

      const eventIso = document.getElementById("event-date-iso").value;
      const timeEnd = document.getElementById("event-time-end").value;
      const deadlineIso = document.getElementById("reg-deadline-iso").value;

      try {
        const res = await fetch("/api/settings", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({
          locDate: formatDateIndo(eventIso),
          locTime: formatTimeRange(eventIso, timeEnd),
          regDeadline: formatDateIndo(deadlineIso),
          eventDateISO: localToUTC(eventIso),
          eventTimeEnd: timeEnd,
          regDeadlineISO: localToUTC(deadlineIso),
        })});
        if (res.ok) toast("Jadwal berhasil disimpan!");
        else throw new Error();
      } catch { toast("Gagal menyimpan jadwal", "error"); }
      btn.disabled = false; btn.textContent = "Simpan Jadwal";
    });

