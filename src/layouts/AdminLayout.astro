---
import Sidebar from "../components/dashboard/Sidebar.astro";
import Header from "../components/dashboard/Header.astro";
import "../styles/global.css";

export interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Admin Dashboard</title>
  </head>
  <body class="admin">
    <Sidebar currentPath={currentPath} isOpen={false} />
    <Header title={title} />

    <main id="main-content" class="lg:ml-[260px] pt-20 px-4 sm:px-8 pb-12 min-h-screen transition-all duration-300">
      <div class="mx-auto max-w-7xl">
        <slot />
      </div>
    </main>
  </body>
</html>
