---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
}

const { title, description = "KKR RPPI - Kebaktian kebangunan rohani yang mempersatukan pelajar, alumni, dan masyarakat di Kediri." } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-kkr-light text-kkr-dark antialiased">
    <div class="min-h-screen">
      <header class="sticky top-0 z-40 border-b border-kkr-light/30 bg-white/90 backdrop-blur-sm">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
          <a href="/" class="flex items-center gap-3 text-lg font-semibold tracking-tight text-kkr-dark">
            <img src="/logo-header.png" alt="KKR RPPI logo" class="h-10 w-10 object-contain rounded-full" />
            <span>KKR <span class="text-kkr-red">RPPI</span></span>
          </a>

          <nav class="hidden items-center gap-7 text-sm font-semibold text-kkr-maroon md:flex">
            <a href="/#home" class="transition hover:text-kkr-red">Beranda</a>
            <a href="/#about" class="transition hover:text-kkr-red">Info</a>
            <a href="/#speakers" class="transition hover:text-kkr-red">Pembicara</a>
            <a href="/#sponsors" class="transition hover:text-kkr-red">Sponsor</a>
            <a href="/#location" class="transition hover:text-kkr-red">Lokasi</a>
          </nav>

          <div class="flex items-center gap-3">
            <a href="/registration" class="hidden sm:inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-kkr-gold to-kkr-gold px-5 py-2.5 text-sm font-semibold text-kkr-dark shadow-lg shadow-kkr-gold/30 transition hover:shadow-xl hover:shadow-kkr-gold/40 hover:-translate-y-0.5">
              Daftar
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <button id="mobile-menu-btn" class="md:hidden p-2 rounded-xl hover:bg-kkr-light/40 text-kkr-maroon transition-colors" aria-label="Menu navigasi">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </button>
          </div>
        </div>

        <div id="mobile-menu" class="md:hidden hidden border-t border-kkr-light/50 bg-white px-6 py-5 space-y-2">
          {["Beranda", "Info", "Pembicara", "Sponsor", "Lokasi"].map((label, i) => {
            const hrefs = ["#home", "#about", "#speakers", "#sponsors", "#location"];
            return (
              <a href={hrefs[i]} class="block px-4 py-2.5 rounded-xl text-sm font-semibold text-kkr-purple hover:bg-kkr-light hover:text-kkr-red transition-colors">{label}</a>
            );
          })}
          <a href="/registration" class="block px-4 py-2.5 rounded-xl text-sm font-semibold text-white bg-kkr-red text-center mt-3">Daftar Sekarang</a>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer class="border-t border-kkr-light/50 bg-white px-6 py-10 text-kkr-maroon">
        <div class="mx-auto max-w-7xl">
          <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            <div>
              <a href="/" class="flex items-center gap-3 text-lg font-semibold tracking-tight text-kkr-dark">
                <img src="/logo-header.png" alt="KKR RPPI logo" class="h-10 w-10 object-contain rounded-full" />
                <span>KKR <span class="text-kkr-red">RPPI</span></span>
              </a>
              <p class="mt-3 text-sm leading-relaxed max-w-xs">"Jika umat-Ku yang disebut dengan nama-Ku merendahkan diri, berdoa dan mencari wajah-Ku, maka Aku akan mendengar dari sorga." — 2 Tawarikh 7:14. Mengalami kebangunan rohani dalam Yesus Kristus.</p>
              <p class="mt-4 text-xs text-kkr-maroon/60">Panitia KKR RPPI Kediri 2025/2026</p>
            </div>
            <div>
              <p class="font-semibold text-kkr-dark text-sm mb-4 uppercase tracking-wider">Menu</p>
              <div class="space-y-2.5 text-sm">
                <a href="/#home" class="block hover:text-kkr-red transition-colors">Beranda</a>
                <a href="/#about" class="block hover:text-kkr-red transition-colors">Info Acara</a>
                <a href="/#speakers" class="block hover:text-kkr-red transition-colors">Pembicara</a>
                <a href="/#location" class="block hover:text-kkr-red transition-colors">Lokasi</a>
                <a href="/registration" class="block hover:text-kkr-red transition-colors">Daftar</a>
              </div>
            </div>
            <div>
              <p class="font-semibold text-kkr-dark text-sm mb-4 uppercase tracking-wider">Kontak</p>
              <div class="space-y-2.5 text-sm" id="footer-contact">
                <p class="text-kkr-maroon/60">Memuat...</p>
              </div>
            </div>
          </div>
          <div class="mt-10 pt-6 border-t border-kkr-light/30 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-xs text-kkr-maroon/60">© 2025/2026 SMK PGRI 1 Kediri. All rights reserved.</p>
            <p class="text-xs text-kkr-maroon/60">Developed with ❤️</p>
          </div>
        </div>
      </footer>
    </div>

    <script>
      const menuBtn = document.getElementById("mobile-menu-btn");
      const mobileMenu = document.getElementById("mobile-menu");
      menuBtn?.addEventListener("click", () => {
        mobileMenu?.classList.toggle("hidden");
        const isOpen = !mobileMenu?.classList.contains("hidden");
        menuBtn.innerHTML = isOpen
          ? `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`
          : `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>`;
      });
      mobileMenu?.querySelectorAll("a").forEach(a => {
        a.addEventListener("click", () => {
          mobileMenu.classList.add("hidden");
          menuBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>`;
        });
      });

      async function loadContact() {
        try {
          const res = await fetch("/api/settings");
          const d = await res.json();
          const s = d.settings || {};
          const el = document.getElementById("footer-contact");
          const email = s.contactEmail || "kkrrppi@gmail.com";
          const phone = s.contactPhone || "";
          const wa = s.contactWa || "6285800753804";
          el.innerHTML = `
            <a href="mailto:${email}" class="block hover:text-kkr-red transition-colors">${email}</a>
            ${phone ? `<a href="tel:${phone}" class="block hover:text-kkr-red transition-colors">${phone}</a>` : ""}
            <a href="https://wa.me/${wa}" target="_blank" class="block hover:text-kkr-red transition-colors">WhatsApp</a>
          `;
        } catch {}
      }
      loadContact();
    </script>
  </body>
</html>
