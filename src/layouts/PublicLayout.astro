---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
}

const { title, description = "KKR RPPI - Kebaktian kebangunan rohani yang mempersatukan pelajar, alumni, dan masyarakat di Kediri." } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="min-h-screen">
      <header id="site-header" class="sticky top-0 z-40 border-b border-white/10 bg-kkr-dark/90 backdrop-blur-xl shadow-lg shadow-black/20 transition-all duration-300">
        <div id="header-inner" class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 transition-all duration-300">
          <a href="/" class="flex items-center gap-3 text-lg font-semibold tracking-tight text-white">
            <img id="header-logo" src="/logo-header.png" alt="KKR RPPI logo" class="h-10 w-10 object-contain rounded-full transition-all duration-300" />
            <span class="transition-all duration-300">KKR <span class="text-kkr-gold">RPPI</span></span>
          </a>

          <nav class="hidden items-center gap-8 text-sm font-semibold text-white/80 md:flex">
            <a href="/#home" class="nav-link nav-link-white transition-all duration-200 hover:text-kkr-gold">Beranda</a>
            <a href="/#about" class="nav-link nav-link-white transition-all duration-200 hover:text-kkr-gold">Info</a>
            <a href="/#speakers" class="nav-link nav-link-white transition-all duration-200 hover:text-kkr-gold">Pembicara</a>
            <a href="/#altar" class="nav-link nav-link-white transition-all duration-200 hover:text-kkr-gold">Pelayan Altar</a>
            <a href="/#sponsors" class="nav-link nav-link-white transition-all duration-200 hover:text-kkr-gold">Sponsor</a>
            <a href="/#location" class="nav-link nav-link-white transition-all duration-200 hover:text-kkr-gold">Lokasi</a>
          </nav>

          <div class="flex items-center gap-3">
            <a href="/registration" class="hidden sm:inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-kkr-gold to-kkr-gold px-5 py-2.5 text-sm font-semibold text-kkr-dark shadow-lg shadow-kkr-gold/30 transition-all duration-300 hover:shadow-xl hover:shadow-kkr-gold/40 hover:-translate-y-0.5 active:scale-[0.97] btn-ripple">
              Daftar
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <button id="mobile-menu-btn" class="md:hidden p-2 rounded-xl hover:bg-white/10 text-white/70 transition-colors" aria-label="Menu navigasi">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </button>
          </div>
        </div>

        <div id="mobile-menu" class="md:hidden overflow-hidden border-t border-white/10 bg-kkr-dark/95 px-6 space-y-2" style="max-height: 0; opacity: 0; transition: max-height 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease, padding 0.3s ease;">
          {["Beranda", "Info", "Pembicara", "Pelayan Altar", "Sponsor", "Lokasi"].map((label, i) => {
            const hrefs = ["#home", "#about", "#speakers", "#altar", "#sponsors", "#location"];
            return (
              <a href={hrefs[i]} class="block px-4 py-2.5 rounded-xl text-sm font-semibold text-white/80 hover:bg-white/10 hover:text-kkr-gold transition-all duration-200 hover:translate-x-1" style={`transition-delay: ${i * 40}ms`}>{label}</a>
            );
          })}
          <a href="/registration" class="block px-4 py-2.5 rounded-xl text-sm font-semibold text-kkr-dark bg-gradient-to-r from-kkr-gold to-kkr-gold text-center mt-3 transition-all duration-200 hover:scale-[1.02] active:scale-[0.98]">Daftar Sekarang</a>
        </div>
      </header>

      <main id="main-content" class="page-enter">
        <slot />
      </main>

      <footer class="border-t border-white/10 bg-kkr-dark/80 backdrop-blur-lg px-6 py-4">
        <div class="mx-auto max-w-7xl flex flex-col sm:flex-row items-center justify-between gap-2">
          <div class="flex items-center gap-3 text-sm">
            <a href="/" class="flex items-center gap-2 font-semibold text-white">
              <img src="/logo-header.png" alt="KKR RPPI logo" class="h-7 w-7 object-contain rounded-full" />
              KKR <span class="text-kkr-gold">RPPI</span>
            </a>
            <span class="text-white/30 hidden sm:inline">|</span>
            <span class="text-xs text-white/50 hidden sm:inline">Panitia KKR RPPI Kediri 2025/2026</span>
          </div>
          <div class="flex items-center gap-4 text-xs text-white/60" id="footer-contact">
            <span>Memuat...</span>
            <span class="text-white/20 hidden sm:inline">|</span>
            <a href="/registration" class="hover:text-kkr-gold transition-colors">Daftar</a>
          </div>
        </div>
      </footer>
    </div>

    <!-- Progress Bar -->
    <div id="progress-bar"></div>

    <!-- Custom Cursor -->
    <div id="cursor-ring"></div>
    <div id="cursor-dot"></div>

    <!-- Mouse Follower -->
    <div id="mouse-follower" style="opacity: 0;"></div>

    <script>
      const header = document.getElementById("site-header");
      const headerInner = document.getElementById("header-inner");
      const headerLogo = document.getElementById("header-logo");
      const menuBtn = document.getElementById("mobile-menu-btn");
      const mobileMenu = document.getElementById("mobile-menu");

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      let lastScroll = 0;
      window.addEventListener("scroll", () => {
        const curr = window.scrollY;
        if (curr > 80) {
          header?.classList.add("shadow-2xl");
          header?.classList.remove("shadow-lg");
          headerInner?.classList.add("py-2");
          headerInner?.classList.remove("py-4");
          if (headerLogo) headerLogo.style.transform = "scale(0.85)";
        } else {
          header?.classList.remove("shadow-2xl");
          header?.classList.add("shadow-lg");
          headerInner?.classList.remove("py-2");
          headerInner?.classList.add("py-4");
          if (headerLogo) headerLogo.style.transform = "scale(1)";
        }
        if (curr > 400) {
          header?.classList.add("bg-kkr-dark/95");
        } else {
          header?.classList.remove("bg-kkr-dark/95");
        }
        lastScroll = curr;
      }, { passive: true });

      menuBtn?.addEventListener("click", () => {
        const isOpen = mobileMenu?.style.maxHeight !== "0px" && mobileMenu?.style.maxHeight !== "";
        if (isOpen) {
          mobileMenu.style.maxHeight = "0";
          mobileMenu.style.opacity = "0";
          mobileMenu.style.paddingTop = "0";
          mobileMenu.style.paddingBottom = "0";
          menuBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>`;
        } else {
          const fullHeight = mobileMenu.scrollHeight;
          mobileMenu.style.maxHeight = fullHeight + "px";
          mobileMenu.style.opacity = "1";
          mobileMenu.style.paddingTop = "1.25rem";
          mobileMenu.style.paddingBottom = "1.25rem";
          menuBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`;
        }
      });

      mobileMenu?.querySelectorAll("a").forEach(a => {
        a.addEventListener("click", () => {
          mobileMenu.style.maxHeight = "0";
          mobileMenu.style.opacity = "0";
          mobileMenu.style.paddingTop = "0";
          mobileMenu.style.paddingBottom = "0";
          menuBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>`;
        });
      });

      async function loadContact() {
        try {
          const res = await fetch("/api/settings");
          const d = await res.json();
          const s = d.settings || {};
          const el = document.getElementById("footer-contact");
          const email = s.contactEmail || "kkrrppi@gmail.com";
          const phone = s.contactPhone || "";
          const wa = s.contactWa || "6285800753804";
          el.innerHTML = `
            <a href="mailto:${email}" class="hover:text-kkr-gold transition-colors">Email</a>
            <span class="text-white/20">|</span>
            <a href="https://wa.me/${wa}" target="_blank" class="hover:text-kkr-gold transition-colors">WhatsApp</a>
            ${phone ? `<span class="text-white/20">|</span><a href="tel:${phone}" class="hover:text-kkr-gold transition-colors">Telp</a>` : ""}
            <span class="text-white/20 hidden sm:inline">|</span>
            <a href="/registration" class="hover:text-kkr-gold transition-colors">Daftar</a>
          `;
        } catch {}
      }
      loadContact();

      /* ══════════════════════════════════════════
         Progress Bar
         ══════════════════════════════════════════ */
      function initProgressBar() {
        if (reduceMotion) return;
        const bar = document.getElementById("progress-bar");
        if (!bar) return;
        window.addEventListener("scroll", () => {
          const h = document.documentElement.scrollHeight - window.innerHeight;
          const pct = window.scrollY / h;
          bar.style.transform = `scaleX(${Math.min(pct, 1)})`;
        }, { passive: true });
      }

      /* ══════════════════════════════════════════
         Custom Cursor
         ══════════════════════════════════════════ */
      function initCustomCursor() {
        if (reduceMotion) return;
        const ring = document.getElementById("cursor-ring");
        const dot = document.getElementById("cursor-dot");
        if (!ring || !dot) return;

        document.body.style.cursor = "none";

        let mx = -100, my = -100;
        let rx = -100, ry = -100;
        let dx = -100, dy = -100;

        function tick() {
          rx += (mx - rx) * 0.12;
          ry += (my - ry) * 0.12;
          dx += (mx - dx) * 0.25;
          dy += (my - dy) * 0.25;
          ring.style.left = rx + "px";
          ring.style.top = ry + "px";
          dot.style.left = dx + "px";
          dot.style.top = dy + "px";
          raf = requestAnimationFrame(tick);
        }
        let raf = requestAnimationFrame(tick);

        document.addEventListener("mousemove", (e) => { mx = e.clientX; my = e.clientY; }, { passive: true });
        document.addEventListener("mouseleave", () => { mx = -200; my = -200; }, { passive: true });
        document.addEventListener("touchstart", () => { ring.style.display = "none"; dot.style.display = "none"; document.body.style.cursor = ""; }, { passive: true });

        // Hover effect for interactive elements
        document.querySelectorAll("a, button, .tilt-card, .magnetic-btn, .sponsor-card").forEach((el) => {
          el.addEventListener("mouseenter", () => { ring.classList.add("hovering"); dot.classList.add("hovering"); });
          el.addEventListener("mouseleave", () => { ring.classList.remove("hovering"); dot.classList.remove("hovering"); });
        });
      }

      /* ══════════════════════════════════════════
         Click Ripple Global
         ══════════════════════════════════════════ */
      function initClickRipple() {
        if (reduceMotion) return;
        document.addEventListener("click", (e) => {
          const el = document.createElement("span");
          el.className = "ripple-el";
          const size = 60;
          el.style.width = el.style.height = size + "px";
          el.style.left = (e.clientX - size / 2) + "px";
          el.style.top = (e.clientY - size / 2) + "px";
          el.style.position = "fixed";
          el.style.pointerEvents = "none";
          el.style.zIndex = "99999";
          document.body.appendChild(el);
          el.addEventListener("animationend", () => el.remove());
        }, { passive: true });
      }

      /* ══════════════════════════════════════════
         ScrollTrigger Parallax
         ══════════════════════════════════════════ */
      function initParallax() {
        const els = document.querySelectorAll(".parallax-slow, .parallax-medium, .parallax-fast");
        if (!els.length || reduceMotion) return;
        const speeds = { slow: 0.15, medium: 0.3, fast: 0.5 };
        const rects = new Map();
        function update() {
          const sy = window.scrollY;
          els.forEach((el) => {
            if (!rects.has(el)) rects.set(el, el.getBoundingClientRect().top + sy);
            const base = rects.get(el);
            const key = el.classList.contains("parallax-slow") ? "slow" : el.classList.contains("parallax-medium") ? "medium" : "fast";
            const offset = (sy - base + window.innerHeight / 2) * (speeds[key] || 0.15);
            el.style.transform = `translateY(${Math.round(offset)}px)`;
          });
          raf = requestAnimationFrame(update);
        }
        let raf = requestAnimationFrame(update);
        window.addEventListener("resize", () => rects.clear(), { passive: true });
      }

      /* ══════════════════════════════════════════
         Mouse Follower Glow
         ══════════════════════════════════════════ */
      function initMouseFollower() {
        const el = document.getElementById("mouse-follower");
        if (!el || reduceMotion) return;
        el.style.opacity = "1";
        let mx = -200, my = -200;
        let cx = -200, cy = -200;
        function tick() {
          cx += (mx - cx) * 0.08;
          cy += (my - cy) * 0.08;
          el.style.left = cx + "px";
          el.style.top = cy + "px";
          raf2 = requestAnimationFrame(tick);
        }
        let raf2 = requestAnimationFrame(tick);
        document.addEventListener("mousemove", (e) => { mx = e.clientX; my = e.clientY; }, { passive: true });
        document.addEventListener("mouseleave", () => { mx = -200; my = -200; }, { passive: true });
        document.addEventListener("touchstart", () => { el.style.opacity = "0"; }, { passive: true });
      }

      /* ══════════════════════════════════════════
         Card Tilt 3D
         ══════════════════════════════════════════ */
      function initCardTilt() {
        if (reduceMotion) return;
        document.querySelectorAll(".tilt-card").forEach((card) => {
          card.addEventListener("mousemove", (e) => {
            const r = card.getBoundingClientRect();
            const x = (e.clientX - r.left) / r.width - 0.5;
            const y = (e.clientY - r.top) / r.height - 0.5;
            card.style.transform = `perspective(600px) rotateY(${x * 10}deg) rotateX(${-y * 10}deg) translateZ(20px)`;
          });
          card.addEventListener("mouseleave", () => {
            card.style.transform = "perspective(600px) rotateY(0deg) rotateX(0deg) translateZ(0)";
          });
        });
      }

      /* ══════════════════════════════════════════
         Magnetic Buttons
         ══════════════════════════════════════════ */
      function initMagneticButtons() {
        if (reduceMotion) return;
        document.querySelectorAll(".magnetic-btn").forEach((btn) => {
          btn.addEventListener("mousemove", (e) => {
            const r = btn.getBoundingClientRect();
            const x = (e.clientX - r.left - r.width / 2) * 0.3;
            const y = (e.clientY - r.top - r.height / 2) * 0.3;
            btn.style.transform = `translate(${x}px, ${y}px)`;
          });
          btn.addEventListener("mouseleave", () => { btn.style.transform = "translate(0, 0)"; });
        });
      }

      /* ══════════════════════════════════════════
         Text Split Reveal (Hero Heading)
         ══════════════════════════════════════════ */
      function initTextSplit() {
        if (reduceMotion) return;
        const headings = document.querySelectorAll("[data-split]");
        headings.forEach((h) => {
          const text = h.textContent;
          if (!text) return;
          h.innerHTML = "";
          h.style.opacity = "1";
          Array.from(text).forEach((char, i) => {
            if (char === " ") { h.innerHTML += " "; return; }
            const span = document.createElement("span");
            span.className = "char-reveal";
            span.style.animationDelay = (i * 40) + "ms";
            span.textContent = char;
            h.appendChild(span);
          });
        });
      }

      /* ══════════════════════════════════════════
         Counter Animation
         ══════════════════════════════════════════ */
      function initCounters() {
        const els = document.querySelectorAll("[data-count-to]");
        if (!els.length) return;
        if ("IntersectionObserver" in window) {
          const obs = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const el = entry.target;
                const target = parseInt(el.dataset.countTo) || 0;
                const duration = parseInt(el.dataset.countDuration) || 2000;
                const suffix = el.dataset.countSuffix || "";
                const start = performance.now();
                function step(now) {
                  const pct = Math.min((now - start) / duration, 1);
                  const eased = 1 - Math.pow(1 - pct, 3);
                  el.textContent = Math.floor(eased * target).toLocaleString() + suffix;
                  if (pct < 1) requestAnimationFrame(step);
                }
                requestAnimationFrame(step);
                obs.unobserve(el);
              }
            });
          }, { threshold: 0.5 });
          els.forEach((el) => obs.observe(el));
        }
      }

      /* ══════════════════════════════════════════
         Lazy Image Skeleton
         ══════════════════════════════════════════ */
      function initLazyImages() {
        if (!("IntersectionObserver" in window)) return;
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const wrap = entry.target;
              const img = wrap.querySelector("img");
              if (img && !img.classList.contains("loaded")) {
                img.addEventListener("load", () => { img.classList.add("loaded"); wrap.classList.add("loaded"); }, { once: true });
                if (img.complete) { img.classList.add("loaded"); wrap.classList.add("loaded"); }
              }
              observer.unobserve(wrap);
            }
          });
        }, { rootMargin: "200px" });
        document.querySelectorAll(".img-skeleton").forEach((el) => observer.observe(el));
      }

      initProgressBar();
      initCustomCursor();
      initClickRipple();
      initParallax();
      initMouseFollower();
      initCardTilt();
      initMagneticButtons();
      initTextSplit();
      initCounters();
      initLazyImages();
    </script>
  </body>
</html>
