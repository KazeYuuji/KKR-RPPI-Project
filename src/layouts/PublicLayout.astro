---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "KKR RPPI - Kebaktian kebangunan rohani yang mempersatukan pelajar, alumni, dan masyarakat di Kediri.", image = "/logo.png" } = Astro.props;

const siteUrl = "https://kkrrppi.vercel.app";
const pageTitle = title;
const pageDesc = description;
const pageImage = new URL(image, siteUrl).href;
const canonical = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <meta name="robots" content="index, follow" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo-header-small.png" />
    <link rel="apple-touch-icon" href="/logo-header.png" />

    <!-- Preload hero assets -->
    <link rel="preload" as="image" href="/logo.png" />
    <link rel="preload" as="image" href="/logo-header-small.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:image" content={pageImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="KKR RPPI" />
    <meta property="og:locale" content="id_ID" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={pageImage} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" id="ld-json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Event",
        "name": "KKR RPPI 2026",
        "description": pageDesc,
        "image": pageImage,
        "url": siteUrl,
        "startDate": "2026-01-10T08:00:00+07:00",
        "endDate": "2026-01-10T12:30:00+07:00",
        "eventStatus": "https://schema.org/EventScheduled",
        "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
        "location": {
          "@type": "Place",
          "name": "Kediri",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Jl. Himalaya No.06",
            "addressLocality": "Kediri",
            "addressCountry": "ID"
          }
        },
        "organizer": {
          "@type": "Organization",
          "name": "KKR RPPI",
          "email": "kkrrppi@gmail.com"
        }
      })}
    </script>
    <script type="module">
      if (!window.__SETTINGS_CACHE) {
        window.__SETTINGS_CACHE = fetch("/api/settings").then(r => r.json()).then(d => d.settings || {}).catch(() => ({}));
      }
      window.__SETTINGS_CACHE.then(s => {
        const el = document.getElementById("ld-json");
        if (!el) return;
        try {
          const ld = JSON.parse(el.textContent);
          if (s.locVenue) ld.location.name = s.locVenue;
          if (s.locAddress) ld.location.address.streetAddress = s.locAddress;
          if (s.locVenue) { const parts = s.locVenue.split(","); ld.location.address.addressLocality = (parts[parts.length - 1] || s.locVenue).trim(); }
          if (s.eventName) ld.name = s.eventName;
          if (s.contactEmail) ld.organizer.email = s.contactEmail;
          if (s.contactWa && ld.organizer) ld.organizer.telephone = "+" + s.contactWa.replace(/[^0-9]/g, "");
          if (s.eventDateISO) ld.startDate = s.eventDateISO;
          if (s.eventDateISO && s.eventTimeEnd) {
            const start = new Date(s.eventDateISO);
            const [endH, endM] = s.eventTimeEnd.split(":").map(Number);
            if (!isNaN(start.getTime()) && !isNaN(endH)) {
              const startWIB = new Date(start.getTime() + 7 * 3600000);
              const startH = startWIB.getUTCHours();
              const startM = startWIB.getUTCMinutes();
              let durMin = (endH - startH) * 60 + (endM - startM);
              if (durMin < 0) durMin += 1440;
              const end = new Date(start.getTime() + durMin * 60000);
              if (!isNaN(end.getTime())) ld.endDate = end.toISOString();
            }
          }
          el.textContent = JSON.stringify(ld);
        } catch {}
      });
    </script>

    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="min-h-screen">
      <header class="sticky top-0 z-40 border-b border-white/10 bg-kkr-dark/95 shadow-lg shadow-black/20">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
          <a href="/" class="flex items-center gap-3 text-lg font-semibold tracking-tight text-white">
            <img src="/logo-header-small.png" alt="KKR RPPI logo" class="h-10 w-10 object-contain rounded-full" loading="lazy" decoding="async" />
            <span>KKR <span class="text-kkr-gold">RPPI</span></span>
          </a>

          <nav class="hidden items-center gap-7 text-sm font-semibold text-white/90 md:flex">
            <a href="/#home" class="transition hover:text-kkr-gold">Beranda</a>
            <a href="/#about" class="transition hover:text-kkr-gold">Info</a>
            <a href="/#speakers" class="transition hover:text-kkr-gold">Pembicara</a>
            <a href="/#altar" class="transition hover:text-kkr-gold">Pelayan Altar</a>
            <a href="/#sponsors" class="transition hover:text-kkr-gold">Sponsor</a>
            <a href="/#location" class="transition hover:text-kkr-gold">Lokasi</a>
          </nav>

          <div class="flex items-center gap-3">
            <a href="/registration" class="hidden sm:inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-kkr-gold to-kkr-gold px-5 py-2.5 text-sm font-semibold text-kkr-dark shadow-lg shadow-kkr-gold/30 transition hover:shadow-xl hover:shadow-kkr-gold/40 hover:-translate-y-0.5">
              Daftar
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <button id="mobile-menu-btn" class="md:hidden p-2 rounded-xl hover:bg-white/10 text-white/70 transition-colors" aria-label="Menu navigasi">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </button>
          </div>
        </div>

        <div id="mobile-menu" class="md:hidden hidden border-t border-white/10 bg-kkr-dark/95 px-6 py-5 space-y-2">
          {["Beranda", "Info", "Pembicara", "Pelayan Altar", "Sponsor", "Lokasi"].map((label, i) => {
            const hrefs = ["#home", "#about", "#speakers", "#altar", "#sponsors", "#location"];
            return (
              <a href={hrefs[i]} class="block px-4 py-2.5 rounded-xl text-sm font-semibold text-white/90 hover:bg-white/10 hover:text-kkr-gold transition-colors">{label}</a>
            );
          })}
          <a href="/registration" class="block px-4 py-2.5 rounded-xl text-sm font-semibold text-kkr-dark bg-gradient-to-r from-kkr-gold to-kkr-gold text-center mt-3">Daftar Sekarang</a>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer class="border-t border-white/10 bg-kkr-dark/90 px-6 py-4">
        <div class="mx-auto max-w-7xl flex flex-col sm:flex-row items-center justify-between gap-2">
          <div class="flex items-center gap-3 text-sm">
            <a href="/" class="flex items-center gap-2 font-semibold text-white">
              <img src="/logo-header-small.png" alt="KKR RPPI logo" class="h-7 w-7 object-contain rounded-full" />
              KKR <span class="text-kkr-gold">RPPI</span>
            </a>
            <span class="text-white/30 hidden sm:inline">|</span>
            <span class="text-xs text-white/50 hidden sm:inline" id="footer-credit">Panitia KKR RPPI</span>
          </div>
          <div class="flex items-center gap-4 text-xs text-white/60" id="footer-contact">
            <span>Memuat...</span>
          </div>
        </div>
        <div class="mx-auto max-w-7xl mt-3 pt-3 border-t border-white/5 flex flex-wrap items-center justify-center gap-x-6 gap-y-1 text-xs text-white/50">
          <a href="/privacy" class="hover:text-kkr-gold transition-colors">Kebijakan Privasi</a>
          <a href="/terms" class="hover:text-kkr-gold transition-colors">Syarat & Ketentuan</a>
          <span id="footer-copy">&copy; 2026 KKR RPPI. Hak cipta dilindungi.</span>
        </div>
      </footer>
    </div>

    <!-- Back to Top -->
    <button id="back-to-top" class="fixed bottom-6 left-6 z-50 w-12 h-12 rounded-full bg-gradient-to-r from-kkr-red to-kkr-gold text-white shadow-lg shadow-kkr-maroon/30 flex items-center justify-center opacity-0 translate-y-4 transition-all duration-300 hover:scale-105 active:scale-95" aria-label="Kembali ke atas">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15"/></svg>
    </button>

    <script type="module">
      const menuBtn = document.getElementById("mobile-menu-btn");
      const mobileMenu = document.getElementById("mobile-menu");
      menuBtn?.addEventListener("click", () => {
        mobileMenu?.classList.toggle("hidden");
        const isOpen = !mobileMenu?.classList.contains("hidden");
        menuBtn.innerHTML = isOpen
          ? `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`
          : `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>`;
      });
      mobileMenu?.querySelectorAll("a").forEach(a => {
        a.addEventListener("click", () => {
          mobileMenu?.classList.add("hidden");
          if (menuBtn) menuBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>`;
        });
      });

      const backToTop = document.getElementById("back-to-top");
      let scrollVis = false;
      if (backToTop) {
        window.addEventListener("scroll", () => {
          const show = window.scrollY >= 400;
          if (show !== scrollVis) {
            scrollVis = show;
            backToTop.classList.toggle("opacity-0", !show);
            backToTop.classList.toggle("translate-y-4", !show);
            backToTop.classList.toggle("opacity-100", show);
            backToTop.classList.toggle("translate-y-0", show);
          }
        }, { passive: true });
        backToTop.addEventListener("click", () => { window.scrollTo({ top: 0, behavior: "smooth" }); });
      }

      function esc(s) { if (!s) return ""; return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;"); }

      async function loadContact() {
        try {
          const s = await (window.__SETTINGS_CACHE || fetch("/api/settings").then(r => r.json()).then(d => d.settings || {}));
          const el = document.getElementById("footer-contact");
          const credit = document.getElementById("footer-credit");
          const email = s.contactEmail || "kkrrppi@gmail.com";
          const phone = s.contactPhone || "";
          const wa = s.contactWa || "6285800753804";
          const venue = s.locVenue || "";
          const evName = s.eventName || "KKR RPPI";
          if (credit) credit.textContent = "Panitia " + esc(evName) + (venue ? " " + esc(venue.split(",")[0].trim()) : "");
          const copyEl = document.getElementById("footer-copy");
          if (copyEl) copyEl.textContent = "\u00a9 " + new Date().getFullYear() + " " + esc(evName) + ". Hak cipta dilindungi.";
          let html = `<a href="mailto:${encodeURI(email)}" class="hover:text-kkr-gold transition-colors">Email</a>`;
          html += `<span class="text-white/20">|</span><a href="https://wa.me/${wa.replace(/[^0-9]/g, "")}" target="_blank" class="hover:text-kkr-gold transition-colors">WhatsApp</a>`;
          if (phone) {
            html += `<span class="text-white/20">|</span><a href="tel:${phone.replace(/[^0-9+]/g, "")}" class="hover:text-kkr-gold transition-colors">Telp</a>`;
          }
          el.innerHTML = html;
        } catch {}
      }
      loadContact();
    </script>
  </body>
</html>
