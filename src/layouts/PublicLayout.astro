---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "KKR RPPI - Kebaktian kebangunan rohani yang mempersatukan pelajar, alumni, dan masyarakat di Kediri.", image = "/logo.png" } = Astro.props;

const siteUrl = "https://kkrrppi.vercel.app";
const pageTitle = title;
const pageDesc = description;
const pageImage = new URL(image, siteUrl).href;
const canonical = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <meta name="robots" content="index, follow" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo-header.png" />
    <link rel="apple-touch-icon" href="/logo-header.png" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />

    <!-- Preload hero assets -->
    <link rel="preload" as="image" href="/logo.png" />
    <link rel="preload" as="fetch" href="/api/settings" crossorigin />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:image" content={pageImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="KKR RPPI" />
    <meta property="og:locale" content="id_ID" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={pageImage} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" id="ld-json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Event",
        "name": "KKR RPPI 2026",
        "description": pageDesc,
        "image": pageImage,
        "url": siteUrl,
        "startDate": "2026-01-10T08:00:00+07:00",
        "endDate": "2026-01-10T12:30:00+07:00",
        "eventStatus": "https://schema.org/EventScheduled",
        "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
        "location": {
          "@type": "Place",
          "name": "SMK PGRI 1 Kediri",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Jl. Himalaya No.06",
            "addressLocality": "Kediri",
            "addressCountry": "ID"
          }
        },
        "organizer": {
          "@type": "Organization",
          "name": "KKR RPPI",
          "email": "kkrrppi@gmail.com"
        }
      })}
    </script>
    <script>fetch("/api/settings").then(r=>r.json()).then(d=>{const s=d.settings||{};const el=document.getElementById("ld-json");if(!el)return;try{const ld=JSON.parse(el.textContent);if(s.locVenue)ld.location.name=s.locVenue;if(s.contactEmail)ld.organizer.email=s.contactEmail;if(s.eventDateISO)ld.startDate=s.eventDateISO;if(s.eventDateISO&&s.eventTimeEnd){const endH=parseInt(s.eventTimeEnd);ld.endDate=s.eventDateISO.replace(/\d{2}:\d{2}/,s.eventTimeEnd)}el.textContent=JSON.stringify(ld)}catch{}}).catch(()=>{});</script>

    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="min-h-screen">
      <header class="sticky top-0 z-40 border-b border-white/10 bg-kkr-dark/85 backdrop-blur-xl shadow-lg shadow-black/20">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
          <a href="/" class="flex items-center gap-3 text-lg font-semibold tracking-tight text-white">
            <img src="/logo-header.png" alt="KKR RPPI logo" class="h-10 w-10 object-contain rounded-full" />
            <span>KKR <span class="text-kkr-gold">RPPI</span></span>
          </a>

          <nav class="hidden items-center gap-7 text-sm font-semibold text-white/80 md:flex">
            <a href="/#home" class="transition hover:text-kkr-gold">Beranda</a>
            <a href="/#about" class="transition hover:text-kkr-gold">Info</a>
            <a href="/#speakers" class="transition hover:text-kkr-gold">Pembicara</a>
            <a href="/#altar" class="transition hover:text-kkr-gold">Pelayan Altar</a>
            <a href="/#sponsors" class="transition hover:text-kkr-gold">Sponsor</a>
            <a href="/#location" class="transition hover:text-kkr-gold">Lokasi</a>
          </nav>

          <div class="flex items-center gap-3">
            <a href="/registration" class="hidden sm:inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-kkr-gold to-kkr-gold px-5 py-2.5 text-sm font-semibold text-kkr-dark shadow-lg shadow-kkr-gold/30 transition hover:shadow-xl hover:shadow-kkr-gold/40 hover:-translate-y-0.5">
              Daftar
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <button id="mobile-menu-btn" class="md:hidden p-2 rounded-xl hover:bg-white/10 text-white/70 transition-colors" aria-label="Menu navigasi">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </button>
          </div>
        </div>

        <div id="mobile-menu" class="md:hidden hidden border-t border-white/10 bg-kkr-dark/95 px-6 py-5 space-y-2">
          {["Beranda", "Info", "Pembicara", "Pelayan Altar", "Sponsor", "Lokasi"].map((label, i) => {
            const hrefs = ["#home", "#about", "#speakers", "#altar", "#sponsors", "#location"];
            return (
              <a href={hrefs[i]} class="block px-4 py-2.5 rounded-xl text-sm font-semibold text-white/80 hover:bg-white/10 hover:text-kkr-gold transition-colors">{label}</a>
            );
          })}
          <a href="/registration" class="block px-4 py-2.5 rounded-xl text-sm font-semibold text-kkr-dark bg-gradient-to-r from-kkr-gold to-kkr-gold text-center mt-3">Daftar Sekarang</a>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer class="border-t border-white/10 bg-kkr-dark/80 backdrop-blur-lg px-6 py-4">
        <div class="mx-auto max-w-7xl flex flex-col sm:flex-row items-center justify-between gap-2">
          <div class="flex items-center gap-3 text-sm">
            <a href="/" class="flex items-center gap-2 font-semibold text-white">
              <img src="/logo-header.png" alt="KKR RPPI logo" class="h-7 w-7 object-contain rounded-full" />
              KKR <span class="text-kkr-gold">RPPI</span>
            </a>
            <span class="text-white/30 hidden sm:inline">|</span>
            <span class="text-xs text-white/50 hidden sm:inline">Panitia KKR RPPI Kediri 2025/2026</span>
          </div>
          <div class="flex items-center gap-4 text-xs text-white/60" id="footer-contact">
            <span>Memuat...</span>
          </div>
        </div>
        <div class="mx-auto max-w-7xl mt-3 pt-3 border-t border-white/5 flex flex-wrap items-center justify-center gap-x-6 gap-y-1 text-xs text-white/40">
          <a href="/privacy" class="hover:text-kkr-gold transition-colors">Kebijakan Privasi</a>
          <a href="/terms" class="hover:text-kkr-gold transition-colors">Syarat & Ketentuan</a>
          <span>&copy; 2026 KKR RPPI. Hak cipta dilindungi.</span>
        </div>
      </footer>
    </div>

    <!-- Back to Top -->
    <button id="back-to-top" class="fixed bottom-6 left-6 z-50 w-12 h-12 rounded-full bg-gradient-to-r from-kkr-red to-kkr-gold text-white shadow-lg shadow-kkr-maroon/30 flex items-center justify-center opacity-0 translate-y-4 transition-all duration-300 hover:scale-105 active:scale-95" aria-label="Kembali ke atas">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15"/></svg>
    </button>

    <script>
      const menuBtn = document.getElementById("mobile-menu-btn");
      const mobileMenu = document.getElementById("mobile-menu");
      menuBtn?.addEventListener("click", () => {
        mobileMenu?.classList.toggle("hidden");
        const isOpen = !mobileMenu?.classList.contains("hidden");
        menuBtn.innerHTML = isOpen
          ? `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`
          : `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>`;
      });
      mobileMenu?.querySelectorAll("a").forEach(a => {
        a.addEventListener("click", () => {
          mobileMenu.classList.add("hidden");
          menuBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>`;
        });
      });

      const backToTop = document.getElementById("back-to-top");
      if (backToTop) {
        let ticking = false;
        window.addEventListener("scroll", () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              backToTop.classList.toggle("opacity-0", window.scrollY < 400);
              backToTop.classList.toggle("translate-y-4", window.scrollY < 400);
              backToTop.classList.toggle("opacity-100", window.scrollY >= 400);
              backToTop.classList.toggle("translate-y-0", window.scrollY >= 400);
              ticking = false;
            });
            ticking = true;
          }
        });
        backToTop.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }

      async function loadContact() {
        try {
          const res = await fetch("/api/settings");
          const d = await res.json();
          const s = d.settings || {};
          const el = document.getElementById("footer-contact");
          const email = s.contactEmail || "kkrrppi@gmail.com";
          const phone = s.contactPhone || "";
          const wa = s.contactWa || "6285800753804";
          let html = `<a href="mailto:${encodeURIComponent(email)}" class="hover:text-kkr-gold transition-colors">Email</a>`;
          html += `<span class="text-white/20">|</span><a href="https://wa.me/${wa.replace(/[^0-9]/g, "")}" target="_blank" class="hover:text-kkr-gold transition-colors">WhatsApp</a>`;
          if (phone) {
            html += `<span class="text-white/20">|</span><a href="tel:${phone.replace(/[^0-9+]/g, "")}" class="hover:text-kkr-gold transition-colors">Telp</a>`;
          }
          el.innerHTML = html;
        } catch {}
      }
      loadContact();
    </script>
  </body>
</html>
