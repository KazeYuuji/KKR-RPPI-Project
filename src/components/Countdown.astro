<section id="countdown" class="scroll-mt-20">
  <div class="mx-auto max-w-7xl px-6">
    <div class="rounded-[2.5rem] bg-gradient-to-br from-kkr-dark via-kkr-purple to-kkr-maroon p-8 sm:p-12 shadow-2xl shadow-kkr-dark/30 text-white relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(251,207,232,.08),_transparent_50%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,_rgba(251,191,36,.05),_transparent_50%)]"></div>

      <div class="relative space-y-10">
        <div class="flex flex-col sm:flex-row items-start justify-between gap-4">
          <div class="flex items-center gap-3">
            <img src="/logo-small.png" alt="Logo Gereja" class="h-14 w-14 sm:h-16 sm:w-16 rounded-full border-2 border-kkr-gold/40 bg-white p-1.5 object-contain shadow-lg shadow-kkr-gold/20" id="countdown-logo" />
            <img src="/logo-header.png" alt="KKR RPPI" class="h-14 w-14 sm:h-16 sm:w-16 rounded-full border-2 border-white/20 bg-white/10 p-1.5 object-contain shadow-lg" />
            <span class="text-xl sm:text-2xl font-bold text-white tracking-tight">KKR <span class="text-kkr-gold">RPPI</span></span>
          </div>
          <div class="text-left sm:text-right">
            <p id="countdown-subtitle" class="text-xs uppercase tracking-[0.3em] text-kkr-light font-semibold">Waktu Terus Berjalan</p>
            <h2 id="countdown-heading" class="text-2xl sm:text-3xl font-bold mt-0.5">Jangan Lewatkan!</h2>
            <div class="w-8 h-0.5 bg-kkr-red/50 mt-2 sm:ml-auto rounded-full"></div>
          </div>
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm">
            <p id="countdown-reg-label" class="text-kkr-light text-sm font-semibold uppercase tracking-wider">Segera Ditutup</p>
            <p class="text-kkr-gold text-lg font-semibold mt-1" id="reg-deadline-label">29 Desember 2025</p>
            <p id="countdown-reg-desc" class="text-sm text-kkr-light mt-2">Batas Pendaftaran Tiket</p>
            <div id="reg-countdown" class="grid grid-cols-4 gap-3 mt-5">
              {["Hari", "Jam", "Menit", "Detik"].map((label, i) => {
                const units = ["days", "hours", "minutes", "seconds"];
                return (
                <div class="bg-white/10 rounded-xl p-3 backdrop-blur-sm">
                  <p class="text-2xl sm:text-3xl font-bold tabular-nums" data-reg={label.toLowerCase()}>00</p>
                  <p data-unit={units[i]} class="text-xs text-kkr-light/80 mt-1 uppercase tracking-wider">{label}</p>
                </div>
              );})}
            </div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm">
            <p id="countdown-event-label" class="text-kkr-light text-sm font-semibold uppercase tracking-wider">Hari H</p>
            <p class="text-kkr-gold text-lg font-semibold mt-1" id="event-date-label">10 Januari 2026</p>
            <p id="countdown-event-desc" class="text-sm text-kkr-light mt-2">Menuju Puncak Acara</p>
            <div id="event-countdown" class="grid grid-cols-4 gap-3 mt-5">
              {["Hari", "Jam", "Menit", "Detik"].map((label, i) => {
                const units = ["days", "hours", "minutes", "seconds"];
                return (
                <div class="bg-white/10 rounded-xl p-3 backdrop-blur-sm">
                  <p class="text-2xl sm:text-3xl font-bold tabular-nums" data-event={label.toLowerCase()}>00</p>
                  <p data-unit={units[i]} class="text-xs text-kkr-light/80 mt-1 uppercase tracking-wider">{label}</p>
                </div>
              );})}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    let regTarget = Date.now() + 30 * 86400000;
    let eventTarget = Date.now() + 30 * 86400000;

    function startCountdown() {
      tick();
      setInterval(tick, 1000);
    }

    function parseWIBDate(str) {
      if (!str) return NaN;
      let dl = str;
      if (!dl.endsWith("Z") && !/[+-]\d{2}:\d{2}$/.test(dl)) dl += "+07:00";
      return new Date(dl).getTime();
    }

    (window.__SETTINGS_CACHE || fetch("/api/settings").then(r => r.json()).then(d => d.settings || {})).then(s => {
      const rt = parseWIBDate(s.regDeadlineISO);
      if (!isNaN(rt)) regTarget = rt;
      const et = parseWIBDate(s.eventDateISO);
      if (!isNaN(et)) eventTarget = et;

      const regLabel = document.getElementById("reg-deadline-label");
      const eventLabel = document.getElementById("event-date-label");
      const logo = document.getElementById("countdown-logo");
      if (logo && s.churchLogo) logo.src = s.churchLogo;
      if (s.regDeadline && regLabel) regLabel.textContent = s.regDeadline;
      if (s.locDate && eventLabel) eventLabel.textContent = s.locDate;
      if (s.countdownSubtitle && document.getElementById("countdown-subtitle")) document.getElementById("countdown-subtitle").textContent = s.countdownSubtitle;
      if (s.countdownHeading && document.getElementById("countdown-heading")) document.getElementById("countdown-heading").textContent = s.countdownHeading;
      if (s.countdownRegLabel && document.getElementById("countdown-reg-label")) document.getElementById("countdown-reg-label").textContent = s.countdownRegLabel;
      if (s.countdownRegDesc && document.getElementById("countdown-reg-desc")) document.getElementById("countdown-reg-desc").textContent = s.countdownRegDesc;
      if (s.countdownEventLabel && document.getElementById("countdown-event-label")) document.getElementById("countdown-event-label").textContent = s.countdownEventLabel;
      if (s.countdownEventDesc && document.getElementById("countdown-event-desc")) document.getElementById("countdown-event-desc").textContent = s.countdownEventDesc;

      const unitMap = {days: "countdownUnitDays", hours: "countdownUnitHours", minutes: "countdownUnitMinutes", seconds: "countdownUnitSeconds"};
      const unitFallbacks = {days: "Hari", hours: "Jam", minutes: "Menit", seconds: "Detik"};
      Object.entries(unitMap).forEach(([unit, key]) => {
        const val = s[key] || unitFallbacks[unit];
        document.querySelectorAll(`[data-unit="${unit}"]`).forEach(el => el.textContent = val);
      });

      startCountdown();
    }).catch(() => startCountdown());

    function updateCountdown(target, prefix) {
      const diff = Math.max(0, target - Date.now());
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const minutes = Math.floor((diff % 3600000) / 60000);
      const seconds = Math.floor((diff % 60000) / 1000);
      const map = { hari: days, jam: hours, menit: minutes, detik: seconds };
      Object.entries(map).forEach(([key, val]) => {
        const el = document.querySelector(`[data-${prefix}="${key}"]`);
        if (el) el.textContent = String(val).padStart(2, "0");
      });
    }

    function tick() {
      updateCountdown(regTarget, "reg");
      updateCountdown(eventTarget, "event");
    }
  </script>
</section>
