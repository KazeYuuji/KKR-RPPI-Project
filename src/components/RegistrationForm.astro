---
export interface TicketType {
  id: string;
  name: string;
  remaining: number;
}
---

<section>
  <div class="space-y-2 mb-4">
    <p class="inline-flex rounded-full bg-kkr-light px-2.5 py-0.5 text-[11px] font-semibold text-kkr-red">Registrasi Tiket</p>
    <h2 id="form-title" class="text-xl font-semibold tracking-tight text-kkr-dark">Formulir Pendaftaran</h2>
    <p id="form-subtitle" class="text-xs text-kkr-maroon">Lengkapi data diri untuk dapatkan tiket.</p>
  </div>

  <form id="registration-form" class="space-y-3">
    <div class="grid gap-2.5 sm:grid-cols-2">
      <label class="block">
        <span class="text-[11px] font-medium text-kkr-purple">Nama Lengkap *</span>
        <input name="name" required class="mt-1 w-full rounded-lg border border-kkr-light/70 bg-white px-3 py-2 text-sm text-kkr-dark outline-none transition focus:border-kkr-red focus:ring-2 focus:ring-kkr-maroon/20" placeholder="Nama sesuai identitas" />
      </label>
      <label id="school-field" class="block">
        <span class="text-[11px] font-medium text-kkr-purple">Sekolah / Instansi <span id="school-required" class="text-kkr-red">*</span></span>
        <input name="school" required class="mt-1 w-full rounded-lg border border-kkr-light/70 bg-white px-3 py-2 text-sm text-kkr-dark outline-none transition focus:border-kkr-red focus:ring-2 focus:ring-kkr-maroon/20" placeholder="Nama sekolah/instansi" />
      </label>
    </div>

    <div class="grid gap-2.5 sm:grid-cols-2">
      <label class="block">
        <span class="text-[11px] font-medium text-kkr-purple">Email *</span>
        <input type="email" name="email" required class="mt-1 w-full rounded-lg border border-kkr-light/70 bg-white px-3 py-2 text-sm text-kkr-dark outline-none transition focus:border-kkr-red focus:ring-2 focus:ring-kkr-maroon/20" placeholder="contoh@email.com" />
      </label>
      <label class="block">
        <span class="text-[11px] font-medium text-kkr-purple">WhatsApp *</span>
        <input name="whatsapp" required class="mt-1 w-full rounded-lg border border-kkr-light/70 bg-white px-3 py-2 text-sm text-kkr-dark outline-none transition focus:border-kkr-red focus:ring-2 focus:ring-kkr-maroon/20" placeholder="0812xxxxxxx" />
      </label>
    </div>

    <div class="space-y-2.5">
      <div>
        <p class="text-[11px] font-medium text-kkr-purple">Status Peserta</p>
        <div class="mt-1.5 grid grid-cols-2 gap-2">
          {[
            { value: "Student", label: "Pelajar" },
            { value: "General", label: "Umum" },
          ].map((option) => (
            <label class="cursor-pointer rounded-lg border border-kkr-light/70 bg-white px-3 py-2 text-center text-xs font-semibold text-kkr-purple transition has-checked:border-kkr-red has-checked:bg-kkr-light has-checked:text-kkr-red hover:border-kkr-maroon">
              <input type="radio" name="status" value={option.value} class="sr-only" checked={option.value === "Student"} data-status={option.value} />
              {option.label}
            </label>
          ))}
        </div>
      </div>

      <label class="block">
        <span class="text-[11px] font-medium text-kkr-purple">Jenis Tiket *</span>
        <div class="relative mt-1">
          <select id="ticket-select" name="ticketType" required class="w-full rounded-lg border border-kkr-light/70 bg-white px-3 py-2 text-sm text-kkr-dark outline-none transition focus:border-kkr-red focus:ring-2 focus:ring-kkr-maroon/20"></select>
          <div id="ticket-stock" class="mt-1 flex flex-wrap gap-1"></div>
        </div>
      </label>
    </div>

    <button type="submit" id="submit-btn" class="w-full rounded-lg bg-gradient-to-r from-kkr-red to-kkr-gold px-4 py-2.5 text-sm font-semibold text-white shadow-md shadow-kkr-maroon/20 transition hover:shadow-lg hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed">
      Konfirmasi Pendaftaran
    </button>
  </form>

  <div id="success-modal" class="pointer-events-none fixed inset-0 z-[60] flex items-center justify-center bg-black/40 backdrop-blur-sm opacity-0 transition-all duration-300 p-3 sm:p-4">
    <div class="relative w-full max-w-xl rounded-2xl bg-white shadow-2xl shadow-black/10 animate-scale-in overflow-hidden">
      <button id="modal-close" class="absolute right-3 top-3 z-10 rounded-full bg-white/80 backdrop-blur p-1.5 text-kkr-dark/50 shadow-sm transition hover:bg-white hover:text-kkr-dark hover:shadow-md" aria-label="Tutup">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <div class="flex flex-col sm:flex-row">
        <div class="sm:w-3/5 px-5 pt-7 pb-5 sm:border-r border-kkr-light/30">
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-emerald-50 shadow-inner shadow-emerald-200/50">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 id="success-title" class="text-base font-bold text-kkr-dark tracking-tight">Pendaftaran Berhasil!</h3>
              <p id="success-subtitle" class="text-[11px] text-kkr-maroon/70 mt-0.5">Simpan nomor tiket dan cek info selanjutnya.</p>
            </div>
          </div>
          <div class="mt-4 grid grid-cols-2 gap-2">
            <div class="rounded-xl bg-gradient-to-br from-kkr-light/60 to-white p-3 shadow-sm border border-kkr-light/40">
              <p class="text-[10px] font-medium uppercase tracking-wider text-kkr-maroon/60">Nomor Tiket</p>
              <p id="ticket-code" class="mt-1 text-sm font-bold text-kkr-dark select-all tracking-wide">-</p>
            </div>
            <div class="rounded-xl bg-gradient-to-br from-kkr-light/60 to-white p-3 shadow-sm border border-kkr-light/40">
              <p class="text-[10px] font-medium uppercase tracking-wider text-kkr-maroon/60">Jenis Tiket</p>
              <p id="ticket-name" class="mt-1 text-sm font-bold text-kkr-dark">-</p>
            </div>
          </div>
          <div class="mt-3 rounded-xl bg-gradient-to-br from-blue-50/80 to-white p-3 border border-blue-100/60 shadow-sm">
            <p class="font-semibold text-blue-800 mb-1 flex items-center gap-1 text-xs">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Langkah Selanjutnya
            </p>
            <ol class="list-decimal pl-4 text-blue-700/80 text-[11px] leading-relaxed space-y-0.5">
              <li>Simpan nomor tiket (screenshot atau catat).</li>
              <li>Cetak tiket PDF atau tunjukkan dari ponsel saat check-in.</li>
              <li id="success-step-3">Hadiri acara pada <strong>Sabtu, 10 Januari 2026</strong> di <strong>Kediri</strong>.</li>
            </ol>
          </div>
        </div>
        <div class="sm:w-2/5 px-5 pt-5 pb-5 flex flex-col items-center justify-center sm:pt-7">
          <div class="rounded-xl bg-white p-2 shadow-sm border border-kkr-light/30">
            <canvas id="qr-code-canvas" width="110" height="110" class="block"></canvas>
          </div>
          <div class="mt-4 w-full space-y-2">
            <a id="pdf-download-btn" href="#" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-kkr-red to-kkr-gold px-4 py-2.5 text-sm font-semibold text-white shadow-md shadow-kkr-maroon/20 transition hover:shadow-lg hover:-translate-y-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
              Cetak Tiket (PDF)
            </a>
            <a id="wa-group-link" href="https://chat.whatsapp.com/KKRRPPI2026" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 rounded-xl border border-emerald-200 bg-gradient-to-br from-emerald-50 to-white px-4 py-2.5 text-sm font-semibold text-emerald-700 shadow-sm transition hover:shadow-md hover:-translate-y-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              Gabung Grup WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    import QRCode from "qrcode";

    const form = document.getElementById("registration-form");
    const select = document.getElementById("ticket-select");
    const btn = document.getElementById("submit-btn");
    const modal = document.getElementById("success-modal");
    const closeModalBtn = document.getElementById("modal-close");
    const codeEl = document.getElementById("ticket-code");
    const nameEl = document.getElementById("ticket-name");
    const stockEl = document.getElementById("ticket-stock");
    const pdfBtn = document.getElementById("pdf-download-btn");
    const qrCanvas = document.getElementById("qr-code-canvas");

    function escapeHtml(str) {
      if (str == null) return "";
      return String(str).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }

    let lastTicketId = "";
    let deadlinePassed = false;

    async function loadTickets() {
      try {
        const res = await fetch("/api/tickets");
        const d = await res.json();
        const tickets = d.tickets || [];
        const prevVal = select.value;

        renderTicketOptions(tickets);
        renderStockIndicators(tickets);

        if (prevVal && [...select.options].some(o => o.value === prevVal && !o.disabled)) {
          select.value = prevVal;
        }
        validateSubmit();
      } catch {
        select.innerHTML = `<option value="general">General Admission</option><option value="early">Early Bird</option>`;
      }
    }

    function renderTicketOptions(tickets) {
      select.innerHTML = tickets.map(t => {
        const habis = t.remaining <= 0;
        return `<option value="${escapeHtml(String(t.id))}" ${habis ? "disabled" : ""}>${escapeHtml(t.name)}${habis ? " (Habis)" : " — Sisa " + t.remaining}</option>`;
      }).join("");
    }

    function renderStockIndicators(tickets) {
      stockEl.innerHTML = tickets.map(t => {
        const habis = t.remaining <= 0;
        return `<span class="inline-flex items-center gap-1 text-[11px] px-2 py-0.5 rounded-full font-medium ${habis ? "bg-red-50 text-red-600" : "bg-emerald-50 text-emerald-700"}">
          <span class="w-1.5 h-1.5 rounded-full ${habis ? "bg-red-400" : "bg-emerald-400"}"></span>
          ${escapeHtml(t.name)}: ${habis ? "Habis" : t.remaining}
        </span>`;
      }).join("");
    }

    function validateSubmit() {
      const opt = select.selectedOptions[0];
      if (opt && opt.disabled) {
        btn.disabled = true;
        btn.textContent = "Tiket sudah habis";
        return;
      }
      btn.disabled = false;
      btn.textContent = "Konfirmasi Pendaftaran";
    }

    select.addEventListener("change", validateSubmit);

    function genId() {
      return "KR-" + Date.now().toString(36).toUpperCase() + Math.random().toString(36).substring(2, 5).toUpperCase();
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (deadlinePassed) {
        alert("Pendaftaran telah ditutup.");
        return;
      }

      const selectedOpt = select.selectedOptions[0];
      if (selectedOpt?.disabled) {
        alert("Tiket yang dipilih sudah habis. Silakan pilih tiket lain.");
        return;
      }

      const data = new FormData(form);
      const id = genId();
      const participantType = data.get("status")?.toString() || "Student";
      const schoolVal = participantType === "Student" ? (data.get("school")?.toString().trim() || "-") : "";
      const ticketType = data.get("ticketType")?.toString() || "general";
      const payload = {
        id,
        name: data.get("name")?.toString().trim() || "-",
        school: schoolVal,
        email: data.get("email")?.toString().trim() || "",
        whatsapp: data.get("whatsapp")?.toString().trim() || "",
        participant_type: participantType,
        ticket: ticketType,
        checked_in: 0,
      };

      btn.disabled = true;
      btn.textContent = "Memproses...";

      try {
        const res = await fetch("/api/registrants", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        const result = await res.json();
        if (res.ok) {
          lastTicketId = id;
          codeEl.textContent = id;
          const opt = select.selectedOptions[0];
          nameEl.textContent = opt ? opt.textContent?.trim().replace(/\s*\(.*\)/, "") || ticketType : ticketType;
          pdfBtn.href = "/api/ticket-pdf/" + id;
          QRCode.toCanvas(qrCanvas, id, { width: 110, margin: 2, color: { dark: "#1a1a1f", light: "#ffffff" } });
          modal.classList.remove("pointer-events-none", "opacity-0");
          form.reset();
          toggleSchoolField();
          loadTickets();
        } else {
          alert(result.error || "Gagal mendaftar");
        }
      } catch {
        alert("Terjadi kesalahan. Silakan coba lagi.");
      } finally {
        if (!btn.dataset.preventReset) {
          btn.disabled = false;
          btn.textContent = "Konfirmasi Pendaftaran";
        }
        validateSubmit();
      }
    });

    closeModalBtn.addEventListener("click", () => {
      modal.classList.add("pointer-events-none", "opacity-0");
    });
    modal.addEventListener("click", (e) => {
      if (e.target === modal) modal.classList.add("pointer-events-none", "opacity-0");
    });

    function toggleSchoolField() {
      const selected = document.querySelector('input[name="status"]:checked');
      const schoolField = document.getElementById("school-field");
      const schoolInput = schoolField?.querySelector('input[name="school"]');
      if (selected && selected.value === "General") {
        schoolField.classList.add("hidden");
        schoolInput.removeAttribute("required");
      } else {
        schoolField.classList.remove("hidden");
        schoolInput.setAttribute("required", "");
      }
    }

    document.querySelectorAll('input[name="status"]').forEach(el => {
      el.addEventListener("change", toggleSchoolField);
    });

    async function checkDeadline() {
      try {
        const s = await (window.__SETTINGS_CACHE || fetch("/api/settings").then(r => r.json()).then(d => d.settings || {}));
        if (s.regDeadlineISO) {
          let dl = s.regDeadlineISO;
          if (!dl.endsWith("Z") && !/[+-]\d{2}:\d{2}$/.test(dl)) dl += "+07:00";
          const deadline = new Date(dl).getTime();
          if (Date.now() > deadline) {
            deadlinePassed = true;
            form.querySelectorAll("input, select, button").forEach(el => el.disabled = true);
            form.innerHTML = `<div class="rounded-2xl bg-red-50 p-8 text-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-red-500 mx-auto" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <h3 class="mt-4 text-xl font-semibold text-red-700">Pendaftaran Ditutup</h3>
              <p class="mt-2 text-red-600/80">Batas waktu pendaftaran telah berakhir. Terima kasih atas minat Anda.</p>
            </div>`;
          }
        }
      } catch {}
    }

    document.addEventListener("DOMContentLoaded", () => {
      loadTickets();
      checkDeadline();
      toggleSchoolField();
      document.addEventListener("visibilitychange", () => { if (!document.hidden) loadTickets(); });
      (window.__SETTINGS_CACHE || fetch("/api/settings").then(r => r.json()).then(d => d.settings || {})).then(s => {
        const step3 = document.getElementById("success-step-3");
        if (step3 && s.locDate && s.locVenue) {
          step3.innerHTML = "Hadiri acara pada <strong>" + escapeHtml(s.locDate) + "</strong> di <strong>" + escapeHtml(s.locVenue.split(",")[0].trim()) + "</strong>.";
        }
        const waLink = document.getElementById("wa-group-link");
        if (waLink && s.waGroupLink) waLink.href = s.waGroupLink;
      }).catch(() => {});
    });
  </script>
</section>
