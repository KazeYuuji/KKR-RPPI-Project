---
const faqs = [
  { q: "Apa itu KKR RPPI?", a: "KKR RPPI adalah kebaktian kebangunan rohani yang mempersatukan siswa, alumni, guru, dan masyarakat untuk mengalami kebangunan rohani dalam Yesus Kristus." },
  { q: "Kapan dan di mana acara dilaksanakan?", a: "Acara akan dilaksanakan pada @date di @venue. Mulai pukul @time." },
  { q: "Bagaimana cara mendaftar?", a: "Kunjungi halaman pendaftaran, isi data diri, pilih tiket gratis, dan dapatkan tiketmu langsung!" },
  { q: "Berapa harga tiketnya?", a: "Gratis! Semua tiket tersedia tanpa biaya. Daftar sekarang dan amankan tiketmu." },
  { q: "Bagaimana cara menghubungi panitia?", a: "Anda dapat menghubungi kami via WhatsApp di @wa atau email ke @email." },
];
---

<div id="chatbot" class="fixed bottom-20 right-4 sm:right-6 z-50 flex flex-col items-end gap-3">
  <div id="chat-window" class="hidden w-[340px] sm:w-[380px] bg-white rounded-2xl shadow-2xl border border-kkr-light/50 overflow-hidden animate-scale-in origin-bottom-right flex flex-col" style="max-height:520px">
    <div class="bg-gradient-to-r from-kkr-maroon to-kkr-red p-4 text-white shrink-0">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-white/20 flex items-center justify-center text-xs font-bold">AI</div>
        <div>
          <p class="font-semibold text-sm">Elias</p>
          <p class="text-xs text-kkr-light">Asisten KKR RPPI</p>
        </div>
        <button id="chat-close" class="ml-auto p-1 rounded-lg hover:bg-white/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>
    <div id="chat-body" class="flex-1 p-4 overflow-y-auto space-y-3" style="min-height:200px;max-height:320px">
      <div class="flex gap-2 items-start">
        <div class="w-7 h-7 rounded-full bg-kkr-light/70 flex items-center justify-center text-[10px] font-bold text-kkr-red shrink-0">AI</div>
        <div class="bg-kkr-light/40 rounded-2xl rounded-tl-sm px-4 py-2.5 text-sm text-kkr-purple">
          Halo! Saya <strong>Elias</strong>, asisten KKR RPPI. Ada yang bisa saya bantu?
        </div>
      </div>
      <div id="quick-questions" class="flex flex-wrap gap-2 pt-1">
        {faqs.slice(0, 3).map((faq) => (
          <button data-question={faq.q} class="text-xs bg-kkr-light text-kkr-red px-3 py-1.5 rounded-full hover:bg-kkr-light/70 transition-colors font-medium">{faq.q}</button>
        ))}
      </div>
    </div>
    <div class="border-t border-kkr-light/40 p-3 flex gap-2 shrink-0">
      <input id="chat-input" type="text" placeholder="Ketik pesan..." class="flex-1 rounded-xl border border-kkr-light/60 bg-kkr-light/20 px-3.5 py-2 text-sm text-kkr-dark outline-none transition focus:border-kkr-red/50 focus:bg-white focus:ring-2 focus:ring-kkr-red/10 placeholder:text-kkr-dark/30" />
      <button id="chat-send" class="rounded-xl bg-gradient-to-r from-kkr-red to-kkr-gold px-3.5 py-2 text-white shadow-md hover:shadow-lg transition-all disabled:opacity-50" disabled>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
  </div>
  <button id="chat-toggle" class="w-14 h-14 rounded-full bg-gradient-to-r from-kkr-red to-kkr-gold text-white shadow-lg shadow-kkr-maroon/30 flex items-center justify-center hover:scale-105 transition-transform active:scale-95">
    <svg id="chat-icon" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    <svg id="close-icon" class="hidden w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
</div>

<script define:vars={{ faqs }}>
  const toggle = document.getElementById("chat-toggle");
  const chatWindow = document.getElementById("chat-window");
  const close = document.getElementById("chat-close");
  const chatIcon = document.getElementById("chat-icon");
  const closeIcon = document.getElementById("close-icon");
  const body = document.getElementById("chat-body");
  const input = document.getElementById("chat-input");
  const sendBtn = document.getElementById("chat-send");
  const QS = document.getElementById("quick-questions");

  window.__CHAT_SESSION_ID = "chat_" + Date.now().toString(36) + Math.random().toString(36).substring(2, 6);
  let isSending = false;

  function addBotMessage(text) {
    const div = document.createElement("div");
    div.className = "flex gap-2 items-start";
    const avatar = document.createElement("div");
    avatar.className = "w-7 h-7 rounded-full bg-kkr-light/70 flex items-center justify-center text-[10px] font-bold text-kkr-red shrink-0";
    avatar.textContent = "AI";
    const msg = document.createElement("div");
    msg.className = "bg-kkr-light/40 rounded-2xl rounded-tl-sm px-4 py-2.5 text-sm text-kkr-purple";
    msg.style.whiteSpace = "pre-wrap";
    msg.textContent = text;
    div.appendChild(avatar);
    div.appendChild(msg);
    body.appendChild(div);
    body.scrollTop = body.scrollHeight;
  }

  function addUserMessage(text) {
    const div = document.createElement("div");
    div.className = "flex gap-2 items-start flex-row-reverse";
    const avatar = document.createElement("div");
    avatar.className = "w-7 h-7 rounded-full bg-gradient-to-br from-kkr-red to-kkr-gold flex items-center justify-center text-[10px] font-bold text-white shrink-0";
    avatar.textContent = "U";
    const msg = document.createElement("div");
    msg.className = "bg-gradient-to-br from-kkr-red/10 to-kkr-gold/10 rounded-2xl rounded-tr-sm px-4 py-2.5 text-sm text-kkr-dark";
    msg.style.whiteSpace = "pre-wrap";
    msg.textContent = text;
    div.appendChild(avatar);
    div.appendChild(msg);
    body.appendChild(div);
    body.scrollTop = body.scrollHeight;
  }

  function addTypingIndicator() {
    const div = document.createElement("div");
    div.className = "flex gap-2 items-start";
    div.id = "typing-indicator";
    const avatar = document.createElement("div");
    avatar.className = "w-7 h-7 rounded-full bg-kkr-light/70 flex items-center justify-center text-[10px] font-bold text-kkr-red shrink-0";
    avatar.textContent = "AI";
    const msg = document.createElement("div");
    msg.className = "bg-kkr-light/40 rounded-2xl rounded-tl-sm px-4 py-3 text-sm text-kkr-purple";
    msg.innerHTML = '<div class="flex gap-1"><span class="w-2 h-2 rounded-full bg-kkr-red/40 animate-bounce" style="animation-delay:0ms"></span><span class="w-2 h-2 rounded-full bg-kkr-red/40 animate-bounce" style="animation-delay:150ms"></span><span class="w-2 h-2 rounded-full bg-kkr-red/40 animate-bounce" style="animation-delay:300ms"></span></div>';
    div.appendChild(avatar);
    div.appendChild(msg);
    body.appendChild(div);
    body.scrollTop = body.scrollHeight;
  }

  function removeTypingIndicator() {
    const el = document.getElementById("typing-indicator");
    if (el) el.remove();
  }

  async function sendMessage(text) {
    if (isSending || !text.trim()) return;
    isSending = true;
    sendBtn.disabled = true;
    input.disabled = true;

    addUserMessage(text.trim());
    QS?.classList.add("hidden");
    addTypingIndicator();

    try {
      const res = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ message: text.trim(), sessionId: window.__CHAT_SESSION_ID || "default" }),
      });
      const data = await res.json();
      removeTypingIndicator();
      if (data.reply) {
        addBotMessage(data.reply);
      } else {
        addBotMessage("Maaf, saya tidak bisa menjawab pertanyaan itu saat ini. Silakan coba lagi.");
      }
    } catch {
      removeTypingIndicator();
      addBotMessage("Maaf, terjadi gangguan. Silakan coba lagi nanti.");
    }

    isSending = false;
    sendBtn.disabled = false;
    input.disabled = false;
    input.focus();
  }

  input.addEventListener("keydown", (e) => {
    if (e.key === "Enter") sendMessage(input.value);
  });

  sendBtn.addEventListener("click", () => {
    sendMessage(input.value);
    input.value = "";
  });

  input.addEventListener("input", () => {
    sendBtn.disabled = !input.value.trim() || isSending;
  });

  toggle.addEventListener("click", () => {
    const isOpen = !chatWindow.classList.contains("hidden");
    chatWindow.classList.toggle("hidden");
    chatIcon.classList.toggle("hidden", !isOpen);
    closeIcon.classList.toggle("hidden", isOpen);
    if (!isOpen) input.focus();
  });

  close.addEventListener("click", () => {
    chatWindow.classList.add("hidden");
    chatIcon.classList.remove("hidden");
    closeIcon.classList.add("hidden");
  });

  (window.__SETTINGS_CACHE || fetch("/api/settings").then(r=>r.json()).then(d=>d.settings||{})).then(s=>{
    const venue=s.locVenue||"GPI IMANUEL Kediri";
    const date=s.locDate||"Sabtu, 10 Januari 2026";
    const time=s.locTime||"08.00 - 12.30 WIB";
    const wa=(s.contactWa||"6285800753804").replace(/^0+/,"+62 ").replace(/(\d{4})(\d{4})(\d{4})/,"$1-$2-$3");
    const email=s.contactEmail||"kkrrppi@gmail.com";
    faqs.forEach(f=>{
      f.a=f.a.replace("@date",date).replace("@venue",venue).replace("@time",time).replace("@wa",wa).replace("@email",email);
    });
  }).catch(()=>{});

  body.addEventListener("click", (e) => {
    const btn = e.target.closest("[data-question]");
    if (btn) {
      const q = btn.dataset.question;
      const faq = faqs.find(f => f.q === q);
      if (faq) {
        sendMessage(q);
        input.value = "";
        sendBtn.disabled = true;
      }
    }
  });
</script>
