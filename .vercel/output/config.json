{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/me/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/registrants/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/settings/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/speakers/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/speakers/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/sponsors/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/sponsors/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/stats/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/ticket-pdf/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/tickets/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/upload/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/uploads(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/analytics/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/settings/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/speakers/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/sponsors/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/?$",
			"dest": "_render"
		},
		{
			"src": "^/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/registration/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}