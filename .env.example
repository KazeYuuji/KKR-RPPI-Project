# MinIO S3-compatible storage
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=your-access-key
# MINIO_SECRET_KEY=your-secret-key
# MINIO_BUCKET=your-bucket-name

# JWT secret for admin authentication (generate with: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-random-64-char-hex-string

# Google Gemini AI API Key (free: https://aistudio.google.com/apikey)
# Jika tidak diisi, chatbot akan menggunakan mode pintar tanpa AI
GEMINI_API_KEY=
